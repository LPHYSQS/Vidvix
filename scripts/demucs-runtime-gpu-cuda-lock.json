{
  "outputZipPath": "Tools/Demucs/Packages/demucs-runtime-win-x64-gpu-cuda.zip",
  "python": {
    "version": "3.10.11",
    "embedUrl": "https://www.python.org/ftp/python/3.10.11/python-3.10.11-embed-amd64.zip",
    "getPipUrl": "https://bootstrap.pypa.io/get-pip.py"
  },
  "baseRuntimeArchivePath": "Tools/Demucs/Packages/demucs-runtime-win-x64-cpu.zip",
  "bootstrapPackages": [
    "pip==25.0.1"
  ],
  "pipInstallArguments": [
    "--force-reinstall",
    "--no-deps"
  ],
  "prefetchPackageUrls": [
    "https://download-r2.pytorch.org/whl/cu124/torch-2.4.1%2Bcu124-cp310-cp310-win_amd64.whl",
    "https://download-r2.pytorch.org/whl/cu124/torchaudio-2.4.1%2Bcu124-cp310-cp310-win_amd64.whl",
    "https://download-r2.pytorch.org/whl/cu124/torchvision-0.19.1%2Bcu124-cp310-cp310-win_amd64.whl"
  ],
  "runtimePackages": [],
  "importCheckScriptLines": [
    "import demucs",
    "import soundfile",
    "import torch",
    "import torchaudio",
    "",
    "backends = list(getattr(torchaudio, \"list_audio_backends\", lambda: [])())",
    "if \"soundfile\" not in backends:",
    "    raise RuntimeError(f\"soundfile backend missing: {backends}\")",
    "if not torch.cuda.is_available():",
    "    raise RuntimeError(\"torch.cuda.is_available() returned False\")",
    "",
    "print(f\"demucs={demucs.__version__}\")",
    "print(f\"torch={torch.__version__}\")",
    "print(f\"torchaudio={torchaudio.__version__}\")",
    "print(f\"soundfile={soundfile.__version__}\")",
    "print(f\"torch_cuda={torch.version.cuda}\")",
    "print(f\"torch_cuda_devices={torch.cuda.device_count()}\")",
    "print(f\"torch_cuda_device_0={torch.cuda.get_device_name(0)}\")"
  ]
}
