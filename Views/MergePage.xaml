<Page
    x:Class="Vidvix.Views.MergePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Vidvix.Core.Models"
    x:Name="RootPage"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="MergeMediaListViewItemStyle"
            TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="AllowDrop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            ContentTransitions="{TemplateBinding ContentTransitions}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="MergeMediaRemoveButtonStyle"
            TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <Style
            x:Key="MergeMediaTypeTextStyle"
            TargetType="TextBlock"
            BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Padding="16"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="素材列表" />
                    <TextBlock
                        Opacity="0.72"
                        Text="支持导入视频或音频文件。单击素材列表中的素材可添加到相应轨道。"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Button
                    Grid.Row="1"
                    Command="{x:Bind ViewModel.ImportFilesCommand, Mode=OneWay}"
                    HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="OpenFile" />
                        <TextBlock Text="导入文件" />
                    </StackPanel>
                </Button>

                <Grid Grid.Row="2">
                    <ListView
                        Background="Transparent"
                        BorderThickness="0"
                        IsItemClickEnabled="True"
                        ItemContainerStyle="{StaticResource MergeMediaListViewItemStyle}"
                        ItemClick="OnMediaItemClick"
                        ItemsSource="{x:Bind ViewModel.MediaItems, Mode=OneWay}"
                        Padding="0"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:MediaItem">
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="12,10"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    ToolTipService.ToolTip="{x:Bind SourcePath, Mode=OneWay}">
                                    <Grid
                                        ColumnSpacing="10"
                                        RowSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock
                                            FontWeight="SemiBold"
                                            MaxLines="1"
                                            Text="{x:Bind FileName}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Style="{StaticResource MergeMediaTypeTextStyle}"
                                            Text="{x:Bind TypeDisplayText}" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="{x:Bind DurationText}" />

                                        <Button
                                            Grid.Column="2"
                                            Grid.RowSpan="2"
                                            Click="OnRemoveMediaItemClick"
                                            Style="{StaticResource MergeMediaRemoveButtonStyle}"
                                            ToolTipService.ToolTip="移除素材">
                                            <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="180"
                        Opacity="0.72"
                        Text="导入后素材会显示在这里。"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        Visibility="{x:Bind ViewModel.MediaItemsEmptyVisibility, Mode=OneWay}" />
                </Grid>
            </Grid>
        </Border>

        <Border
            Grid.Column="1"
            Padding="16"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="合并工作区" />
                    <TextBlock
                        Opacity="0.72"
                        Text="在不同合并模式之间切换，按需将素材编排到视频轨道或音频轨道。"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    HorizontalAlignment="Left"
                    Padding="4"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                    <StackPanel Orientation="Horizontal" Spacing="8">

                        <RadioButton
                            GroupName="MergeMode"
                            IsChecked="{x:Bind ViewModel.IsVideoJoinModeSelected, Mode=TwoWay}"
                            Style="{StaticResource MergeModeSegmentRadioButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border
                                    Width="34"
                                    Height="34"
                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                    CornerRadius="10">
                                    <SymbolIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Symbol="Video" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="视频拼接"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            GroupName="MergeMode"
                            IsChecked="{x:Bind ViewModel.IsAudioJoinModeSelected, Mode=TwoWay}"
                            Style="{StaticResource MergeModeSegmentRadioButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border
                                    Width="34"
                                    Height="34"
                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                    CornerRadius="10">
                                    <SymbolIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Symbol="Audio" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="音频拼接"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            GroupName="MergeMode"
                            IsChecked="{x:Bind ViewModel.IsAudioVideoComposeModeSelected, Mode=TwoWay}"
                            Style="{StaticResource MergeModeSegmentRadioButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border
                                    Width="34"
                                    Height="34"
                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                    CornerRadius="10">
                                    <Grid>
                                        <SymbolIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Symbol="Video" />
                                        <Border
                                            Width="12"
                                            Height="12"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,1,1"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="6">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="7"
                                                FontWeight="SemiBold"
                                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                Text="♪" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="音视频合成"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <TextBlock
                    Grid.Row="2"
                    Opacity="0.72"
                    Text="{x:Bind ViewModel.TimelineHintText, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />

                <Grid
                    Grid.Row="3"
                    RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Padding="14"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        CornerRadius="16">
                        <Grid RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="视频轨道" />
                            <TextBlock
                                Grid.Column="1"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.VideoTrackSummaryText, Mode=OneWay}" />

                            <Grid Grid.ColumnSpan="2" Margin="0,32,0,0" MinHeight="116">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled">
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.VideoTrackItems, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="10" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:TrackItem">
                                                <Border
                                                    Width="{x:Bind VisualWidth}"
                                                    MinWidth="120"
                                                    Height="92"
                                                    Padding="12"
                                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                    <Grid RowSpacing="8">
                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Text="{x:Bind DisplayName}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <StackPanel VerticalAlignment="Bottom" Spacing="4">
                                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind TypeDisplayText}" />
                                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind DurationText}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Opacity="0.72"
                                    Text="{x:Bind ViewModel.VideoTrackEmptyText, Mode=OneWay}"
                                    TextAlignment="Center"
                                    TextWrapping="WrapWholeWords"
                                    Visibility="{x:Bind ViewModel.VideoTrackEmptyVisibility, Mode=OneWay}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Padding="14"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        CornerRadius="16">
                        <Grid RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="音频轨道" />
                            <TextBlock
                                Grid.Column="1"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.AudioTrackSummaryText, Mode=OneWay}" />

                            <Grid Grid.ColumnSpan="2" Margin="0,32,0,0" MinHeight="116">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled">
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.AudioTrackItems, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="10" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:TrackItem">
                                                <Border
                                                    Width="{x:Bind VisualWidth}"
                                                    MinWidth="120"
                                                    Height="92"
                                                    Padding="12"
                                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                                    BorderBrush="{ThemeResource TextFillColorSecondaryBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                    <Grid RowSpacing="8">
                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Text="{x:Bind DisplayName}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <StackPanel VerticalAlignment="Bottom" Spacing="4">
                                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind TypeDisplayText}" />
                                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind DurationText}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Opacity="0.72"
                                    Text="{x:Bind ViewModel.AudioTrackEmptyText, Mode=OneWay}"
                                    TextAlignment="Center"
                                    TextWrapping="WrapWholeWords"
                                    Visibility="{x:Bind ViewModel.AudioTrackEmptyVisibility, Mode=OneWay}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border
            Grid.Column="2"
            Padding="16"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="输出设置" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="输出格式" />
                        <ComboBox
                            ItemsSource="{x:Bind ViewModel.OutputFormats, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedOutputFormat, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="输出路径" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                Text="{x:Bind ViewModel.OutputPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="可选择导出目录，当前阶段暂不执行真实导出。" />
                            <Button
                                Grid.Column="1"
                                Command="{x:Bind ViewModel.BrowseOutputPathCommand, Mode=OneWay}"
                                Content="浏览" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="分辨率处理" />
                        <RadioButton
                            Content="统一为第一段视频"
                            GroupName="ResolutionStrategy"
                            IsChecked="{x:Bind ViewModel.IsMatchFirstVideoResolutionSelected, Mode=TwoWay}" />
                        <RadioButton
                            Content="填充黑边"
                            GroupName="ResolutionStrategy"
                            IsChecked="{x:Bind ViewModel.IsPadWithBlackBarsSelected, Mode=TwoWay}" />
                        <RadioButton
                            Content="拉伸填充"
                            GroupName="ResolutionStrategy"
                            IsChecked="{x:Bind ViewModel.IsStretchToFillSelected, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="时长策略" />
                        <RadioButton
                            Content="以视频为准"
                            GroupName="DurationStrategy"
                            IsChecked="{x:Bind ViewModel.IsVideoPrioritySelected, Mode=TwoWay}" />
                        <RadioButton
                            Content="以音频为准"
                            GroupName="DurationStrategy"
                            IsChecked="{x:Bind ViewModel.IsAudioPrioritySelected, Mode=TwoWay}" />
                        <RadioButton
                            Content="自动循环"
                            GroupName="DurationStrategy"
                            IsChecked="{x:Bind ViewModel.IsAutoLoopSelected, Mode=TwoWay}" />
                    </StackPanel>

                    <Button
                        Click="OnExportButtonClick"
                        HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Save" />
                            <TextBlock Text="导出" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
