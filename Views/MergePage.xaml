<Page
    x:Class="Vidvix.Views.MergePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Vidvix.Core.Models"
    x:Name="RootPage"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="MergeMediaListViewItemStyle"
            TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="AllowDrop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            ContentTransitions="{TemplateBinding ContentTransitions}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="MergeMediaRemoveButtonStyle"
            TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <Style
            x:Key="MergeMediaTypeTextStyle"
            TargetType="TextBlock"
            BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="MergeTrackListViewItemStyle"
            TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
        </Style>

        <Style
            x:Key="MergeTrackActionButtonStyle"
            TargetType="Button">
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="MergeTrackEmptyTextStyle"
            TargetType="TextBlock"
            BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MaxWidth" Value="420" />
            <Setter Property="Opacity" Value="0.72" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <DataTemplate
            x:Key="AudioVideoComposeVideoTrackItemTemplate"
            x:DataType="models:TrackItem">
            <Grid
                Width="{x:Bind VisualWidth}"
                MinWidth="392"
                Height="188"
                ToolTipService.ToolTip="{x:Bind SourceName}">
                <Border
                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                    BorderThickness="1"
                    CornerRadius="16" />
                <Border
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="1.4"
                    CornerRadius="16"
                    Opacity="{x:Bind NormalOutlineOpacity, Mode=OneWay}" />
                <Border
                    BorderBrush="#FFE25555"
                    BorderThickness="2"
                    CornerRadius="16"
                    Visibility="{x:Bind InvalidStateVisibility, Mode=OneWay}" />
                <Grid
                    Padding="14,12"
                    RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="6">
                            <Border
                                Padding="10,4"
                                Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                CornerRadius="10"
                                Visibility="{x:Bind ResolutionPresetBadgeVisibility, Mode=OneWay}">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                    Text="以视频长度为预设" />
                            </Border>
                            <Border
                                Padding="10,4"
                                Background="#24C42B1C"
                                CornerRadius="10"
                                Visibility="{x:Bind InvalidStateVisibility, Mode=OneWay}">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="#FFC42B1C"
                                    Text="已失效" />
                            </Border>
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6">
                            <Button
                                Click="OnSetAudioVideoComposeVideoPresetClick"
                                Style="{StaticResource MergeTrackActionButtonStyle}"
                                IsEnabled="{x:Bind CanSetAsResolutionPreset, Mode=OneWay}"
                                Tag="{x:Bind}"
                                Visibility="{Binding ViewModel.AudioVideoComposePresetSelectionVisibility, ElementName=RootPage}"
                                ToolTipService.ToolTip="设为视频长度预设">
                                <TextBlock Text="长度预设" />
                            </Button>
                            <Button
                                Click="OnRemoveVideoTrackItemClick"
                                Style="{StaticResource MergeTrackActionButtonStyle}"
                                Tag="{x:Bind}"
                                ToolTipService.ToolTip="移除视频片段">
                                <TextBlock Text="移除" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <TextBlock
                        Grid.Row="1"
                        FontSize="15"
                        FontWeight="SemiBold"
                        MaxLines="2"
                        Text="{x:Bind SourceName}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="WrapWholeWords" />

                    <StackPanel
                        Grid.Row="2"
                        VerticalAlignment="Top"
                        Spacing="6">
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind TypeDisplayText}" />
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind ResolutionDisplayText, Mode=OneWay}" />
                    </StackPanel>

                    <Grid
                        Grid.Row="3"
                        ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind DurationText}" />
                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            MaxWidth="140"
                            FontSize="12"
                            Foreground="#FFC42B1C"
                            Text="{x:Bind SourceAvailabilityStatusText, Mode=OneWay}"
                            TextAlignment="Right"
                            TextWrapping="WrapWholeWords"
                            Visibility="{x:Bind InvalidStateVisibility, Mode=OneWay}" />
                    </Grid>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate
            x:Key="AudioVideoComposeAudioTrackItemTemplate"
            x:DataType="models:TrackItem">
            <Grid
                Width="{x:Bind VisualWidth}"
                MinWidth="360"
                Height="188"
                ToolTipService.ToolTip="{x:Bind SourceName}">
                <Border
                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                    BorderThickness="1"
                    CornerRadius="16" />
                <Border
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="1.4"
                    CornerRadius="16"
                    Opacity="{x:Bind NormalOutlineOpacity, Mode=OneWay}" />
                <Border
                    BorderBrush="#FFE25555"
                    BorderThickness="2"
                    CornerRadius="16"
                    Visibility="{x:Bind InvalidStateVisibility, Mode=OneWay}" />
                <Grid
                    Padding="14,12"
                    RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="6">
                            <Border
                                Padding="10,4"
                                Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                CornerRadius="10"
                                Visibility="{x:Bind ResolutionPresetBadgeVisibility, Mode=OneWay}">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                    Text="以音频长度为预设" />
                            </Border>
                            <Border
                                Padding="10,4"
                                Background="#24C42B1C"
                                CornerRadius="10"
                                Visibility="{x:Bind InvalidStateVisibility, Mode=OneWay}">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="#FFC42B1C"
                                    Text="已失效" />
                            </Border>
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6">
                            <Button
                                Click="OnSetAudioVideoComposeAudioPresetClick"
                                Style="{StaticResource MergeTrackActionButtonStyle}"
                                IsEnabled="{x:Bind CanSetAsResolutionPreset, Mode=OneWay}"
                                Tag="{x:Bind}"
                                Visibility="{Binding ViewModel.AudioVideoComposePresetSelectionVisibility, ElementName=RootPage}"
                                ToolTipService.ToolTip="设为音频长度预设">
                                <TextBlock Text="长度预设" />
                            </Button>
                            <Button
                                Click="OnRemoveAudioTrackItemClick"
                                Style="{StaticResource MergeTrackActionButtonStyle}"
                                Tag="{x:Bind}"
                                ToolTipService.ToolTip="移除音频片段">
                                <TextBlock Text="移除" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <TextBlock
                        Grid.Row="1"
                        FontSize="15"
                        FontWeight="SemiBold"
                        MaxLines="2"
                        Text="{x:Bind SourceName}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="WrapWholeWords" />

                    <StackPanel
                        Grid.Row="2"
                        VerticalAlignment="Top"
                        Spacing="6">
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind TypeDisplayText}" />
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind ResolutionDisplayText, Mode=OneWay}" />
                    </StackPanel>

                    <Grid
                        Grid.Row="3"
                        ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind DurationText}" />
                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            MaxWidth="140"
                            FontSize="12"
                            Foreground="#FFC42B1C"
                            Text="{x:Bind SourceAvailabilityStatusText, Mode=OneWay}"
                            TextAlignment="Right"
                            TextWrapping="WrapWholeWords"
                            Visibility="{x:Bind InvalidStateVisibility, Mode=OneWay}" />
                    </Grid>
                </Grid>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Padding="16"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="素材列表" />
                    <TextBlock
                        Opacity="0.72"
                        Text="支持导入视频或音频文件。单击素材列表中的素材可添加到相应轨道。"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Button
                    Grid.Row="1"
                    Command="{x:Bind ViewModel.ImportFilesCommand, Mode=OneWay}"
                    HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="OpenFile" />
                        <TextBlock Text="导入文件" />
                    </StackPanel>
                </Button>

                <Grid Grid.Row="2">
                    <ListView
                        Background="Transparent"
                        BorderThickness="0"
                        IsItemClickEnabled="True"
                        ItemContainerStyle="{StaticResource MergeMediaListViewItemStyle}"
                        ItemClick="OnMediaItemClick"
                        ItemsSource="{x:Bind ViewModel.MediaItems, Mode=OneWay}"
                        Padding="0,0,12,0"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:MediaItem">
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="12,10"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    ToolTipService.ToolTip="{x:Bind SourcePath, Mode=OneWay}">
                                    <Grid
                                        ColumnSpacing="10"
                                        RowSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock
                                            FontWeight="SemiBold"
                                            MaxLines="1"
                                            Text="{x:Bind FileName}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Style="{StaticResource MergeMediaTypeTextStyle}"
                                            Text="{x:Bind TypeDisplayText}" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="{x:Bind DurationText}" />

                                        <Button
                                            Grid.Column="2"
                                            Grid.RowSpan="2"
                                            Click="OnRemoveMediaItemClick"
                                            Style="{StaticResource MergeMediaRemoveButtonStyle}"
                                            ToolTipService.ToolTip="移除素材">
                                            <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="180"
                        Opacity="0.72"
                        Text="导入后素材会显示在这里。"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        Visibility="{x:Bind ViewModel.MediaItemsEmptyVisibility, Mode=OneWay}" />
                </Grid>
            </Grid>
        </Border>

        <Border
            Grid.Column="1"
            Padding="16"
            Style="{StaticResource SurfaceCardBorderStyle}">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="合并工作区" />
                    <TextBlock
                        Opacity="0.72"
                        Text="在不同合并模式之间切换，按需将素材编排到视频轨道或音频轨道。"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    HorizontalAlignment="Left"
                    Padding="4"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                    <StackPanel Orientation="Horizontal" Spacing="8">

                        <RadioButton
                            GroupName="MergeMode"
                            IsChecked="{x:Bind ViewModel.IsVideoJoinModeSelected, Mode=TwoWay}"
                            Style="{StaticResource MergeModeSegmentRadioButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border
                                    Width="34"
                                    Height="34"
                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                    CornerRadius="10">
                                    <SymbolIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Symbol="Video" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="视频拼接"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            GroupName="MergeMode"
                            IsChecked="{x:Bind ViewModel.IsAudioJoinModeSelected, Mode=TwoWay}"
                            Style="{StaticResource MergeModeSegmentRadioButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border
                                    Width="34"
                                    Height="34"
                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                    CornerRadius="10">
                                    <SymbolIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Symbol="Audio" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="音频拼接"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            GroupName="MergeMode"
                            IsChecked="{x:Bind ViewModel.IsAudioVideoComposeModeSelected, Mode=TwoWay}"
                            Style="{StaticResource MergeModeSegmentRadioButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border
                                    Width="34"
                                    Height="34"
                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                    CornerRadius="10">
                                    <Grid>
                                        <SymbolIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Symbol="Video" />
                                        <Border
                                            Width="12"
                                            Height="12"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,1,1"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="6">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="7"
                                                FontWeight="SemiBold"
                                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                Text="♪" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="音视频合成"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <TextBlock
                    Grid.Row="2"
                    Opacity="0.72"
                    Text="{x:Bind ViewModel.TimelineHintText, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />

                <Grid Grid.Row="3">
                    <Border
                        Padding="14"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        CornerRadius="16"
                        VerticalAlignment="Top"
                        Visibility="{x:Bind ViewModel.VideoJoinTimelineVisibility, Mode=OneWay}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="视频轨道" />
                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Spacing="2">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="{x:Bind ViewModel.VideoTrackSummaryText, Mode=OneWay}" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Opacity="0.72"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="{x:Bind ViewModel.VideoJoinTotalDurationText, Mode=OneWay}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel
                                Grid.Row="1"
                                Spacing="4">
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.VideoResolutionPresetSummaryText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Opacity="0.72"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="可左键长按拖拽片段调整顺序，也可使用片段顶部按钮快速移除或设为分辨率预设。"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <Grid
                                Grid.Row="2"
                                MinHeight="176">
                                <ListView
                                    AllowDrop="True"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CanDragItems="True"
                                    CanReorderItems="True"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    IsSwipeEnabled="False"
                                    ItemContainerStyle="{StaticResource MergeTrackListViewItemStyle}"
                                    ItemsSource="{x:Bind ViewModel.VideoTrackItems, Mode=OneWay}"
                                    Padding="0,0,0,18"
                                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                    ScrollViewer.HorizontalScrollMode="Enabled"
                                    ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                    ScrollViewer.VerticalScrollMode="Disabled"
                                    VerticalAlignment="Top"
                                    SelectionMode="None">
                                    <ListView.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsStackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListView.ItemsPanel>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:TrackItem">
                                            <Grid
                                                Width="{x:Bind VisualWidth}"
                                                MinWidth="264"
                                                Height="176"
                                                ToolTipService.ToolTip="{x:Bind SourceName}">
                                                <Border
                                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="16" />
                                                <Border
                                                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                                    BorderThickness="1.4"
                                                    CornerRadius="16"
                                                    Opacity="{x:Bind NormalOutlineOpacity, Mode=OneWay}" />
                                                <Border
                                                    BorderBrush="#FFE25555"
                                                    BorderThickness="2"
                                                    CornerRadius="16"
                                                    Visibility="{x:Bind InvalidStateVisibility, Mode=OneWay}" />
                                                <Grid
                                                    Padding="14,12"
                                                    RowSpacing="10">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border
                                                            Padding="10,4"
                                                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                            CornerRadius="10">
                                                            <TextBlock
                                                                FontWeight="SemiBold"
                                                                Text="{x:Bind SequenceNumberText, Mode=OneWay}" />
                                                        </Border>

                                                        <StackPanel
                                                            Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Spacing="6">
                                                            <Border
                                                                Padding="10,4"
                                                                Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                                                CornerRadius="10"
                                                                Visibility="{x:Bind ResolutionPresetBadgeVisibility, Mode=OneWay}">
                                                                <TextBlock
                                                                    FontSize="12"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                                    Text="{x:Bind ResolutionPresetLabelText, Mode=OneWay}" />
                                                            </Border>
                                                            <Border
                                                                Padding="10,4"
                                                                Background="#24C42B1C"
                                                                CornerRadius="10"
                                                                Visibility="{x:Bind InvalidStateVisibility, Mode=OneWay}">
                                                                <TextBlock
                                                                    FontSize="12"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="#FFC42B1C"
                                                                    Text="已失效" />
                                                            </Border>
                                                        </StackPanel>

                                                        <StackPanel
