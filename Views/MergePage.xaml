                                Text="{x:Bind ViewModel.VideoJoinOutputDirectoryDisplayText, Mode=OneWay}"
                                PlaceholderText="预设视频目录" />
                            <Button
                                Grid.Column="1"
                                Command="{x:Bind ViewModel.BrowseOutputDirectoryCommand, Mode=OneWay}"
                                Content="选择目录" />
                            <Button
                                Grid.Column="2"
                                Command="{x:Bind ViewModel.ClearOutputDirectoryCommand, Mode=OneWay}"
                                Content="清空" />
                        </Grid>
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.OutputDirectoryHintText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.VideoJoinOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="输出文件名" />
                        <TextBox
                            PlaceholderText="留空时自动生成"
                            Text="{x:Bind ViewModel.VideoJoinOutputFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.VideoJoinOutputNameHintText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.VideoJoinOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="分辨率处理" />
                        <TextBlock
                            Opacity="0.72"
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind ViewModel.VideoResolutionPresetSummaryText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock FontWeight="SemiBold" Text="较小分辨率视频" />
                        <RadioButton
                            Content="填充黑边"
                            GroupName="SmallerResolutionStrategy"
                            IsChecked="{x:Bind ViewModel.IsPadSmallerVideoWithBlackBarsSelected, Mode=TwoWay}" />
                        <RadioButton
                            Content="拉伸填充"
                            GroupName="SmallerResolutionStrategy"
                            IsChecked="{x:Bind ViewModel.IsStretchSmallerVideoToFillSelected, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.VideoJoinOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="较大分辨率视频" />
                        <RadioButton
                            Content="挤压"
                            GroupName="LargerResolutionStrategy"
                            IsChecked="{x:Bind ViewModel.IsSqueezeLargerVideoToFitSelected, Mode=TwoWay}" />
                        <RadioButton
                            Content="裁剪"
                            GroupName="LargerResolutionStrategy"
                            IsChecked="{x:Bind ViewModel.IsCropLargerVideoToFillSelected, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.AudioJoinOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="输出格式" />
                        <ComboBox
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{x:Bind ViewModel.AudioJoinOutputFormats, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedAudioJoinOutputFormat, Mode=TwoWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.SelectedAudioJoinOutputFormatDescription, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.AudioJoinOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="参数模式" />
                        <RadioButton
                            Content="均衡模式"
                            GroupName="AudioJoinParameterMode"
                            IsChecked="{x:Bind ViewModel.IsBalancedAudioJoinParameterModeSelected, Mode=TwoWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Style="{StaticResource CaptionTextStyle}"
                            Text="不锁定单个预设音频，按全部有效音轨的整体情况统一采样率与码率，更偏向稳定听感和输出兼容性。"
                            TextWrapping="WrapWholeWords" />
                        <RadioButton
                            Content="指定预设模式"
                            GroupName="AudioJoinParameterMode"
                            IsChecked="{x:Bind ViewModel.IsPresetAudioJoinParameterModeSelected, Mode=TwoWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Style="{StaticResource CaptionTextStyle}"
                            Text="以音频轨道中选中的参数预设为目标，低于目标的补齐到目标，高于目标的压到目标，匹配的保持不动。"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.AudioJoinOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="输出目录" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                IsReadOnly="True"
                                ToolTipService.ToolTip="{x:Bind ViewModel.AudioJoinOutputDirectoryDisplayText, Mode=OneWay}"
                                Text="{x:Bind ViewModel.AudioJoinOutputDirectoryDisplayText, Mode=OneWay}"
                                PlaceholderText="预设音频目录" />
                            <Button
                                Grid.Column="1"
                                Command="{x:Bind ViewModel.BrowseOutputDirectoryCommand, Mode=OneWay}"
                                Content="选择目录" />
                            <Button
                                Grid.Column="2"
                                Command="{x:Bind ViewModel.ClearOutputDirectoryCommand, Mode=OneWay}"
                                Content="清空" />
                        </Grid>
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.OutputDirectoryHintText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.AudioJoinOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="输出文件名" />
                        <TextBox
                            PlaceholderText="留空时自动生成"
                            Text="{x:Bind ViewModel.AudioJoinOutputFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.AudioJoinOutputNameHintText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.AudioJoinOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="参数基准" />
                        <Border
                            Padding="12"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            CornerRadius="12">
                            <TextBlock
                                Text="{x:Bind ViewModel.AudioParameterPresetSummaryText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Border>
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.AudioJoinParameterModeHintText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.AudioVideoComposeOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="输出格式" />
                        <ComboBox
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{x:Bind ViewModel.AudioVideoComposeOutputFormats, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedAudioVideoComposeOutputFormat, Mode=TwoWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.SelectedAudioVideoComposeOutputFormatDescription, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.AudioVideoComposeOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="输出目录" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                IsReadOnly="True"
                                ToolTipService.ToolTip="{x:Bind ViewModel.AudioVideoComposeOutputDirectoryDisplayText, Mode=OneWay}"
                                Text="{x:Bind ViewModel.AudioVideoComposeOutputDirectoryDisplayText, Mode=OneWay}"
                                PlaceholderText="当前视频目录" />
                            <Button
                                Grid.Column="1"
                                Command="{x:Bind ViewModel.BrowseOutputDirectoryCommand, Mode=OneWay}"
                                Content="选择目录" />
                            <Button
                                Grid.Column="2"
                                Command="{x:Bind ViewModel.ClearOutputDirectoryCommand, Mode=OneWay}"
                                Content="清空" />
                        </Grid>
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.AudioVideoComposeOutputDirectoryHintText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.AudioVideoComposeOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="输出文件名" />
                        <TextBox
                            PlaceholderText="留空时自动生成"
                            Text="{x:Bind ViewModel.AudioVideoComposeOutputFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.AudioVideoComposeOutputNameHintText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.AudioVideoComposeOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="智能对齐策略" />
                        <Border
                            Padding="12"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            CornerRadius="12">
                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.AudioVideoComposeStrategySummaryText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Opacity="0.72"
                                    Text="{x:Bind ViewModel.AudioVideoComposeDurationSummaryText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.AudioVideoComposeOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="导入音频处理" />
                        <Border
                            Padding="12"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            CornerRadius="12">
                            <StackPanel Spacing="10">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="导入音频音量" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Opacity="0.72"
                                        Text="{x:Bind ViewModel.AudioVideoComposeImportedAudioVolumeText, Mode=OneWay}" />
                                </Grid>
                                <Slider
                                    Maximum="12"
                                    Minimum="-36"
                                    StepFrequency="0.5"
                                    Value="{x:Bind ViewModel.AudioVideoComposeImportedAudioVolumeDecibels, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                        <TextBlock
                            Opacity="0.72"
                            Text="导入音频的整体音量在这里统一调整，导出时会按当前分贝直接生效。"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.AudioVideoComposeOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="混音" />
                        <Border
                            Padding="12"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            CornerRadius="12">
                            <StackPanel Spacing="10">
                                <ToggleSwitch
                                    Header="保留原视频声音并与导入音频混合"
                                    IsOn="{x:Bind ViewModel.IsAudioVideoComposeMixOriginalAudioEnabled, Mode=TwoWay}"
                                    OffContent="关闭"
                                    OnContent="开启" />
                                <TextBlock
                                    Opacity="0.72"
                                    Text="{x:Bind ViewModel.AudioVideoComposeMixOriginalAudioAvailabilityText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <StackPanel
                                    Spacing="10"
                                    Visibility="{x:Bind ViewModel.AudioVideoComposeOriginalAudioControlsVisibility, Mode=OneWay}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="原视频声音音量" />
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Opacity="0.72"
                                            Text="{x:Bind ViewModel.AudioVideoComposeOriginalVideoVolumeText, Mode=OneWay}" />
                                    </Grid>
                                    <Slider
                                        Maximum="12"
                                        Minimum="-36"
                                        StepFrequency="0.5"
                                        Value="{x:Bind ViewModel.AudioVideoComposeOriginalVideoVolumeDecibels, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.AudioVideoComposeOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="淡入淡出" />
                        <Border
                            Padding="12"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            CornerRadius="12">
                            <StackPanel Spacing="12">
                                <ToggleSwitch
                                    Header="导入音频淡入"
                                    IsOn="{x:Bind ViewModel.IsAudioVideoComposeFadeInEnabled, Mode=TwoWay}"
                                    OffContent="关闭"
                                    OnContent="开启" />
                                <NumberBox
                                    Header="淡入时长（秒）"
                                    IsEnabled="{x:Bind ViewModel.IsAudioVideoComposeFadeInEnabled, Mode=OneWay}"
                                    Minimum="0"
                                    SmallChange="0.5"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{x:Bind ViewModel.AudioVideoComposeFadeInSeconds, Mode=TwoWay}" />
                                <ToggleSwitch
                                    Header="导入音频淡出"
                                    IsOn="{x:Bind ViewModel.IsAudioVideoComposeFadeOutEnabled, Mode=TwoWay}"
                                    OffContent="关闭"
                                    OnContent="开启" />
                                <NumberBox
                                    Header="淡出时长（秒）"
                                    IsEnabled="{x:Bind ViewModel.IsAudioVideoComposeFadeOutEnabled, Mode=OneWay}"
                                    Minimum="0"
                                    SmallChange="0.5"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{x:Bind ViewModel.AudioVideoComposeFadeOutSeconds, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.AudioVideoComposeFadeHintText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
