<Page
    x:Class="Vidvix.Views.MergePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Vidvix.Core.Models"
    x:Name="RootPage"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="MergeMediaListViewItemStyle"
            TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="AllowDrop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            ContentTransitions="{TemplateBinding ContentTransitions}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="MergeMediaRemoveButtonStyle"
            TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <Style
            x:Key="MergeMediaTypeTextStyle"
            TargetType="TextBlock"
            BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="MergeTrackListViewItemStyle"
            TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
        </Style>

        <Style
            x:Key="MergeTrackActionButtonStyle"
            TargetType="Button">
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Padding="16"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="素材列表" />
                    <TextBlock
                        Opacity="0.72"
                        Text="支持导入视频或音频文件。单击素材列表中的素材可添加到相应轨道。"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Button
                    Grid.Row="1"
                    Command="{x:Bind ViewModel.ImportFilesCommand, Mode=OneWay}"
                    HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="OpenFile" />
                        <TextBlock Text="导入文件" />
                    </StackPanel>
                </Button>

                <Grid Grid.Row="2">
                    <ListView
                        Background="Transparent"
                        BorderThickness="0"
                        IsItemClickEnabled="True"
                        ItemContainerStyle="{StaticResource MergeMediaListViewItemStyle}"
                        ItemClick="OnMediaItemClick"
                        ItemsSource="{x:Bind ViewModel.MediaItems, Mode=OneWay}"
                        Padding="0,0,12,0"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:MediaItem">
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="12,10"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    ToolTipService.ToolTip="{x:Bind SourcePath, Mode=OneWay}">
                                    <Grid
                                        ColumnSpacing="10"
                                        RowSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock
                                            FontWeight="SemiBold"
                                            MaxLines="1"
                                            Text="{x:Bind FileName}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Style="{StaticResource MergeMediaTypeTextStyle}"
                                            Text="{x:Bind TypeDisplayText}" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="{x:Bind DurationText}" />

                                        <Button
                                            Grid.Column="2"
                                            Grid.RowSpan="2"
                                            Click="OnRemoveMediaItemClick"
                                            Style="{StaticResource MergeMediaRemoveButtonStyle}"
                                            ToolTipService.ToolTip="移除素材">
                                            <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="180"
                        Opacity="0.72"
                        Text="导入后素材会显示在这里。"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        Visibility="{x:Bind ViewModel.MediaItemsEmptyVisibility, Mode=OneWay}" />
                </Grid>
            </Grid>
        </Border>

        <Border
            Grid.Column="1"
            Padding="16"
            Style="{StaticResource SurfaceCardBorderStyle}">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="合并工作区" />
                    <TextBlock
                        Opacity="0.72"
                        Text="在不同合并模式之间切换，按需将素材编排到视频轨道或音频轨道。"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    HorizontalAlignment="Left"
                    Padding="4"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                    <StackPanel Orientation="Horizontal" Spacing="8">

                        <RadioButton
                            GroupName="MergeMode"
                            IsChecked="{x:Bind ViewModel.IsVideoJoinModeSelected, Mode=TwoWay}"
                            Style="{StaticResource MergeModeSegmentRadioButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border
                                    Width="34"
                                    Height="34"
                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                    CornerRadius="10">
                                    <SymbolIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Symbol="Video" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="视频拼接"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            GroupName="MergeMode"
                            IsChecked="{x:Bind ViewModel.IsAudioJoinModeSelected, Mode=TwoWay}"
                            Style="{StaticResource MergeModeSegmentRadioButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border
                                    Width="34"
                                    Height="34"
                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                    CornerRadius="10">
                                    <SymbolIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Symbol="Audio" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="音频拼接"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            GroupName="MergeMode"
                            IsChecked="{x:Bind ViewModel.IsAudioVideoComposeModeSelected, Mode=TwoWay}"
                            Style="{StaticResource MergeModeSegmentRadioButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border
                                    Width="34"
                                    Height="34"
                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                    CornerRadius="10">
                                    <Grid>
                                        <SymbolIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Symbol="Video" />
                                        <Border
                                            Width="12"
                                            Height="12"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,1,1"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="6">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="7"
                                                FontWeight="SemiBold"
                                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                Text="♪" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="音视频合成"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <TextBlock
                    Grid.Row="2"
                    Opacity="0.72"
                    Text="{x:Bind ViewModel.TimelineHintText, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />

                <Grid Grid.Row="3">
                    <Border
                        Padding="14"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        CornerRadius="16"
                        VerticalAlignment="Top"
                        Visibility="{x:Bind ViewModel.VideoJoinTimelineVisibility, Mode=OneWay}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="视频轨道" />
                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Spacing="2">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="{x:Bind ViewModel.VideoTrackSummaryText, Mode=OneWay}" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Opacity="0.72"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="{x:Bind ViewModel.VideoJoinTotalDurationText, Mode=OneWay}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel
                                Grid.Row="1"
                                Spacing="4">
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.VideoResolutionPresetSummaryText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Opacity="0.72"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="可左键长按拖拽片段调整顺序，也可使用片段顶部按钮快速移除或设为分辨率预设。"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <Grid
                                Grid.Row="2"
                                MinHeight="176">
                                <ListView
                                    AllowDrop="True"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CanDragItems="True"
                                    CanReorderItems="True"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    IsSwipeEnabled="False"
                                    ItemContainerStyle="{StaticResource MergeTrackListViewItemStyle}"
                                    ItemsSource="{x:Bind ViewModel.VideoTrackItems, Mode=OneWay}"
                                    Padding="0,0,0,18"
                                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                    ScrollViewer.HorizontalScrollMode="Enabled"
                                    ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                    ScrollViewer.VerticalScrollMode="Disabled"
                                    VerticalAlignment="Top"
                                    SelectionMode="None">
                                    <ListView.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsStackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListView.ItemsPanel>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:TrackItem">
                                            <Grid
                                                Width="{x:Bind VisualWidth}"
                                                MinWidth="264"
                                                Height="176"
                                                ToolTipService.ToolTip="{x:Bind SourceName}">
                                                <Border
                                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="16" />
                                                <Border
                                                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                                    BorderThickness="1.4"
                                                    CornerRadius="16"
                                                    Opacity="{x:Bind NormalOutlineOpacity, Mode=OneWay}" />
                                                <Border
                                                    BorderBrush="#FFE25555"
                                                    BorderThickness="2"
                                                    CornerRadius="16"
                                                    Visibility="{x:Bind InvalidStateVisibility, Mode=OneWay}" />
                                                <Grid
                                                    Padding="14,12"
                                                    RowSpacing="10">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border
                                                            Padding="10,4"
                                                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                            CornerRadius="10">
                                                            <TextBlock
                                                                FontWeight="SemiBold"
                                                                Text="{x:Bind SequenceNumberText, Mode=OneWay}" />
                                                        </Border>

                                                        <StackPanel
                                                            Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Spacing="6">
                                                            <Border
                                                                Padding="10,4"
                                                                Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                                                CornerRadius="10"
                                                                Visibility="{x:Bind ResolutionPresetBadgeVisibility, Mode=OneWay}">
                                                                <TextBlock
                                                                    FontSize="12"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                                    Text="{x:Bind ResolutionPresetLabelText, Mode=OneWay}" />
                                                            </Border>
                                                            <Border
                                                                Padding="10,4"
                                                                Background="#24C42B1C"
                                                                CornerRadius="10"
                                                                Visibility="{x:Bind InvalidStateVisibility, Mode=OneWay}">
                                                                <TextBlock
                                                                    FontSize="12"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="#FFC42B1C"
                                                                    Text="已失效" />
                                                            </Border>
                                                        </StackPanel>

                                                        <StackPanel
                                                            Grid.Column="2"
                                                            Orientation="Horizontal"
                                                            Spacing="6">
                                                            <Button
                                                                Click="OnSetVideoResolutionPresetClick"
                                                                Style="{StaticResource MergeTrackActionButtonStyle}"
                                                                IsEnabled="{x:Bind CanSetAsResolutionPreset, Mode=OneWay}"
                                                                Tag="{x:Bind}"
                                                                ToolTipService.ToolTip="设为分辨率预设">
                                                                <TextBlock Text="预设" />
                                                            </Button>
                                                            <Button
                                                                Click="OnRemoveVideoTrackItemClick"
                                                                Style="{StaticResource MergeTrackActionButtonStyle}"
                                                                Tag="{x:Bind}"
                                                                ToolTipService.ToolTip="移除视频片段">
                                                                <TextBlock Text="移除" />
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>

                                                    <TextBlock
                                                        Grid.Row="1"
                                                        FontSize="15"
                                                        FontWeight="SemiBold"
                                                        MaxLines="2"
                                                        Text="{x:Bind SourceName}"
                                                        TextTrimming="CharacterEllipsis"
                                                        TextWrapping="WrapWholeWords" />

                                                    <StackPanel
                                                        Grid.Row="2"
                                                        VerticalAlignment="Top"
                                                        Spacing="6">
                                                        <TextBlock
                                                            Style="{StaticResource CaptionTextStyle}"
                                                            Text="{x:Bind TypeDisplayText}" />
                                                        <TextBlock
                                                            Style="{StaticResource CaptionTextStyle}"
                                                            Text="{x:Bind ResolutionDisplayText, Mode=OneWay}" />
                                                    </StackPanel>

                                                    <Grid
                                                        Grid.Row="3"
                                                        ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock
                                                            Style="{StaticResource CaptionTextStyle}"
                                                            Text="{x:Bind DurationText}" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            HorizontalAlignment="Right"
                                                            MaxWidth="140"
                                                            FontSize="12"
                                                            Foreground="#FFC42B1C"
                                                            Text="{x:Bind SourceAvailabilityStatusText, Mode=OneWay}"
                                                            TextAlignment="Right"
                                                            TextWrapping="WrapWholeWords"
                                                            Visibility="{x:Bind InvalidStateVisibility, Mode=OneWay}" />
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="280"
                                    Opacity="0.72"
                                    Text="{x:Bind ViewModel.VideoTrackEmptyText, Mode=OneWay}"
                                    TextAlignment="Center"
                                    TextWrapping="WrapWholeWords"
                                    Visibility="{x:Bind ViewModel.VideoTrackEmptyVisibility, Mode=OneWay}" />
                            </Grid>
                            <Border
                                Grid.Row="3"
                                Margin="0,4,0,0"
                                Padding="10,8"
                                Background="#24D13438"
                                BorderBrush="#66D13438"
                                BorderThickness="1"
                                CornerRadius="12"
                                Visibility="{x:Bind ViewModel.ModeMismatchWarningVisibility, Mode=OneWay}">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="20"
                                        Height="20"
                                        VerticalAlignment="Top"
                                        Background="#FFD13438"
                                        CornerRadius="10">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            Text="!" />
                                    </Border>
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="#FFF1B7B9"
                                        Text="{x:Bind ViewModel.ModeMismatchWarningMessage, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid
                        RowSpacing="14"
                        Visibility="{x:Bind ViewModel.StandardTimelineVisibility, Mode=OneWay}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                    <Border
                        Padding="14"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        CornerRadius="16">
                        <Grid RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="视频轨道" />
                            <TextBlock
                                Grid.Column="1"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.VideoTrackSummaryText, Mode=OneWay}" />

                            <Grid Grid.ColumnSpan="2" Margin="0,32,0,0" MinHeight="116">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled">
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.VideoTrackItems, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="10" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:TrackItem">
                                                <Border
                                                    Width="{x:Bind VisualWidth}"
                                                    MinWidth="120"
                                                    Height="92"
                                                    Padding="12"
                                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                    <Grid RowSpacing="8">
                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Text="{x:Bind DisplayName}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <StackPanel VerticalAlignment="Bottom" Spacing="4">
                                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind TypeDisplayText}" />
                                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind DurationText}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Opacity="0.72"
                                    Text="{x:Bind ViewModel.VideoTrackEmptyText, Mode=OneWay}"
                                    TextAlignment="Center"
                                    TextWrapping="WrapWholeWords"
                                    Visibility="{x:Bind ViewModel.VideoTrackEmptyVisibility, Mode=OneWay}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Padding="14"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        CornerRadius="16">
                        <Grid RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="音频轨道" />
                            <TextBlock
                                Grid.Column="1"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.AudioTrackSummaryText, Mode=OneWay}" />

                            <Grid Grid.ColumnSpan="2" Margin="0,32,0,0" MinHeight="116">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled">
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.AudioTrackItems, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="10" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:TrackItem">
                                                <Border
                                                    Width="{x:Bind VisualWidth}"
                                                    MinWidth="120"
                                                    Height="92"
                                                    Padding="12"
                                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                                    BorderBrush="{ThemeResource TextFillColorSecondaryBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                    <Grid RowSpacing="8">
                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Text="{x:Bind DisplayName}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <StackPanel VerticalAlignment="Bottom" Spacing="4">
                                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind TypeDisplayText}" />
                                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind DurationText}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Opacity="0.72"
                                    Text="{x:Bind ViewModel.AudioTrackEmptyText, Mode=OneWay}"
                                    TextAlignment="Center"
                                    TextWrapping="WrapWholeWords"
                                    Visibility="{x:Bind ViewModel.AudioTrackEmptyVisibility, Mode=OneWay}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
                </Grid>
            </Grid>
        </Border>

        <Border
            Grid.Column="2"
            Padding="16"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <ScrollViewer
                Padding="0,0,14,0"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="输出设置" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.VideoJoinOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="输出格式" />
                        <ComboBox
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{x:Bind ViewModel.VideoJoinOutputFormats, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedOutputFormat, Mode=TwoWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.SelectedOutputFormatDescription, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.VideoJoinOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="输出目录" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                IsReadOnly="True"
                                ToolTipService.ToolTip="{x:Bind ViewModel.VideoJoinOutputDirectoryDisplayText, Mode=OneWay}"
                                Text="{x:Bind ViewModel.VideoJoinOutputDirectoryDisplayText, Mode=OneWay}"
                                PlaceholderText="预设视频目录" />
                            <Button
                                Grid.Column="1"
                                Command="{x:Bind ViewModel.BrowseOutputDirectoryCommand, Mode=OneWay}"
                                Content="选择目录" />
                            <Button
                                Grid.Column="2"
                                Command="{x:Bind ViewModel.ClearOutputDirectoryCommand, Mode=OneWay}"
                                Content="清空" />
                        </Grid>
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.OutputDirectoryHintText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.VideoJoinOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="分辨率处理" />
                        <TextBlock
                            Opacity="0.72"
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind ViewModel.VideoResolutionPresetSummaryText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock FontWeight="SemiBold" Text="较小分辨率视频" />
                        <RadioButton
                            Content="填充黑边"
                            GroupName="SmallerResolutionStrategy"
                            IsChecked="{x:Bind ViewModel.IsPadSmallerVideoWithBlackBarsSelected, Mode=TwoWay}" />
                        <RadioButton
                            Content="拉伸填充"
                            GroupName="SmallerResolutionStrategy"
                            IsChecked="{x:Bind ViewModel.IsStretchSmallerVideoToFillSelected, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.VideoJoinOutputSettingsVisibility, Mode=OneWay}">
                        <TextBlock FontWeight="SemiBold" Text="较大分辨率视频" />
                        <RadioButton
                            Content="挤压"
                            GroupName="LargerResolutionStrategy"
                            IsChecked="{x:Bind ViewModel.IsSqueezeLargerVideoToFitSelected, Mode=TwoWay}" />
                        <RadioButton
                            Content="裁剪"
                            GroupName="LargerResolutionStrategy"
                            IsChecked="{x:Bind ViewModel.IsCropLargerVideoToFillSelected, Mode=TwoWay}" />
                    </StackPanel>

                    <Border
                        Padding="14"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        CornerRadius="14"
                        Visibility="{x:Bind ViewModel.NonVideoJoinOutputSettingsVisibility, Mode=OneWay}">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="当前模式暂无独立输出设置" />
                            <TextBlock
                                Opacity="0.72"
                                Text="右侧这组输出设置仅服务于视频拼接。音频拼接与音视频合成会在各自模式下提供独立配置，不再和视频拼接共用。"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
