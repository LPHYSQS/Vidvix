<Page
    x:Class="Vidvix.Views.AiPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:Vidvix.ViewModels"
    x:Name="RootPage"
    Background="Transparent"
    Loaded="OnPageLoaded"
    SizeChanged="OnPageSizeChanged"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="AiInsetCardBorderStyle"
            BasedOn="{StaticResource InsetSurfaceCardBorderStyle}"
            TargetType="Border">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style
            x:Key="AiMaterialListViewItemStyle"
            TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
        </Style>

        <Style
            x:Key="AiMaterialRemoveButtonStyle"
            TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <Style
            x:Key="AiMetadataLabelTextStyle"
            BasedOn="{StaticResource CaptionTextStyle}"
            TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style
            x:Key="AiTrackEmptyTextStyle"
            BasedOn="{StaticResource CaptionTextStyle}"
            TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MaxWidth" Value="420" />
            <Setter Property="Opacity" Value="0.72" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Page.Resources>

    <Grid
        x:Name="LayoutRoot"
        Background="Transparent"
        ColumnSpacing="12"
        VerticalAlignment="Stretch"
        RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="PrimaryRowDefinition" Height="*" />
            <RowDefinition x:Name="SecondaryRowDefinition" Height="0" />
            <RowDefinition x:Name="TertiaryRowDefinition" Height="0" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="MaterialsColumnDefinition" Width="260" />
            <ColumnDefinition x:Name="WorkspaceColumnDefinition" Width="*" />
            <ColumnDefinition x:Name="OutputColumnDefinition" Width="320" />
        </Grid.ColumnDefinitions>

        <Border
            x:Name="MaterialsCard"
            Grid.Column="0"
            Padding="16"
            VerticalAlignment="Stretch"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        Style="{StaticResource SectionTitleTextStyle}"
                        Text="{x:Bind ViewModel.MaterialsSectionTitleText, Mode=OneWay}" />
                    <TextBlock
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.MaterialsSectionDescriptionText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <StackPanel
                    Grid.Row="1"
                    Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border
                            Padding="10,4"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            CornerRadius="999">
                            <TextBlock
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.VideoOnlyImportBadgeText, Mode=OneWay}" />
                        </Border>
                        <Border
                            Padding="10,4"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            CornerRadius="999">
                            <TextBlock
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.SingleVideoExecutionBadgeText, Mode=OneWay}" />
                        </Border>
                    </StackPanel>

                    <Border
                        HorizontalAlignment="Left"
                        Padding="10,4"
                        Background="{ThemeResource ControlFillColorTertiaryBrush}"
                        CornerRadius="999">
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind ViewModel.MaterialCountText, Mode=OneWay}" />
                    </Border>
                </StackPanel>

                <StackPanel
                    Grid.Row="2"
                    Spacing="10">
                    <Button
                        Command="{x:Bind ViewModel.ImportFilesCommand, Mode=OneWay}"
                        HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="OpenFile" />
                            <TextBlock Text="{x:Bind ViewModel.MaterialsImportButtonText, Mode=OneWay}" />
                        </StackPanel>
                    </Button>

                    <Border
                        Padding="10,8"
                        Background="{ThemeResource ControlFillColorTertiaryBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </Border>
                </StackPanel>

                <Grid Grid.Row="3">
                    <ListView
                        Background="Transparent"
                        BorderThickness="0"
                        ItemContainerStyle="{StaticResource AiMaterialListViewItemStyle}"
                        ItemsSource="{Binding ViewModel.MaterialLibrary.Materials, ElementName=RootPage, Mode=OneWay}"
                        Padding="0,0,12,0"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        SelectedItem="{Binding ViewModel.MaterialLibrary.SelectedMaterial, ElementName=RootPage, Mode=TwoWay}"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:AiMaterialItemViewModel">
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="12"
                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                    CornerRadius="14">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Width="36"
                                            Height="36"
                                            VerticalAlignment="Top"
                                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                            CornerRadius="18">
                                            <SymbolIcon
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Symbol="Video" />
                                        </Border>

                                        <StackPanel
                                            Grid.Column="1"
                                            Spacing="4">
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Text="{x:Bind InputFileName, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Opacity="0.72"
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="{x:Bind InputPath, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <Border
                                                HorizontalAlignment="Left"
                                                Padding="8,3"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="999">
                                                <TextBlock
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="{x:Bind FileExtensionText, Mode=OneWay}" />
                                            </Border>
                                        </StackPanel>

                                        <Button
                                            Grid.Column="2"
                                            Command="{Binding ViewModel.RemoveMaterialCommand, ElementName=RootPage, Mode=OneWay}"
                                            CommandParameter="{x:Bind}"
                                            Style="{StaticResource AiMaterialRemoveButtonStyle}">
                                            <SymbolIcon Symbol="Delete" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock
                        Visibility="{x:Bind ViewModel.MaterialsEmptyVisibility, Mode=OneWay}"
                        Style="{StaticResource AiTrackEmptyTextStyle}"
                        Text="{x:Bind ViewModel.MaterialsPlaceholderText, Mode=OneWay}" />
                </Grid>
            </Grid>
        </Border>

        <Border
            x:Name="WorkspaceCard"
            Grid.Column="1"
            Padding="16"
            VerticalAlignment="Stretch"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <ScrollViewer
                Padding="0,0,14,0"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="{x:Bind ViewModel.WorkspaceSectionTitleText, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.WorkspaceSectionDescriptionText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Border
                        HorizontalAlignment="Left"
                        Padding="4"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="20">
                        <ScrollViewer
                            HorizontalAlignment="Stretch"
                            HorizontalScrollBarVisibility="Auto"
                            HorizontalScrollMode="Enabled"
                            Padding="0,0,0,10"
                            VerticalScrollBarVisibility="Disabled"
                            VerticalScrollMode="Disabled">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <RadioButton
                                    GroupName="AiMode"
                                    IsChecked="{Binding ViewModel.ModeState.IsInterpolationSelected, ElementName=RootPage, Mode=TwoWay}"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    Style="{StaticResource MergeModeSegmentRadioButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border
                                            Width="34"
                                            Height="34"
                                            Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                            CornerRadius="10">
                                            <SymbolIcon
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Symbol="Video" />
                                        </Border>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind ViewModel.InterpolationModeLabelText, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton
                                    GroupName="AiMode"
                                    IsChecked="{Binding ViewModel.ModeState.IsEnhancementSelected, ElementName=RootPage, Mode=TwoWay}"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    Style="{StaticResource MergeModeSegmentRadioButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border
                                            Width="34"
                                            Height="34"
                                            Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                            CornerRadius="10">
                                            <SymbolIcon
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Symbol="Switch" />
                                        </Border>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind ViewModel.EnhancementModeLabelText, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <TextBlock
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.WorkspaceModeSwitchHintText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />

                    <Border
                        Padding="14"
                        Style="{StaticResource InsetSurfaceCardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.CurrentTrackTitleText, Mode=OneWay}" />

                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Spacing="4">
                                    <Border
                                        HorizontalAlignment="Right"
                                        Padding="8,3"
                                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                        CornerRadius="999">
                                        <TextBlock
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="{x:Bind ViewModel.CurrentModeEngineBadgeText, Mode=OneWay}" />
                                    </Border>
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="{x:Bind ViewModel.CurrentInputStatusText, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Grid>

                            <StackPanel
                                Grid.Row="1"
                                Spacing="4">
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.CurrentModeDescriptionText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Opacity="0.72"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.CurrentTrackHintText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <Grid
                                Grid.Row="2"
                                MinHeight="196">
                                <Border
                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Opacity="0.46" />

                                <TextBlock
                                    Visibility="{x:Bind ViewModel.CurrentTrackEmptyVisibility, Mode=OneWay}"
                                    Style="{StaticResource AiTrackEmptyTextStyle}"
                                    Text="{x:Bind ViewModel.CurrentTrackEmptyText, Mode=OneWay}" />

                                <Border
                                    Visibility="{x:Bind ViewModel.CurrentTrackCardVisibility, Mode=OneWay}"
                                    Margin="12"
                                    Padding="16"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                    <StackPanel Spacing="10">
                                        <TextBlock
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Text="{Binding ViewModel.InputState.CurrentInputFileName, ElementName=RootPage, Mode=OneWay}" />

                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Style="{StaticResource AiMetadataLabelTextStyle}"
                                                Text="{x:Bind ViewModel.SourceFileLabelText, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Text="{Binding ViewModel.InputState.CurrentInputPath, ElementName=RootPage, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </Grid>

                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Style="{StaticResource AiMetadataLabelTextStyle}"
                                                Text="{x:Bind ViewModel.CurrentOutputDirectoryLabelText, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Text="{Binding ViewModel.OutputSettings.EffectiveOutputDirectory, ElementName=RootPage, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </Grid>

                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Style="{StaticResource AiMetadataLabelTextStyle}"
                                                Text="{x:Bind ViewModel.CurrentOutputPreviewLabelText, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Text="{Binding ViewModel.OutputSettings.EffectiveOutputFileNameWithExtension, ElementName=RootPage, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border
                        Visibility="{x:Bind ViewModel.InterpolationControlsVisibility, Mode=OneWay}"
                        Style="{StaticResource AiInsetCardBorderStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.InterpolationSettingsTitleText, Mode=OneWay}" />
                            <TextBlock
                                Opacity="0.72"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.InterpolationSettingsDescriptionText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />

                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.InterpolationScaleTitleText, Mode=OneWay}" />
                                <ComboBox
                                    DisplayMemberPath="DisplayName"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    ItemsSource="{Binding ViewModel.InterpolationSettings.AvailableScaleFactors, ElementName=RootPage, Mode=OneWay}"
                                    SelectedItem="{Binding ViewModel.InterpolationSettings.SelectedScaleFactor, ElementName=RootPage, Mode=TwoWay}" />
                                <TextBlock
                                    Opacity="0.72"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.InterpolationScaleHintText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.InterpolationDeviceTitleText, Mode=OneWay}" />
                                <ComboBox
                                    DisplayMemberPath="DisplayName"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    ItemsSource="{Binding ViewModel.InterpolationSettings.AvailableDeviceOptions, ElementName=RootPage, Mode=OneWay}"
                                    SelectedItem="{Binding ViewModel.InterpolationSettings.SelectedDeviceOption, ElementName=RootPage, Mode=TwoWay}" />
                                <TextBlock
                                    Opacity="0.72"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.InterpolationDeviceHintText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <ToggleSwitch
                                    Header="{x:Bind ViewModel.InterpolationUhdTitleText, Mode=OneWay}"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    IsOn="{Binding ViewModel.InterpolationSettings.EnableUhdMode, ElementName=RootPage, Mode=TwoWay}" />
                                <TextBlock
                                    Opacity="0.72"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.InterpolationUhdHintText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border
                        Visibility="{x:Bind ViewModel.EnhancementControlsVisibility, Mode=OneWay}"
                        Style="{StaticResource AiInsetCardBorderStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.EnhancementSettingsTitleText, Mode=OneWay}" />
                            <TextBlock
                                Opacity="0.72"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.EnhancementSettingsDescriptionText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />

                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.EnhancementModelTierTitleText, Mode=OneWay}" />
                                <ComboBox
                                    DisplayMemberPath="DisplayName"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    ItemsSource="{Binding ViewModel.EnhancementSettings.AvailableModelTierOptions, ElementName=RootPage, Mode=OneWay}"
                                    SelectedItem="{Binding ViewModel.EnhancementSettings.SelectedModelTierOption, ElementName=RootPage, Mode=TwoWay}" />
                                <TextBlock
                                    Opacity="0.72"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.EnhancementModelTierHintText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.EnhancementScaleTitleText, Mode=OneWay}" />
                                <ComboBox
                                    DisplayMemberPath="DisplayName"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    ItemsSource="{Binding ViewModel.EnhancementSettings.AvailableScaleOptions, ElementName=RootPage, Mode=OneWay}"
                                    SelectedItem="{Binding ViewModel.EnhancementSettings.SelectedScaleOption, ElementName=RootPage, Mode=TwoWay}" />
                                <TextBlock
                                    Opacity="0.72"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.EnhancementScaleHintText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <Border
                                Visibility="{x:Bind ViewModel.EnhancementHighLoadWarningVisibility, Mode=OneWay}"
                                Padding="12"
                                Background="#1AF59E0B"
                                BorderBrush="#66F59E0B"
                                BorderThickness="1"
                                CornerRadius="12">
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.EnhancementHighLoadTitleText, Mode=OneWay}" />
                                    <TextBlock
                                        Opacity="0.82"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="{x:Bind ViewModel.EnhancementHighLoadWarningText, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border
                        Margin="0,4,0,0"
                        Padding="10,8"
                        Background="#1F4CC2FF"
                        BorderBrush="#664CC2FF"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel Spacing="6">
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{x:Bind ViewModel.CurrentModeRuntimeTitleText, Mode=OneWay}" />
                            <TextBlock
                                Foreground="#FFD9F4FF"
                                Text="{x:Bind ViewModel.CurrentModeRuntimeNoteText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Foreground="#FFD9F4FF"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.CurrentModeRuntimeVersionText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Foreground="#FFD9F4FF"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.CurrentModeGpuStatusText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Foreground="#FFD9F4FF"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.CurrentModeCpuStatusText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Foreground="#FFD9F4FF"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.CurrentModeModelSummaryText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Foreground="#FFD9F4FF"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.CurrentModePackageSummaryText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border
            x:Name="OutputCard"
            Grid.Column="2"
            Padding="16"
            VerticalAlignment="Stretch"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <ScrollViewer
                Padding="0,0,14,0"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="{x:Bind ViewModel.OutputSectionTitleText, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.OutputSectionDescriptionText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border
                            Padding="10,4"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            CornerRadius="999">
                            <TextBlock
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.OutputFormatsBadgeText, Mode=OneWay}" />
                        </Border>
                        <Border
                            Padding="10,4"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            CornerRadius="999">
                            <TextBlock
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.OutputAudioBadgeText, Mode=OneWay}" />
                        </Border>
                    </StackPanel>

                    <Border Style="{StaticResource AiInsetCardBorderStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.OutputFormatTitleText, Mode=OneWay}" />
                            <ComboBox
                                DisplayMemberPath="DisplayName"
                                IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                ItemsSource="{Binding ViewModel.OutputSettings.AvailableOutputFormats, ElementName=RootPage, Mode=OneWay}"
                                SelectedItem="{Binding ViewModel.OutputSettings.SelectedOutputFormat, ElementName=RootPage, Mode=TwoWay}" />
                            <TextBlock
                                Opacity="0.72"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.OutputFormatDescriptionText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Opacity="0.72"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.OutputFormatHintText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource AiInsetCardBorderStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.OutputDirectoryTitleText, Mode=OneWay}" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    IsReadOnly="True"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    PlaceholderText="{x:Bind ViewModel.OutputDirectoryPlaceholderText, Mode=OneWay}"
                                    Text="{Binding ViewModel.OutputSettings.OutputDirectoryDisplayText, ElementName=RootPage, Mode=OneWay}" />
                                <Button
                                    Grid.Column="1"
                                    Command="{x:Bind ViewModel.SelectOutputDirectoryCommand, Mode=OneWay}"
                                    Content="{x:Bind ViewModel.SelectOutputDirectoryButtonText, Mode=OneWay}" />
                                <Button
                                    Grid.Column="2"
                                    Command="{x:Bind ViewModel.ClearOutputDirectoryCommand, Mode=OneWay}"
                                    Content="{x:Bind ViewModel.ClearOutputDirectoryButtonText, Mode=OneWay}" />
                            </Grid>
                            <TextBlock
                                Opacity="0.72"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.OutputDirectoryHintText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource AiInsetCardBorderStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.OutputFileNameTitleText, Mode=OneWay}" />
                            <TextBox
                                IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                PlaceholderText="{x:Bind ViewModel.OutputFileNamePlaceholderText, Mode=OneWay}"
                                Text="{Binding ViewModel.OutputSettings.OutputFileName, ElementName=RootPage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Opacity="0.72"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.OutputFileNameHintText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource AiInsetCardBorderStyle}">
                        <TextBlock
                            Opacity="0.78"
                            Text="{x:Bind ViewModel.OutputParameterSummaryText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </Border>

                    <Border
                        Visibility="{x:Bind ViewModel.InterpolationProgressVisibility, Mode=OneWay}"
                        Style="{StaticResource AiInsetCardBorderStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.ProcessingActionsTitleText, Mode=OneWay}" />
                            <TextBlock
                                Opacity="0.72"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.ProcessingActionsHintText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button
                                    Command="{x:Bind ViewModel.StartProcessingCommand, Mode=OneWay}"
                                    Content="{x:Bind ViewModel.StartProcessingButtonText, Mode=OneWay}" />
                                <Button
                                    Grid.Column="1"
                                    Command="{x:Bind ViewModel.CancelProcessingCommand, Mode=OneWay}"
                                    Content="{x:Bind ViewModel.CancelProcessingButtonText, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource AiInsetCardBorderStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.InterpolationProgressTitleText, Mode=OneWay}" />
                            <ProgressBar
                                Maximum="100"
                                Value="{Binding ViewModel.InterpolationExecution.ProgressValue, ElementName=RootPage, Mode=OneWay}" />
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.InterpolationProgressStageTitleText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Opacity="0.72"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.InterpolationProgressDetailText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Opacity="0.78"
                                Text="{x:Bind ViewModel.InterpolationResultSummaryText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Style="{StaticResource AiMetadataLabelTextStyle}"
                                    Text="{x:Bind ViewModel.LastInterpolationOutputLabelText, Mode=OneWay}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{Binding ViewModel.InterpolationExecution.LastOutputPath, ElementName=RootPage, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border
                        Visibility="{x:Bind ViewModel.EnhancementProgressVisibility, Mode=OneWay}"
                        Style="{StaticResource AiInsetCardBorderStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.EnhancementProgressTitleText, Mode=OneWay}" />
                            <ProgressBar
                                Maximum="100"
                                Value="{Binding ViewModel.EnhancementExecution.ProgressValue, ElementName=RootPage, Mode=OneWay}" />
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.EnhancementProgressStageTitleText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Opacity="0.72"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.EnhancementProgressDetailText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Opacity="0.78"
                                Text="{x:Bind ViewModel.EnhancementResultSummaryText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Style="{StaticResource AiMetadataLabelTextStyle}"
                                    Text="{x:Bind ViewModel.LastEnhancementOutputLabelText, Mode=OneWay}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{Binding ViewModel.EnhancementExecution.LastOutputPath, ElementName=RootPage, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
