<Page
    x:Class="Vidvix.Views.AiPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="RootPage"
    Background="Transparent"
    Loaded="OnPageLoaded"
    SizeChanged="OnPageSizeChanged"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="AiInsetCardBorderStyle"
            BasedOn="{StaticResource InsetSurfaceCardBorderStyle}"
            TargetType="Border">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14" />
        </Style>
    </Page.Resources>

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Enabled">
        <Grid
            x:Name="LayoutRoot"
            Background="Transparent"
            ColumnSpacing="12"
            Margin="8,6,8,0"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="PrimaryRowDefinition" Height="Auto" />
                <RowDefinition x:Name="SecondaryRowDefinition" Height="0" />
                <RowDefinition x:Name="TertiaryRowDefinition" Height="0" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="MaterialsColumnDefinition" Width="260" />
                <ColumnDefinition x:Name="WorkspaceColumnDefinition" Width="*" />
                <ColumnDefinition x:Name="OutputColumnDefinition" Width="320" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="MaterialsCard"
                Grid.Column="0"
                Padding="16"
                Style="{StaticResource SurfaceCardBorderStyle}">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="{x:Bind ViewModel.MaterialsSectionTitleText, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.78"
                            Text="{x:Bind ViewModel.MaterialsSectionDescriptionText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8">
                        <Border
                            Padding="10,4"
                            Style="{StaticResource SubtleBadgeBorderStyle}">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.VideoOnlyImportBadgeText, Mode=OneWay}" />
                        </Border>
                        <Border
                            Padding="10,4"
                            Style="{StaticResource SubtleBadgeBorderStyle}">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.SingleVideoExecutionBadgeText, Mode=OneWay}" />
                        </Border>
                    </StackPanel>

                    <Border Style="{StaticResource AiInsetCardBorderStyle}">
                        <TextBlock
                            Opacity="0.82"
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind ViewModel.MaterialsPlaceholderText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </Border>
                </StackPanel>
            </Border>

            <Border
                x:Name="WorkspaceCard"
                Grid.Column="1"
                Padding="18"
                Style="{StaticResource SurfaceCardBorderStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="{x:Bind ViewModel.WorkspaceSectionTitleText, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.78"
                            Text="{x:Bind ViewModel.WorkspaceSectionDescriptionText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Border Style="{StaticResource AiInsetCardBorderStyle}">
                        <StackPanel Spacing="8">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.InterpolationCardTitleText, Mode=OneWay}" />

                                <Border
                                    Grid.Column="1"
                                    Padding="10,4"
                                    Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                    CornerRadius="10">
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                        Text="{x:Bind ViewModel.InterpolationEngineBadgeText, Mode=OneWay}" />
                                </Border>
                            </Grid>

                            <TextBlock
                                Opacity="0.82"
                                Text="{x:Bind ViewModel.InterpolationCardDescriptionText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.InterpolationPlaceholderText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource AiInsetCardBorderStyle}">
                        <StackPanel Spacing="8">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.EnhancementCardTitleText, Mode=OneWay}" />

                                <Border
                                    Grid.Column="1"
                                    Padding="10,4"
                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                    CornerRadius="10">
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.EnhancementEngineBadgeText, Mode=OneWay}" />
                                </Border>
                            </Grid>

                            <TextBlock
                                Opacity="0.82"
                                Text="{x:Bind ViewModel.EnhancementCardDescriptionText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.EnhancementPlaceholderText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border
                x:Name="OutputCard"
                Grid.Column="2"
                Padding="16"
                Style="{StaticResource SurfaceCardBorderStyle}">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="{x:Bind ViewModel.OutputSectionTitleText, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.78"
                            Text="{x:Bind ViewModel.OutputSectionDescriptionText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <Border
                            Padding="10,4"
                            HorizontalAlignment="Left"
                            Style="{StaticResource SubtleBadgeBorderStyle}">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.OutputFormatsBadgeText, Mode=OneWay}" />
                        </Border>
                        <Border
                            Padding="10,4"
                            HorizontalAlignment="Left"
                            Style="{StaticResource SubtleBadgeBorderStyle}">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.OutputAudioBadgeText, Mode=OneWay}" />
                        </Border>
                    </StackPanel>

                    <Border Style="{StaticResource AiInsetCardBorderStyle}">
                        <TextBlock
                            Opacity="0.82"
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind ViewModel.OutputPlaceholderText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
