<Page
    x:Class="Vidvix.Views.AiPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Enabled">
        <StackPanel
            Background="Transparent"
            Padding="8,6,8,0"
            Spacing="12">
            <Border
                Padding="22,18"
                Style="{StaticResource SurfaceCardBorderStyle}">
                <StackPanel Spacing="6">
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{x:Bind ViewModel.SectionCaptionText, Mode=OneWay}" />
                    <TextBlock
                        FontSize="24"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.PageTitleText, Mode=OneWay}" />
                    <TextBlock
                        Opacity="0.78"
                        Text="{x:Bind ViewModel.PageDescriptionText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="18"
                    Style="{StaticResource SurfaceCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="{x:Bind ViewModel.MaterialsSectionTitleText, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.78"
                            Text="{x:Bind ViewModel.MaterialsSectionDescriptionText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="18"
                    Style="{StaticResource SurfaceCardBorderStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="{x:Bind ViewModel.WorkspaceSectionTitleText, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.78"
                            Text="{x:Bind ViewModel.WorkspaceSectionDescriptionText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />

                        <Border
                            Padding="14"
                            Background="{ThemeResource ControlFillColorTertiaryBrush}"
                            CornerRadius="16">
                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.InterpolationCardTitleText, Mode=OneWay}" />
                                <TextBlock
                                    Opacity="0.78"
                                    Text="{x:Bind ViewModel.InterpolationCardDescriptionText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Border
                            Padding="14"
                            Background="{ThemeResource ControlFillColorTertiaryBrush}"
                            CornerRadius="16">
                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.EnhancementCardTitleText, Mode=OneWay}" />
                                <TextBlock
                                    Opacity="0.78"
                                    Text="{x:Bind ViewModel.EnhancementCardDescriptionText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Padding="18"
                    Style="{StaticResource SurfaceCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="{x:Bind ViewModel.OutputSectionTitleText, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.78"
                            Text="{x:Bind ViewModel.OutputSectionDescriptionText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
