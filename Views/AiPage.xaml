<Page
    x:Class="Vidvix.Views.AiPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:Vidvix.ViewModels"
    x:Name="RootPage"
    Background="Transparent"
    Loaded="OnPageLoaded"
    SizeChanged="OnPageSizeChanged"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="AiInsetCardBorderStyle"
            BasedOn="{StaticResource InsetSurfaceCardBorderStyle}"
            TargetType="Border">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style
            x:Key="AiMaterialListViewItemStyle"
            TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            ContentTransitions="{TemplateBinding ContentTransitions}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="AiMaterialRemoveButtonStyle"
            TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <Style
            x:Key="AiMetadataLabelTextStyle"
            BasedOn="{StaticResource CaptionTextStyle}"
            TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style
            x:Key="AiMetadataValueTextStyle"
            TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style
            x:Key="AiTrackMetadataLabelTextStyle"
            BasedOn="{StaticResource CaptionTextStyle}"
            TargetType="TextBlock">
            <Setter Property="Width" Value="96" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style
            x:Key="AiTrackMetadataValueTextStyle"
            BasedOn="{StaticResource CaptionTextStyle}"
            TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style
            x:Key="AiTrackMetricLabelTextStyle"
            BasedOn="{StaticResource CaptionTextStyle}"
            TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="Opacity" Value="0.78" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style
            x:Key="AiTrackMetricValueTextStyle"
            BasedOn="{StaticResource CaptionTextStyle}"
            TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style
            x:Key="AiMaterialTypeTextStyle"
            BasedOn="{StaticResource CaptionTextStyle}"
            TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="AiTrackEmptyTextStyle"
            BasedOn="{StaticResource CaptionTextStyle}"
            TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MaxWidth" Value="420" />
            <Setter Property="Opacity" Value="0.72" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Page.Resources>

    <Grid
        x:Name="LayoutRoot"
        Background="Transparent"
        ColumnSpacing="12"
        VerticalAlignment="Stretch"
        RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="PrimaryRowDefinition" Height="*" />
            <RowDefinition x:Name="SecondaryRowDefinition" Height="0" />
            <RowDefinition x:Name="TertiaryRowDefinition" Height="0" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="MaterialsColumnDefinition" Width="260" />
            <ColumnDefinition x:Name="WorkspaceColumnDefinition" Width="*" />
            <ColumnDefinition x:Name="OutputColumnDefinition" Width="320" />
        </Grid.ColumnDefinitions>

        <Border
            x:Name="MaterialsCard"
            Grid.Column="0"
            Padding="16"
            VerticalAlignment="Stretch"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        Style="{StaticResource SectionTitleTextStyle}"
                        Text="{x:Bind ViewModel.MaterialsSectionTitleText, Mode=OneWay}" />
                    <TextBlock
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.MaterialsSectionDescriptionText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <StackPanel
                    Grid.Row="1"
                    Spacing="10">
                    <Button
                        Command="{x:Bind ViewModel.ImportFilesCommand, Mode=OneWay}"
                        HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="OpenFile" />
                            <TextBlock Text="{x:Bind ViewModel.MaterialsImportButtonText, Mode=OneWay}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Grid Grid.Row="2">
                    <ListView
                        Background="Transparent"
                        BorderThickness="0"
                        IsEnabled="{x:Bind ViewModel.CanModifyMaterials, Mode=OneWay}"
                        ItemContainerStyle="{StaticResource AiMaterialListViewItemStyle}"
                        ItemsSource="{Binding ViewModel.MaterialLibrary.Materials, ElementName=RootPage, Mode=OneWay}"
                        Padding="0,0,12,0"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        SelectedItem="{Binding ViewModel.MaterialLibrary.SelectedMaterial, ElementName=RootPage, Mode=TwoWay}"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:AiMaterialItemViewModel">
                                <Border
                                    Margin="0,0,0,10"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <ToolTipService.ToolTip>
                                        <ToolTip>
                                            <TextBlock
                                                MaxWidth="420"
                                                Text="{x:Bind InputPathToolTipText, Mode=OneWay}"
                                                TextWrapping="Wrap" />
                                        </ToolTip>
                                    </ToolTipService.ToolTip>
                                    <Grid>
                                        <Border
                                            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                            BorderThickness="1.4"
                                            CornerRadius="12"
                                            Opacity="{x:Bind SelectionOutlineOpacity, Mode=OneWay}" />

                                        <Grid
                                            Padding="12,10"
                                            ColumnSpacing="10"
                                            RowSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock
                                                FontWeight="SemiBold"
                                                MaxLines="1"
                                                Text="{x:Bind InputFileName, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="NoWrap" />
                                            <TextBlock
                                                Grid.Row="1"
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="{x:Bind DurationText, Mode=OneWay}" />

                                            <StackPanel
                                                Grid.Column="1"
                                                Grid.RowSpan="2"
                                                VerticalAlignment="Center"
                                                Spacing="4">
                                                <TextBlock
                                                    Style="{StaticResource AiMaterialTypeTextStyle}"
                                                    Text="{x:Bind MediaTypeText, Mode=OneWay}" />
                                                <TextBlock
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="{x:Bind FileExtensionText, Mode=OneWay}" />
                                            </StackPanel>

                                            <Button
                                                Grid.Column="2"
                                                Grid.RowSpan="2"
                                                Command="{Binding ViewModel.RemoveMaterialCommand, ElementName=RootPage, Mode=OneWay}"
                                                CommandParameter="{x:Bind}"
                                                Style="{StaticResource AiMaterialRemoveButtonStyle}"
                                                ToolTipService.ToolTip="{Binding ViewModel.RemoveMaterialButtonText, ElementName=RootPage, Mode=OneWay}">
                                                <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock
                        Visibility="{x:Bind ViewModel.MaterialsEmptyVisibility, Mode=OneWay}"
                        Style="{StaticResource AiTrackEmptyTextStyle}"
                        Text="{x:Bind ViewModel.MaterialsPlaceholderText, Mode=OneWay}" />
                </Grid>
            </Grid>
        </Border>

        <Border
            x:Name="WorkspaceCard"
            Grid.Column="1"
            Padding="16"
            VerticalAlignment="Stretch"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <ScrollViewer
                Padding="0,0,14,0"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="{x:Bind ViewModel.WorkspaceSectionTitleText, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.WorkspaceSectionDescriptionText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Border
                        Padding="14,12"
                        Style="{StaticResource AiInsetCardBorderStyle}"
                        Visibility="{x:Bind ViewModel.InterpolationWorkspaceProgressVisibility, Mode=OneWay}">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Width="34"
                                Height="34"
                                VerticalAlignment="Top"
                                Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                CornerRadius="17">
                                <SymbolIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Symbol="Video" />
                            </Border>

                            <StackPanel
                                Grid.Column="1"
                                Spacing="8">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.InterpolationWorkspaceProgressSummaryText, Mode=OneWay}" />

                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Opacity="0.72"
                                        Text="{x:Bind ViewModel.InterpolationWorkspaceProgressPercentText, Mode=OneWay}" />
                                </Grid>

                                <ProgressBar
                                    Height="6"
                                    IsIndeterminate="{x:Bind ViewModel.IsInterpolationWorkspaceProgressIndeterminate, Mode=OneWay}"
                                    Maximum="100"
                                    Value="{Binding ViewModel.InterpolationExecution.ProgressValue, ElementName=RootPage, Mode=OneWay}" />

                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.InterpolationWorkspaceProgressDetailText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border
                        HorizontalAlignment="Left"
                        Padding="4"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="20">
                        <ScrollViewer
                            HorizontalAlignment="Stretch"
                            HorizontalScrollBarVisibility="Auto"
                            HorizontalScrollMode="Enabled"
                            Padding="0,0,0,10"
                            VerticalScrollBarVisibility="Disabled"
                            VerticalScrollMode="Disabled">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <RadioButton
                                    GroupName="AiMode"
                                    IsChecked="{Binding ViewModel.ModeState.IsInterpolationSelected, ElementName=RootPage, Mode=TwoWay}"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    Style="{StaticResource MergeModeSegmentRadioButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border
                                            Width="34"
                                            Height="34"
                                            Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                            CornerRadius="10">
                                            <SymbolIcon
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Symbol="Video" />
                                        </Border>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind ViewModel.InterpolationModeLabelText, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton
                                    GroupName="AiMode"
                                    IsChecked="{Binding ViewModel.ModeState.IsEnhancementSelected, ElementName=RootPage, Mode=TwoWay}"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    Style="{StaticResource MergeModeSegmentRadioButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border
                                            Width="34"
                                            Height="34"
                                            Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                            CornerRadius="10">
                                            <SymbolIcon
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Symbol="Switch" />
                                        </Border>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind ViewModel.EnhancementModeLabelText, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border
                        Style="{StaticResource AiInsetCardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.CurrentTrackTitleText, Mode=OneWay}" />

                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Spacing="4">
                                    <Border
                                        HorizontalAlignment="Right"
                                        Padding="8,3"
                                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                        CornerRadius="999">
                                        <TextBlock
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="{x:Bind ViewModel.CurrentModeEngineBadgeText, Mode=OneWay}" />
                                    </Border>
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="{x:Bind ViewModel.CurrentInputStatusText, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Grid>

                            <StackPanel
                                Grid.Row="1"
                                Spacing="4">
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.CurrentModeDescriptionText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Opacity="0.72"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.CurrentTrackHintText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <Grid
                                Grid.Row="2"
                                MinHeight="196">
                                <Border
                                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Opacity="0.46" />

                                <TextBlock
                                    Visibility="{x:Bind ViewModel.CurrentTrackEmptyVisibility, Mode=OneWay}"
                                    Style="{StaticResource AiTrackEmptyTextStyle}"
                                    Text="{x:Bind ViewModel.CurrentTrackEmptyText, Mode=OneWay}" />

                                <Border
                                    Visibility="{x:Bind ViewModel.CurrentTrackCardVisibility, Mode=OneWay}"
                                    Margin="12"
                                    Padding="16"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                    <StackPanel Spacing="10">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                FontSize="18"
                                                FontWeight="SemiBold"
                                                Text="{Binding ViewModel.InputState.CurrentInputFileName, ElementName=RootPage, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="NoWrap" />
                                            <Button
                                                Grid.Column="1"
                                                Command="{x:Bind ViewModel.ClearCurrentInputCommand, Mode=OneWay}"
                                                Content="{x:Bind ViewModel.ClearCurrentInputButtonText, Mode=OneWay}"
                                                ToolTipService.ToolTip="{x:Bind ViewModel.ClearCurrentInputButtonText, Mode=OneWay}" />
                                        </Grid>

                                        <Grid
                                            ColumnSpacing="10"
                                            RowSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="96" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock
                                                Grid.Row="0"
                                                Style="{StaticResource AiTrackMetadataLabelTextStyle}"
                                                Text="{x:Bind ViewModel.SourceFileLabelText, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                Style="{StaticResource AiTrackMetadataValueTextStyle}"
                                                Text="{Binding ViewModel.InputState.CurrentInputPath, ElementName=RootPage, Mode=OneWay}"
                                                />

                                            <TextBlock
                                                Grid.Row="1"
                                                Style="{StaticResource AiTrackMetadataLabelTextStyle}"
                                                Text="{x:Bind ViewModel.CurrentOutputDirectoryLabelText, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Style="{StaticResource AiTrackMetadataValueTextStyle}"
                                                Text="{Binding ViewModel.OutputSettings.EffectiveOutputDirectory, ElementName=RootPage, Mode=OneWay}"
                                                />

                                            <TextBlock
                                                Grid.Row="2"
                                                Style="{StaticResource AiTrackMetadataLabelTextStyle}"
                                                Text="{x:Bind ViewModel.CurrentOutputPreviewLabelText, Mode=OneWay}" />
                                             <TextBlock
                                                 Grid.Row="2"
                                                 Grid.Column="1"
                                                 Style="{StaticResource AiTrackMetadataValueTextStyle}"
                                                 Text="{Binding ViewModel.OutputSettings.EffectiveOutputFileNameWithExtension, ElementName=RootPage, Mode=OneWay}"
                                                 />
                                         </Grid>

                                        <Border
                                            Height="1"
                                            Background="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                            Opacity="0.75" />

                                        <Grid ColumnSpacing="18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel
                                                Grid.Column="0"
                                                Spacing="2">
                                                <TextBlock
                                                    Style="{StaticResource AiTrackMetricLabelTextStyle}"
                                                    Text="{x:Bind ViewModel.CurrentTrackDurationLabelText, Mode=OneWay}" />
                                                <TextBlock
                                                    Style="{StaticResource AiTrackMetricValueTextStyle}"
                                                    Text="{x:Bind ViewModel.CurrentTrackDurationValueText, Mode=OneWay}" />
                                            </StackPanel>

                                            <StackPanel
                                                Grid.Column="1"
                                                Spacing="2">
                                                <TextBlock
                                                    Style="{StaticResource AiTrackMetricLabelTextStyle}"
                                                    Text="{x:Bind ViewModel.CurrentTrackResolutionLabelText, Mode=OneWay}" />
                                                <TextBlock
                                                    Style="{StaticResource AiTrackMetricValueTextStyle}"
                                                    Text="{x:Bind ViewModel.CurrentTrackResolutionValueText, Mode=OneWay}" />
                                            </StackPanel>

                                            <StackPanel
                                                Grid.Column="2"
                                                Spacing="2">
                                                <TextBlock
                                                    Style="{StaticResource AiTrackMetricLabelTextStyle}"
                                                    Text="{x:Bind ViewModel.CurrentTrackFrameRateLabelText, Mode=OneWay}" />
                                                <TextBlock
                                                    Style="{StaticResource AiTrackMetricValueTextStyle}"
                                                    Text="{x:Bind ViewModel.CurrentTrackFrameRateValueText, Mode=OneWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border
                        Visibility="{x:Bind ViewModel.InterpolationControlsVisibility, Mode=OneWay}"
                        Style="{StaticResource AiInsetCardBorderStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.InterpolationSettingsTitleText, Mode=OneWay}" />
                            <TextBlock
                                Opacity="0.72"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.InterpolationSettingsDescriptionText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />

                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.InterpolationScaleTitleText, Mode=OneWay}" />
                                <ComboBox
                                    DisplayMemberPath="DisplayName"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    ItemsSource="{Binding ViewModel.InterpolationSettings.AvailableScaleFactors, ElementName=RootPage, Mode=OneWay}"
                                    SelectedItem="{Binding ViewModel.InterpolationSettings.SelectedScaleFactor, ElementName=RootPage, Mode=TwoWay}" />
                                <TextBlock
                                    Opacity="0.72"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.InterpolationScaleHintText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.InterpolationDeviceTitleText, Mode=OneWay}" />
                                <ComboBox
                                    DisplayMemberPath="DisplayName"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    ItemsSource="{Binding ViewModel.InterpolationSettings.AvailableDeviceOptions, ElementName=RootPage, Mode=OneWay}"
                                    SelectedItem="{Binding ViewModel.InterpolationSettings.SelectedDeviceOption, ElementName=RootPage, Mode=TwoWay}" />
                                <TextBlock
                                    Opacity="0.72"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.InterpolationDeviceHintText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <ToggleSwitch
                                    Header="{x:Bind ViewModel.InterpolationUhdTitleText, Mode=OneWay}"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    IsOn="{Binding ViewModel.InterpolationSettings.EnableUhdMode, ElementName=RootPage, Mode=TwoWay}" />
                                <TextBlock
                                    Opacity="0.72"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.InterpolationUhdHintText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border
                        Visibility="{x:Bind ViewModel.EnhancementControlsVisibility, Mode=OneWay}"
                        Style="{StaticResource AiInsetCardBorderStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.EnhancementSettingsTitleText, Mode=OneWay}" />
                            <TextBlock
                                Opacity="0.72"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.EnhancementSettingsDescriptionText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />

                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.EnhancementModelTierTitleText, Mode=OneWay}" />
                                <ComboBox
                                    DisplayMemberPath="DisplayName"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    ItemsSource="{Binding ViewModel.EnhancementSettings.AvailableModelTierOptions, ElementName=RootPage, Mode=OneWay}"
                                    SelectedItem="{Binding ViewModel.EnhancementSettings.SelectedModelTierOption, ElementName=RootPage, Mode=TwoWay}" />
                                <TextBlock
                                    Opacity="0.72"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.EnhancementModelTierHintText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.EnhancementScaleTitleText, Mode=OneWay}" />
                                <ComboBox
                                    DisplayMemberPath="DisplayName"
                                    IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                    ItemsSource="{Binding ViewModel.EnhancementSettings.AvailableScaleOptions, ElementName=RootPage, Mode=OneWay}"
                                    SelectedItem="{Binding ViewModel.EnhancementSettings.SelectedScaleOption, ElementName=RootPage, Mode=TwoWay}" />
                                <TextBlock
                                    Opacity="0.72"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{x:Bind ViewModel.EnhancementScaleHintText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <Border
                                Visibility="{x:Bind ViewModel.EnhancementHighLoadWarningVisibility, Mode=OneWay}"
                                Padding="12"
                                Background="#1AF59E0B"
                                BorderBrush="#66F59E0B"
                                BorderThickness="1"
                                CornerRadius="12">
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.EnhancementHighLoadTitleText, Mode=OneWay}" />
                                    <TextBlock
                                        Opacity="0.82"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="{x:Bind ViewModel.EnhancementHighLoadWarningText, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border
            x:Name="OutputCard"
            Grid.Column="2"
            Padding="16"
            VerticalAlignment="Stretch"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <ScrollViewer
                Padding="0,0,14,0"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="{x:Bind ViewModel.OutputSectionTitleText, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.OutputSectionDescriptionText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.InterpolationProgressVisibility, Mode=OneWay}">
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.OutputFormatTitleText, Mode=OneWay}" />
                        <ComboBox
                            DisplayMemberPath="DisplayName"
                            IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                            ItemsSource="{Binding ViewModel.OutputSettings.AvailableOutputFormats, ElementName=RootPage, Mode=OneWay}"
                            SelectedItem="{Binding ViewModel.OutputSettings.SelectedOutputFormat, ElementName=RootPage, Mode=TwoWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind ViewModel.OutputFormatDescriptionText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.OutputDirectoryTitleText, Mode=OneWay}" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                IsReadOnly="True"
                                IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                                PlaceholderText="{x:Bind ViewModel.OutputDirectoryPlaceholderText, Mode=OneWay}"
                                Text="{Binding ViewModel.OutputSettings.OutputDirectoryDisplayText, ElementName=RootPage, Mode=OneWay}"
                                ToolTipService.ToolTip="{Binding ViewModel.OutputSettings.OutputDirectoryDisplayText, ElementName=RootPage, Mode=OneWay}" />
                            <Button
                                Grid.Column="1"
                                Command="{x:Bind ViewModel.SelectOutputDirectoryCommand, Mode=OneWay}"
                                Content="{x:Bind ViewModel.SelectOutputDirectoryButtonText, Mode=OneWay}" />
                            <Button
                                Grid.Column="2"
                                Command="{x:Bind ViewModel.ClearOutputDirectoryCommand, Mode=OneWay}"
                                Content="{x:Bind ViewModel.ClearOutputDirectoryButtonText, Mode=OneWay}" />
                        </Grid>
                        <TextBlock
                            Opacity="0.72"
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind ViewModel.OutputDirectoryHintText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.OutputFileNameTitleText, Mode=OneWay}" />
                        <TextBox
                            IsEnabled="{x:Bind ViewModel.CanEditProcessingParameters, Mode=OneWay}"
                            PlaceholderText="{x:Bind ViewModel.OutputFileNamePlaceholderText, Mode=OneWay}"
                            Text="{Binding ViewModel.OutputSettings.OutputFileName, ElementName=RootPage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
                            Opacity="0.72"
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind ViewModel.OutputFileNameHintText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Border Style="{StaticResource AiInsetCardBorderStyle}">
                        <TextBlock
                            Opacity="0.78"
                            Text="{x:Bind ViewModel.OutputParameterSummaryText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </Border>

                    <Border
                        Style="{StaticResource AiInsetCardBorderStyle}"
                        Visibility="{x:Bind ViewModel.EnhancementControlsVisibility, Mode=OneWay}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.ProcessingActionsTitleText, Mode=OneWay}" />
                            <TextBlock
                                Opacity="0.72"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.ProcessingActionsHintText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button
                                    Command="{x:Bind ViewModel.StartProcessingCommand, Mode=OneWay}"
                                    Content="{x:Bind ViewModel.StartProcessingButtonText, Mode=OneWay}" />
                                <Button
                                    Grid.Column="1"
                                    Command="{x:Bind ViewModel.CancelProcessingCommand, Mode=OneWay}"
                                    Content="{x:Bind ViewModel.CancelProcessingButtonText, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border
                        Visibility="{x:Bind ViewModel.EnhancementProgressVisibility, Mode=OneWay}"
                        Style="{StaticResource AiInsetCardBorderStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.EnhancementProgressTitleText, Mode=OneWay}" />
                            <ProgressBar
                                Maximum="100"
                                Value="{Binding ViewModel.EnhancementExecution.ProgressValue, ElementName=RootPage, Mode=OneWay}" />
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.EnhancementProgressStageTitleText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Opacity="0.72"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.EnhancementProgressDetailText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Opacity="0.78"
                                Text="{x:Bind ViewModel.EnhancementResultSummaryText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Style="{StaticResource AiMetadataLabelTextStyle}"
                                    Text="{x:Bind ViewModel.LastEnhancementOutputLabelText, Mode=OneWay}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{Binding ViewModel.EnhancementExecution.LastOutputPath, ElementName=RootPage, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <Button
                                    Grid.Column="2"
                                    VerticalAlignment="Top"
                                    Command="{x:Bind ViewModel.RevealLatestOutputCommand, Mode=OneWay}"
                                    CommandParameter="{Binding ViewModel.EnhancementExecution.LastOutputPath, ElementName=RootPage, Mode=OneWay}"
                                    Content="{x:Bind ViewModel.RevealLatestOutputButtonText, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
