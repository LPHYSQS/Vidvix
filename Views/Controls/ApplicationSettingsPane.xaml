<UserControl
    x:Class="Vidvix.Views.Controls.ApplicationSettingsPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="Root">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="20,20,20,24" Spacing="18">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        Style="{StaticResource SectionTitleTextStyle}"
                        Text="应用设置" />
                    <TextBlock
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.SettingsPaneDescription, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Command="{x:Bind CloseCommand, Mode=OneWay}"
                    VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Cancel" />
                        <TextBlock Text="关闭" />
                    </StackPanel>
                </Button>
            </Grid>

            <Border
                Padding="14"
                Background="{ThemeResource SettingsPaneSectionBrush}"
                CornerRadius="16">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="外观" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="软件主题" />
                        <ComboBox
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{x:Bind ViewModel.ThemeOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedThemeOption, Mode=TwoWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.SelectedThemeOption.Description, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border
                Padding="14"
                Background="{ThemeResource SettingsPaneSectionBrush}"
                CornerRadius="16"
                Visibility="{x:Bind ViewModel.SettingsPaneProcessingBehaviorVisibility, Mode=OneWay}">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="处理完成行为" />
                        <Border
                            Width="18"
                            Height="18"
                            Background="{ThemeResource SettingsInfoBadgeBackgroundBrush}"
                            CornerRadius="9"
                            VerticalAlignment="Center">
                            <ToolTipService.ToolTip>
                                <ToolTip>
                                    <TextBlock
                                        MaxWidth="360"
                                        Text="{x:Bind ViewModel.SettingsPaneProcessingBehaviorInfoTooltip, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </ToolTip>
                            </ToolTipService.ToolTip>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="{ThemeResource SettingsInfoBadgeForegroundBrush}"
                                Text="!" />
                        </Border>
                    </StackPanel>

                    <ToggleSwitch
                        Header="处理完成后定位输出文件"
                        IsOn="{x:Bind ViewModel.RevealOutputFileAfterProcessing, Mode=TwoWay}"
                        OffContent="关闭"
                        OnContent="开启" />

                    <TextBlock
                        Opacity="0.72"
                        Text="开启后，处理完成时会打开输出文件所在文件夹，并自动选中对应文件。批量任务会定位最后一个成功输出的文件。"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border
                Padding="14"
                Background="{ThemeResource SettingsPaneSectionBrush}"
                CornerRadius="16"
                Visibility="{x:Bind ViewModel.SettingsPaneTranscodingVisibility, Mode=OneWay}">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="转码方式" />
                        <Border
                            Width="18"
                            Height="18"
                            Background="{ThemeResource SettingsInfoBadgeBackgroundBrush}"
                            CornerRadius="9"
                            VerticalAlignment="Center">
                            <ToolTipService.ToolTip>
                                <ToolTip>
                                    <TextBlock
                                        MaxWidth="360"
                                        Text="{x:Bind ViewModel.SettingsPaneTranscodingInfoTooltip, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </ToolTip>
                            </ToolTipService.ToolTip>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="{ThemeResource SettingsInfoBadgeForegroundBrush}"
                                Text="!" />
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="默认转码策略" />
                        <ComboBox
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{x:Bind ViewModel.TranscodingOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedTranscodingModeOption, Mode=TwoWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.SelectedTranscodingModeOption.Description, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.GpuAccelerationSettingVisibility, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Video" />
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="GPU 加速" />
                        </StackPanel>

                        <ToggleSwitch
                            Header="是否开启 GPU 加速"
                            IsOn="{x:Bind ViewModel.EnableGpuAccelerationForTranscoding, Mode=TwoWay}"
                            OffContent="关闭"
                            OnContent="开启" />

                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.GpuAccelerationDescription, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
