<UserControl
    x:Class="Vidvix.Views.Controls.ApplicationSettingsPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="Root">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="20,20,20,24" Spacing="18">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        AutomationProperties.AutomationId="SettingsPaneTitleText"
                        Style="{StaticResource SectionTitleTextStyle}"
                        Text="{x:Bind ViewModel.SettingsPaneTitleText, Mode=OneWay}" />
                    <TextBlock
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.SettingsPaneDescription, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Command="{x:Bind CloseCommand, Mode=OneWay}"
                    VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Cancel" />
                        <TextBlock Text="{x:Bind ViewModel.SettingsPaneCloseButtonText, Mode=OneWay}" />
                    </StackPanel>
                </Button>
            </Grid>

            <InfoBar
                IsClosable="True"
                IsIconVisible="True"
                IsOpen="{x:Bind ViewModel.IsDesktopShortcutNotificationOpen, Mode=TwoWay}"
                Message="{x:Bind ViewModel.DesktopShortcutNotificationMessage, Mode=OneWay}"
                Severity="{x:Bind ViewModel.DesktopShortcutNotificationSeverity, Mode=OneWay}" />

            <Border
                Padding="14"
                Background="{ThemeResource SettingsPaneSectionBrush}"
                CornerRadius="16">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.SettingsAppearanceTitleText, Mode=OneWay}" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="{x:Bind ViewModel.SettingsThemeLabelText, Mode=OneWay}" />
                        <ComboBox
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{x:Bind ViewModel.ThemeOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedThemeOption, Mode=TwoWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.SelectedThemeOption.Description, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border
                Padding="14"
                Background="{ThemeResource SettingsPaneSectionBrush}"
                CornerRadius="16">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.SettingsLanguageSectionTitleText, Mode=OneWay}" />

                    <ComboBox
                        AutomationProperties.AutomationId="SettingsLanguageComboBox"
                        DisplayMemberPath="DisplayName"
                        ItemsSource="{x:Bind ViewModel.AvailableLanguages, Mode=OneWay}"
                        SelectedValuePath="Code"
                        SelectedValue="{x:Bind ViewModel.SelectedLanguageCode, Mode=TwoWay}" />

                    <TextBlock
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.SettingsLanguageDescriptionText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />

                    <TextBlock
                        AutomationProperties.AutomationId="SettingsCurrentLanguageText"
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.CurrentLanguageDisplayText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border
                Padding="14"
                Background="{ThemeResource SettingsPaneSectionBrush}"
                CornerRadius="16">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.SettingsSystemTrayTitleText, Mode=OneWay}" />

                    <ToggleSwitch
                        Header="{x:Bind ViewModel.SettingsSystemTrayToggleHeaderText, Mode=OneWay}"
                        IsOn="{x:Bind ViewModel.EnableSystemTray, Mode=TwoWay}"
                        OffContent="{x:Bind ViewModel.CommonToggleOffText, Mode=OneWay}"
                        OnContent="{x:Bind ViewModel.CommonToggleOnText, Mode=OneWay}" />

                    <TextBlock
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.SettingsSystemTrayDescriptionText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border
                Padding="14"
                Background="{ThemeResource SettingsPaneSectionBrush}"
                CornerRadius="16">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.SettingsDesktopShortcutTitleText, Mode=OneWay}" />

                    <TextBlock
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.SettingsDesktopShortcutDescriptionText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />

                    <Button
                        Command="{x:Bind ViewModel.CreateDesktopShortcutCommand, Mode=OneWay}"
                        HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Add" />
                            <TextBlock Text="{x:Bind ViewModel.SettingsDesktopShortcutButtonText, Mode=OneWay}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border
                Padding="14"
                Background="{ThemeResource SettingsPaneSectionBrush}"
                CornerRadius="16"
                Visibility="{x:Bind ViewModel.SettingsPaneProcessingBehaviorVisibility, Mode=OneWay}">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.SettingsProcessingBehaviorTitleText, Mode=OneWay}" />
                        <Border
                            Width="18"
                            Height="18"
                            Background="{ThemeResource SettingsInfoBadgeBackgroundBrush}"
                            CornerRadius="9"
                            VerticalAlignment="Center">
                            <ToolTipService.ToolTip>
                                <ToolTip>
                                    <TextBlock
                                        MaxWidth="360"
                                        Text="{x:Bind ViewModel.SettingsPaneProcessingBehaviorInfoTooltip, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </ToolTip>
                            </ToolTipService.ToolTip>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="{ThemeResource SettingsInfoBadgeForegroundBrush}"
                                Text="!" />
                        </Border>
                    </StackPanel>

                    <ToggleSwitch
                        Header="{x:Bind ViewModel.SettingsProcessingBehaviorToggleHeaderText, Mode=OneWay}"
                        IsOn="{x:Bind ViewModel.RevealOutputFileAfterProcessing, Mode=TwoWay}"
                        OffContent="{x:Bind ViewModel.CommonToggleOffText, Mode=OneWay}"
                        OnContent="{x:Bind ViewModel.CommonToggleOnText, Mode=OneWay}" />

                    <TextBlock
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.SettingsProcessingBehaviorDescriptionText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border
                Padding="14"
                Background="{ThemeResource SettingsPaneSectionBrush}"
                CornerRadius="16"
                Visibility="{x:Bind ViewModel.SettingsPaneTranscodingVisibility, Mode=OneWay}">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.SettingsTranscodingTitleText, Mode=OneWay}" />
                        <Border
                            Width="18"
                            Height="18"
                            Background="{ThemeResource SettingsInfoBadgeBackgroundBrush}"
                            CornerRadius="9"
                            VerticalAlignment="Center">
                            <ToolTipService.ToolTip>
                                <ToolTip>
                                    <TextBlock
                                        MaxWidth="360"
                                        Text="{x:Bind ViewModel.SettingsPaneTranscodingInfoTooltip, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </ToolTip>
                            </ToolTipService.ToolTip>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="{ThemeResource SettingsInfoBadgeForegroundBrush}"
                                Text="!" />
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="{x:Bind ViewModel.SettingsTranscodingLabelText, Mode=OneWay}" />
                        <ComboBox
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{x:Bind ViewModel.TranscodingOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedTranscodingModeOption, Mode=TwoWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.SelectedTranscodingModeOption.Description, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.GpuAccelerationSettingVisibility, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Video" />
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.SettingsGpuAccelerationTitleText, Mode=OneWay}" />
                        </StackPanel>

                        <ToggleSwitch
                            Header="{x:Bind ViewModel.SettingsGpuAccelerationToggleHeaderText, Mode=OneWay}"
                            IsOn="{x:Bind ViewModel.EnableGpuAccelerationForTranscoding, Mode=TwoWay}"
                            OffContent="{x:Bind ViewModel.CommonToggleOffText, Mode=OneWay}"
                            OnContent="{x:Bind ViewModel.CommonToggleOnText, Mode=OneWay}" />

                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.GpuAccelerationDescription, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
