<UserControl
    x:Class="Vidvix.Views.Controls.TerminalOutputPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:Vidvix.ViewModels"
    mc:Ignorable="d"
    x:Name="Root">

    <Border
        Padding="16,14"
        Style="{StaticResource SurfaceCardBorderStyle}">
        <Grid RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.OutputSectionTitle, Mode=OneWay}" />
                <TextBlock
                    Opacity="0.72"
                    Text="{x:Bind ViewModel.OutputSectionDescription, Mode=OneWay}" />
            </StackPanel>

            <Grid Grid.Row="1">
                <ScrollViewer
                    x:Name="OutputScrollViewer"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Enabled"
                    Visibility="{x:Bind ViewModel.OutputEntriesVisibility, Mode=OneWay}">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.OutputEntries, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:TerminalOutputEntryViewModel">
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="12,10"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                FontSize="12"
                                                Opacity="0.72"
                                                Text="{x:Bind HeaderText, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Opacity="0.72"
                                                Text="{x:Bind StatusText, Mode=OneWay}"
                                                Visibility="{x:Bind StatusVisibility, Mode=OneWay}" />
                                        </Grid>

                                        <TextBlock
                                            FontSize="13"
                                            FontFamily="Cascadia Mono,Consolas,Segoe UI"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind CommandText, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords"
                                            Visibility="{x:Bind CommandVisibility, Mode=OneWay}" />

                                        <TextBlock
                                            FontSize="13"
                                            FontFamily="Cascadia Mono,Consolas,Segoe UI"
                                            Text="{x:Bind OutputText, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords"
                                            Visibility="{x:Bind OutputVisibility, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border
                    Padding="18,22"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                        <SymbolIcon
                            HorizontalAlignment="Center"
                            Opacity="0.72"
                            Symbol="Document" />
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            Text="{x:Bind ViewModel.EmptyStateTitle, Mode=OneWay}"
                            TextAlignment="Center" />
                        <TextBlock
                            MaxWidth="460"
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.EmptyStateDescription, Mode=OneWay}"
                            TextWrapping="WrapWholeWords"
                            TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
