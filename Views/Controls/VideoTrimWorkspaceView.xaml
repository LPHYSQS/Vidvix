<UserControl
    x:Class="Vidvix.Views.Controls.VideoTrimWorkspaceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Vidvix.Views.Controls"
    xmlns:models="using:Vidvix.Core.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="TimelineStripButtonStyle"
            TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>
    <Border Padding="16" Style="{StaticResource SurfaceCardBorderStyle}">
        <Grid RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="16" Visibility="{x:Bind ViewModel.EditorVisibility, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="视频裁剪" />
                    <TextBlock Opacity="0.72" Text="导入后会在同一张主卡片中显示预览、时间轴、裁剪范围与导出设置。" TextWrapping="WrapWholeWords" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="2" Visibility="{x:Bind ViewModel.EditorVisibility, Mode=OneWay}">
                    <TextBlock HorizontalAlignment="Right" Style="{StaticResource CaptionTextStyle}" Text="当前文件" />
                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.InputFileName, Mode=OneWay}" TextAlignment="Right" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>

            <Grid Grid.RowSpan="2" MinHeight="420" Visibility="{x:Bind ViewModel.PlaceholderVisibility, Mode=OneWay}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="760" Spacing="16">
                    <SymbolIcon HorizontalAlignment="Center" Symbol="Video" />
                    <TextBlock FontSize="28" FontWeight="SemiBold" MaxWidth="720" Text="请导入视频文件或拖拽到此处开始裁剪" TextAlignment="Center" TextWrapping="Wrap" />
                    <TextBlock MaxWidth="760" Opacity="0.72" Text="导入后会在同一张主卡片中显示视频预览、播放控制、时间轴、双滑块裁剪和输出格式选择。" TextAlignment="Center" TextWrapping="Wrap" />
                    <Button HorizontalAlignment="Center" Command="{x:Bind ViewModel.SelectVideoCommand, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="OpenFile" />
                            <TextBlock Text="导入视频" />
                        </StackPanel>
                    </Button>
                    <TextBlock MaxWidth="760" Opacity="0.72" Text="{x:Bind ViewModel.SupportedInputFormatsHint, Mode=OneWay}" TextAlignment="Center" TextWrapping="Wrap" />
                    <Border HorizontalAlignment="Center" MaxWidth="760" Padding="14" Background="{ThemeResource ControlFillColorSecondaryBrush}" CornerRadius="14" Visibility="{x:Bind ViewModel.ImportErrorVisibility, Mode=OneWay}">
                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="导入失败详情" TextAlignment="Center" />
                            <TextBlock Opacity="0.82" Text="{x:Bind ViewModel.LastImportErrorDetails, Mode=OneWay}" TextAlignment="Center" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="16" RowSpacing="14" Visibility="{x:Bind ViewModel.EditorVisibility, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.75*" />
                    <ColumnDefinition Width="1.05*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Column="0" Grid.Row="0" MinHeight="190" Background="Black" CornerRadius="18">
                    <Grid x:Name="PreviewViewport" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <MediaPlayerElement x:Name="PreviewPlayer" AreTransportControlsEnabled="False" AutoPlay="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Stretch="Uniform" />
                        <Border Background="#66000000" CornerRadius="18" Visibility="{x:Bind ViewModel.PreviewOverlayVisibility, Mode=OneWay}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="320" Spacing="10">
                                <SymbolIcon HorizontalAlignment="Center" Foreground="White" Symbol="Video" />
                                <TextBlock Foreground="White" Text="{x:Bind ViewModel.PreviewStateMessage, Mode=OneWay}" TextAlignment="Center" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="0" Grid.Row="1" MinHeight="44" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Margin="0,0,8,0"
                        AutomationProperties.Name="{x:Bind ViewModel.PlayPauseButtonText, Mode=OneWay}"
                        Click="OnPlayPauseClick"
                        IsEnabled="{x:Bind ViewModel.CanPlayPreview, Mode=OneWay}"
                        Style="{StaticResource TimelineStripButtonStyle}"
                        ToolTipService.ToolTip="{x:Bind ViewModel.PlayPauseButtonText, Mode=OneWay}">
                        <SymbolIcon Foreground="{ThemeResource TextFillColorSecondaryBrush}" Symbol="{x:Bind ViewModel.PlayPauseButtonSymbol, Mode=OneWay}" />
                    </Button>

                    <Button
                        Grid.Column="1"
                        Margin="0,0,14,0"
                        AutomationProperties.Name="回到入点"
                        Click="OnResetPreviewClick"
                        IsEnabled="{x:Bind ViewModel.CanPlayPreview, Mode=OneWay}"
                        Style="{StaticResource TimelineStripButtonStyle}"
                        ToolTipService.ToolTip="回到入点">
                        <SymbolIcon Foreground="{ThemeResource TextFillColorSecondaryBrush}" Symbol="Back" />
                    </Button>

                    <Slider
                        Grid.Column="2"
                        x:Name="TimelineSlider"
                        Height="24"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="时间轴定位"
                        Background="{ThemeResource ControlFillColorTertiaryBrush}"
                        CornerRadius="999"
                        Foreground="{ThemeResource ControlStrongFillColorDefaultBrush}"
                        Maximum="{x:Bind ViewModel.TimelineMaximum, Mode=OneWay}"
                        Minimum="{x:Bind ViewModel.TimelineMinimum, Mode=OneWay}"
                        Value="{x:Bind ViewModel.CurrentPositionMilliseconds, Mode=TwoWay}"
                        ValueChanged="OnTimelineSliderValueChanged">
                        <Slider.Resources>
                            <x:Double x:Key="SliderHorizontalHeight">24</x:Double>
                            <x:Double x:Key="SliderTrackThemeHeight">4</x:Double>
                            <x:Double x:Key="SliderHorizontalThumbWidth">14</x:Double>
                            <x:Double x:Key="SliderHorizontalThumbHeight">14</x:Double>
                            <StaticResource x:Key="SliderThumbBackground" ResourceKey="ControlStrongFillColorDefaultBrush" />
                            <StaticResource x:Key="SliderThumbBackgroundPointerOver" ResourceKey="TextFillColorPrimaryBrush" />
                            <StaticResource x:Key="SliderThumbBackgroundPressed" ResourceKey="TextFillColorPrimaryBrush" />
                        </Slider.Resources>
                    </Slider>

                    <TextBlock
                        Grid.Column="3"
                        Margin="14,0,12,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{x:Bind ViewModel.TimelinePositionText, Mode=OneWay}" />

                    <Button
                        Grid.Column="4"
                        Margin="0,0,8,0"
                        AutomationProperties.Name="回到出点"
                        Click="OnJumpToSelectionEndClick"
                        IsEnabled="{x:Bind ViewModel.CanPlayPreview, Mode=OneWay}"
                        Style="{StaticResource TimelineStripButtonStyle}"
                        ToolTipService.ToolTip="回到出点">
                        <SymbolIcon Foreground="{ThemeResource TextFillColorSecondaryBrush}" Symbol="Forward" />
                    </Button>

                    <Button
                        Grid.Column="5"
                        AutomationProperties.Name="音量"
                        HorizontalAlignment="Right"
                        IsEnabled="{x:Bind ViewModel.CanPlayPreview, Mode=OneWay}"
                        PointerWheelChanged="OnVolumeButtonPointerWheelChanged"
                        Style="{StaticResource TimelineStripButtonStyle}"
                        ToolTipService.ToolTip="音量">
                        <SymbolIcon Foreground="{ThemeResource TextFillColorSecondaryBrush}" Symbol="{x:Bind ViewModel.VolumeButtonSymbol, Mode=OneWay}" />
                        <Button.Flyout>
                            <Flyout Placement="TopEdgeAlignedRight">
                                <StackPanel Padding="4" HorizontalAlignment="Center" Spacing="10">
                                    <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Text="音量" />
                                    <TextBlock HorizontalAlignment="Center" Opacity="0.72" Text="{x:Bind ViewModel.VolumePercentText, Mode=OneWay}" />
                                    <Slider Height="150" Minimum="0" Maximum="100" Orientation="Vertical" StepFrequency="1" Value="{x:Bind ViewModel.VolumePercent, Mode=TwoWay}" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </Grid>

                <Border Grid.Column="0" Grid.Row="2" Padding="14" Background="{ThemeResource ControlFillColorSecondaryBrush}" CornerRadius="16">
                    <StackPanel Spacing="12">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="裁剪区间" />
                        <TextBlock Opacity="0.72" Text="{x:Bind ViewModel.SelectionSummaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <local:DualThumbRangeSelector x:Name="RangeSelector" EndValue="{x:Bind ViewModel.SelectionEndMilliseconds, Mode=TwoWay}" Maximum="{x:Bind ViewModel.SelectionMaximum, Mode=OneWay}" Minimum="0" MinimumRange="1" SelectionChanged="OnRangeSelectorSelectionChanged" StartValue="{x:Bind ViewModel.SelectionStartMilliseconds, Mode=TwoWay}" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="入点" />
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectionStartText, Mode=OneWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="片段时长" />
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedDurationText, Mode=OneWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="2">
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="出点" />
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectionEndText, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Column="1" Grid.RowSpan="3" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                    <StackPanel Padding="0,0,16,0" Spacing="12">
                        <Border Padding="12" Background="{ThemeResource ControlFillColorSecondaryBrush}" CornerRadius="16">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="当前选区" />
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectionSummaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="入点" />
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectionStartText, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="出点" />
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectionEndText, Mode=OneWay}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Opacity="0.72" Text="导出时会严格按照入点和出点截取视频片段。" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Border Padding="12" Background="{ThemeResource ControlFillColorSecondaryBrush}" CornerRadius="16">
                            <StackPanel Spacing="10">
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="输出设置" />
                                <StackPanel Spacing="6">
                                    <TextBlock Text="输出格式" />
                                    <ComboBox DisplayMemberPath="DisplayName" ItemsSource="{x:Bind ViewModel.AvailableOutputFormats, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedOutputFormat, Mode=TwoWay}" />
                                    <TextBlock Opacity="0.72" Text="{x:Bind ViewModel.SelectedOutputFormatDescription, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="输出目录" />
                                    <TextBox IsReadOnly="True" Text="{x:Bind ViewModel.OutputDirectory, Mode=OneWay}" />
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Opacity="0.72" Text="留空时默认导出到原视频所在文件夹" TextWrapping="WrapWholeWords" />
                                        <Button Grid.Column="1" Command="{x:Bind ViewModel.SelectOutputDirectoryCommand, Mode=OneWay}" Content="选择目录" />
                                        <Button Grid.Column="2" Command="{x:Bind ViewModel.ClearOutputDirectoryCommand, Mode=OneWay}" Content="清空" />
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="计划输出路径" />
                                    <TextBox IsReadOnly="True" Text="{x:Bind ViewModel.PlannedOutputPath, Mode=OneWay}" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Padding="12" Background="{ThemeResource ControlFillColorSecondaryBrush}" CornerRadius="16">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="视频信息" />
                                <TextBlock MaxLines="2" FontWeight="SemiBold" Text="{x:Bind ViewModel.InputFileName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Opacity="0.72" Text="{x:Bind ViewModel.InputPath, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                <StackPanel Spacing="6" Visibility="{x:Bind ViewModel.BasicInfoVisibility, Mode=OneWay}">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="基础信息" />
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.BasicInfoFields, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:MediaDetailField">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Opacity="0.72" Text="{x:Bind Label}" />
                                                    <TextBlock Grid.Column="1" Opacity="0.72" Text=":" />
                                                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="{x:Bind Value}" TextWrapping="WrapWholeWords" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <StackPanel Spacing="6" Visibility="{x:Bind ViewModel.VideoInfoVisibility, Mode=OneWay}">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="视频信息" />
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.VideoInfoFields, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:MediaDetailField">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Opacity="0.72" Text="{x:Bind Label}" />
                                                    <TextBlock Grid.Column="1" Opacity="0.72" Text=":" />
                                                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="{x:Bind Value}" TextWrapping="WrapWholeWords" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <StackPanel Spacing="6" Visibility="{x:Bind ViewModel.AudioInfoVisibility, Mode=OneWay}">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="音频信息" />
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.AudioInfoFields, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:MediaDetailField">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Opacity="0.72" Text="{x:Bind Label}" />
                                                    <TextBlock Grid.Column="1" Opacity="0.72" Text=":" />
                                                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="{x:Bind Value}" TextWrapping="WrapWholeWords" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Opacity="0.72" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</UserControl>
