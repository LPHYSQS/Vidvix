<Page
    x:Class="Vidvix.Views.SplitAudioPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="SplitAudioInsetCardStyle"
            TargetType="Border"
            BasedOn="{StaticResource InsetSurfaceCardBorderStyle}">
            <Setter Property="CornerRadius" Value="18" />
        </Style>
    </Page.Resources>

    <Grid
        Padding="8,6,8,0"
        ColumnSpacing="12"
        RowSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

            <Border
                Grid.Column="0"
                Padding="20"
                Style="{StaticResource SurfaceCardBorderStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="导入文件" />
                        <TextBlock
                            Opacity="0.72"
                            Text="一次仅支持导入 1 个音频或视频文件；若导入视频，需包含可用音频轨道。"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Border
                        Grid.Row="1"
                        MinHeight="168"
                        Padding="16"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Grid>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="420"
                                Spacing="12">
                                <SymbolIcon
                                    HorizontalAlignment="Center"
                                    Symbol="OpenFile" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="请导入文件或拖拽到此处"
                                    TextAlignment="Center" />
                                <Button
                                    HorizontalAlignment="Center"
                                    IsEnabled="False">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="OpenFile" />
                                        <TextBlock Text="导入文件" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

        <Border
            Grid.RowSpan="2"
            Grid.Column="1"
            Padding="18"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        Style="{StaticResource SectionTitleTextStyle}"
                        Text="拆音相关设置" />
                    <TextBlock
                        Opacity="0.72"
                        Text="右侧只承接拆音模块自身的输出与命名配置，不影响其他工作区。"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <ScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Enabled">
                    <StackPanel Padding="0,0,4,0" Spacing="16">
                        <Border
                            Padding="14"
                            Style="{StaticResource SplitAudioInsetCardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="输出格式" />
                                <ComboBox SelectedIndex="0">
                                    <ComboBoxItem Content="WAV" />
                                    <ComboBoxItem Content="FLAC" />
                                    <ComboBoxItem Content="MP3" />
                                </ComboBox>
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="预留为拆分结果的默认导出格式选择。" />
                            </StackPanel>
                        </Border>

                        <Border
                            Padding="14"
                            Style="{StaticResource SplitAudioInsetCardStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="输出内容" />
                                <ToggleSwitch
                                    Header="导出人声轨道"
                                    IsOn="True"
                                    OffContent="关闭"
                                    OnContent="开启" />
                                <ToggleSwitch
                                    Header="导出背景音轨道"
                                    IsOn="True"
                                    OffContent="关闭"
                                    OnContent="开启" />
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="后续可扩展为仅人声、仅伴奏或同时导出。" />
                            </StackPanel>
                        </Border>

                        <Border
                            Padding="14"
                            Style="{StaticResource SplitAudioInsetCardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="默认保存目录" />
                                <TextBox
                                    IsReadOnly="True"
                                    PlaceholderText="跟随源文件目录，或在后续逻辑中指定默认位置" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button
                                        Grid.Column="0"
                                        IsEnabled="False"
                                        Content="选择目录" />
                                    <Button
                                        Grid.Column="1"
                                        IsEnabled="False"
                                        Content="恢复默认" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border
                            Padding="14"
                            Style="{StaticResource SplitAudioInsetCardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="导出命名规则" />
                                <TextBox Text="{x:Bind VocalFileNameTemplate, Mode=TwoWay}" />
                                <TextBox Text="{x:Bind InstrumentalFileNameTemplate, Mode=TwoWay}" />
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="当前仅为 UI 输入框预留，后续可按模板替换原文件名变量。" />
                            </StackPanel>
                        </Border>

                        <Border
                            Padding="14"
                            Style="{StaticResource SplitAudioInsetCardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="试听与导出预留" />
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="结果列表中的试听、单项导出和一键导出按钮已完成布局预留，待后续接入实际命令。" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Grid.Column="0"
            Padding="20"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="处理完毕列表" />
                            <TextBlock
                                Opacity="0.72"
                                Text="处理完毕的音频拆音结果展示。"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <Button
                            Grid.Column="1"
                            IsEnabled="False"
                            HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Save" />
                                <TextBlock Text="全部导出" />
                            </StackPanel>
                        </Button>
                    </Grid>

                <Border
                    Grid.Row="1"
                    Padding="0"
                    Style="{StaticResource SplitAudioInsetCardStyle}">
                    <Grid>
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto"
                            VerticalScrollMode="Enabled">
                            <StackPanel Padding="16" Spacing="12" />
                        </ScrollViewer>

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0.72"
                            Text="暂无处理结果" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
