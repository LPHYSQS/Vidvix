<Page
    x:Class="Vidvix.Views.SplitAudioPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:converters="using:Vidvix.Views.Converters"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Vidvix.Views.Controls"
    xmlns:viewModels="using:Vidvix.ViewModels"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="SplitAudioInsetCardStyle"
            TargetType="Border"
            BasedOn="{StaticResource InsetSurfaceCardBorderStyle}">
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style
            x:Key="TimelineStripButtonStyle"
            TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid
                            x:Name="LayoutRoot"
                            MinWidth="{TemplateBinding MinWidth}"
                            MinHeight="{TemplateBinding MinHeight}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="InteractionSurface.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="InteractionSurface.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Opacity" Value="0.42" />
                                            <Setter Target="InteractionSurface.Background" Value="Transparent" />
                                            <Setter Target="InteractionSurface.BorderBrush" Value="Transparent" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Border
                                x:Name="InteractionSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <converters:TimelineMillisecondsToTimeConverter x:Key="TimelineMillisecondsToTimeConverter" />

        <DataTemplate
            x:Key="SplitAudioResultTemplate"
            x:DataType="viewModels:SplitAudioResultItemViewModel">
            <Border
                Margin="0,0,0,12"
                Padding="16"
                Style="{StaticResource SplitAudioInsetCardStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{x:Bind SourceFileName}" />
                            <TextBlock
                                Opacity="0.72"
                                Text="{x:Bind OutputDirectory}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Spacing="4">
                            <TextBlock
                                HorizontalAlignment="Right"
                                Opacity="0.72"
                                Text="{x:Bind CompletedAtText}" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                Opacity="0.72"
                                Text="{x:Bind DurationText}" />
                        </StackPanel>
                    </Grid>

                    <Grid
                        Grid.Row="1"
                        ColumnSpacing="10"
                        RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            Padding="12"
                            Background="{ThemeResource ControlFillColorTertiaryBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="人声 · vocals" />
                                <TextBlock
                                    Opacity="0.72"
                                    Text="{x:Bind VocalsFileName}"
                                    TextTrimming="CharacterEllipsis" />
                                <Button
                                    Command="{Binding ElementName=RootPage, Path=ViewModel.RevealFileCommand}"
                                    CommandParameter="{x:Bind VocalsPath}"
                                    Content="定位文件" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Padding="12"
                            Background="{ThemeResource ControlFillColorTertiaryBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="鼓组 · drums" />
                                <TextBlock
                                    Opacity="0.72"
                                    Text="{x:Bind DrumsFileName}"
                                    TextTrimming="CharacterEllipsis" />
                                <Button
                                    Command="{Binding ElementName=RootPage, Path=ViewModel.RevealFileCommand}"
                                    CommandParameter="{x:Bind DrumsPath}"
                                    Content="定位文件" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="1"
                            Padding="12"
                            Background="{ThemeResource ControlFillColorTertiaryBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="低频 · bass" />
                                <TextBlock
                                    Opacity="0.72"
                                    Text="{x:Bind BassFileName}"
                                    TextTrimming="CharacterEllipsis" />
                                <Button
                                    Command="{Binding ElementName=RootPage, Path=ViewModel.RevealFileCommand}"
                                    CommandParameter="{x:Bind BassPath}"
                                    Content="定位文件" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="1"
                            Grid.Column="1"
                            Padding="12"
                            Background="{ThemeResource ControlFillColorTertiaryBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="其他 · other" />
                                <TextBlock
                                    Opacity="0.72"
                                    Text="{x:Bind OtherFileName}"
                                    TextTrimming="CharacterEllipsis" />
                                <Button
                                    Command="{Binding ElementName=RootPage, Path=ViewModel.RevealFileCommand}"
                                    CommandParameter="{x:Bind OtherPath}"
                                    Content="定位文件" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate
            x:Key="SplitAudioResultCardTemplate"
            x:DataType="viewModels:SplitAudioResultItemViewModel">
            <StackPanel Margin="0,0,0,18" Spacing="12">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="15"
                            FontWeight="SemiBold"
                            Text="{x:Bind SourceFileName}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind OutputDirectory}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        Spacing="4">
                        <TextBlock
                            HorizontalAlignment="Right"
                            Opacity="0.72"
                            Text="{x:Bind CompletedAtText}" />
                        <TextBlock
                            HorizontalAlignment="Right"
                            Opacity="0.72"
                            Text="{x:Bind DurationText}" />
                    </StackPanel>
                </Grid>

                <Grid
                    ColumnSpacing="10"
                    RowSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <controls:SplitAudioStemPreviewCard
                        DurationMilliseconds="{x:Bind DurationMilliseconds}"
                        FilePath="{x:Bind VocalsPath}"
                        RevealCommand="{Binding ElementName=RootPage, Path=ViewModel.RevealFileCommand}"
                        StemTitle="人声 / vocals" />

                    <controls:SplitAudioStemPreviewCard
                        Grid.Column="1"
                        DurationMilliseconds="{x:Bind DurationMilliseconds}"
                        FilePath="{x:Bind DrumsPath}"
                        RevealCommand="{Binding ElementName=RootPage, Path=ViewModel.RevealFileCommand}"
                        StemTitle="鼓组 / drums" />

                    <controls:SplitAudioStemPreviewCard
                        Grid.Row="1"
                        DurationMilliseconds="{x:Bind DurationMilliseconds}"
                        FilePath="{x:Bind BassPath}"
                        RevealCommand="{Binding ElementName=RootPage, Path=ViewModel.RevealFileCommand}"
                        StemTitle="低频 / bass" />

                    <controls:SplitAudioStemPreviewCard
                        Grid.Row="1"
                        Grid.Column="1"
                        DurationMilliseconds="{x:Bind DurationMilliseconds}"
                        FilePath="{x:Bind OtherPath}"
                        RevealCommand="{Binding ElementName=RootPage, Path=ViewModel.RevealFileCommand}"
                        StemTitle="其他 / other" />
                </Grid>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid
        Padding="8,0,0,0"
        ColumnSpacing="12"
        RowSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="PreviewHostAnchor"
            Width="1"
            Height="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            IsHitTestVisible="False"
            Opacity="0" />

        <Border
            Grid.Column="0"
            Padding="20"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        Style="{StaticResource SectionTitleTextStyle}"
                        Text="导入文件" />
                    <TextBlock
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.SupportedInputFormatsHint, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <Border
                        MinHeight="168"
                        Padding="16"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{x:Bind ViewModel.PlaceholderVisibility, Mode=OneWay}">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="420"
                            Spacing="12">
                            <SymbolIcon
                                HorizontalAlignment="Center"
                                Symbol="OpenFile" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontWeight="SemiBold"
                                Text="请导入文件或拖拽到此处"
                                TextAlignment="Center" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                Opacity="0.72"
                                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                TextAlignment="Center"
                                TextWrapping="WrapWholeWords" />
                            <Button
                                Command="{x:Bind ViewModel.SelectInputCommand, Mode=OneWay}"
                                HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="OpenFile" />
                                    <TextBlock Text="导入文件" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border
                        MinHeight="168"
                        Padding="16"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{x:Bind ViewModel.InputCardVisibility, Mode=OneWay}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.InputFileName, Mode=OneWay}" />
                                    <TextBlock
                                        Opacity="0.72"
                                        Text="{x:Bind ViewModel.InputPath, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <Button
                                    Grid.Column="1"
                                    Command="{x:Bind ViewModel.RemoveInputCommand, Mode=OneWay}"
                                    Content="移除" />
                            </Grid>

                            <Border
                                Grid.Row="1"
                                Padding="12"
                                Style="{StaticResource SplitAudioInsetCardStyle}">
                                <StackPanel Spacing="10">
                                    <Grid ColumnSpacing="12" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button
                                            AutomationProperties.Name="{x:Bind ViewModel.PlayPauseButtonText, Mode=OneWay}"
                                            Click="OnPlayPauseClick"
                                            IsEnabled="{x:Bind ViewModel.CanPlayPreview, Mode=OneWay}"
                                            Style="{StaticResource TimelineStripButtonStyle}"
                                            ToolTipService.ToolTip="{x:Bind ViewModel.PlayPauseButtonText, Mode=OneWay}">
                                            <SymbolIcon
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Symbol="{x:Bind ViewModel.PlayPauseButtonSymbol, Mode=OneWay}" />
                                        </Button>

                                        <Slider
                                            Grid.Column="1"
                                            x:Name="TimelineSlider"
                                            Height="24"
                                            IsEnabled="{x:Bind ViewModel.CanPlayPreview, Mode=OneWay}"
                                            IsThumbToolTipEnabled="True"
                                            Margin="0,-3,0,0"
                                            ThumbToolTipValueConverter="{StaticResource TimelineMillisecondsToTimeConverter}"
                                            VerticalAlignment="Center"
                                            Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                            CornerRadius="999"
                                            Foreground="{ThemeResource ControlStrongFillColorDefaultBrush}"
                                            Maximum="{x:Bind ViewModel.TimelineMaximum, Mode=OneWay}"
                                            Minimum="{x:Bind ViewModel.TimelineMinimum, Mode=OneWay}"
                                            Value="{x:Bind ViewModel.CurrentPositionMilliseconds, Mode=TwoWay}"
                                            ValueChanged="OnTimelineSliderValueChanged">
                                            <Slider.Resources>
                                                <x:Double x:Key="SliderHorizontalHeight">24</x:Double>
                                                <x:Double x:Key="SliderTrackThemeHeight">4</x:Double>
                                                <x:Double x:Key="SliderHorizontalThumbWidth">14</x:Double>
                                                <x:Double x:Key="SliderHorizontalThumbHeight">14</x:Double>
                                                <StaticResource x:Key="SliderThumbBackground" ResourceKey="ControlStrongFillColorDefaultBrush" />
                                                <StaticResource x:Key="SliderThumbBackgroundPointerOver" ResourceKey="TextFillColorPrimaryBrush" />
                                                <StaticResource x:Key="SliderThumbBackgroundPressed" ResourceKey="TextFillColorPrimaryBrush" />
                                            </Slider.Resources>
                                        </Slider>

                                        <TextBlock
                                            Grid.Column="2"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="{x:Bind ViewModel.TimelinePositionText, Mode=OneWay}" />
                                    </Grid>

                                    <TextBlock
                                        Opacity="0.72"
                                        Text="{x:Bind ViewModel.InputSummaryText, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border
            Grid.RowSpan="2"
            Grid.Column="1"
            Padding="16"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <ScrollViewer
                Padding="0,0,12,0"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Enabled">
                <StackPanel Spacing="18">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="拆音相关设置" />
                        <TextBlock
                            Opacity="0.72"
                            Text="输出格式仍由 FFmpeg 负责，Demucs 只负责生成中间四轨。"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="输出格式" />
                        <ComboBox
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{x:Bind ViewModel.AvailableOutputFormats, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedOutputFormat, Mode=TwoWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.SelectedOutputFormatDescription, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="输出目录" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                IsReadOnly="True"
                                PlaceholderText="原文件目录"
                                Text="{x:Bind ViewModel.OutputDirectory, Mode=OneWay}" />
                            <Button
                                Grid.Column="1"
                                Command="{x:Bind ViewModel.BrowseOutputDirectoryCommand, Mode=OneWay}"
                                Content="选择目录" />
                            <Button
                                Grid.Column="2"
                                Command="{x:Bind ViewModel.ClearOutputDirectoryCommand, Mode=OneWay}"
                                Content="清空" />
                        </Grid>
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.OutputDirectoryHintText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="拆音加速模式" />
                        <ComboBox
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{x:Bind ViewModel.AvailableAccelerationModes, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedAccelerationMode, Mode=TwoWay}" />
                        <TextBlock
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.SelectedAccelerationModeDescription, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="当前状态" />
                        <Border
                            Padding="12"
                            Style="{StaticResource SplitAudioInsetCardStyle}">
                            <TextBlock
                                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border
            Grid.Row="1"
            Grid.Column="0"
            Padding="20"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        Style="{StaticResource SectionTitleTextStyle}"
                        Text="处理完毕列表" />
                    <TextBlock
                        Opacity="0.72"
                        Text="每次完成后会按原文件名 + stem 名称输出四个结果文件。"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    Padding="16,16,6,16"
                    Style="{StaticResource SplitAudioInsetCardStyle}">
                    <Grid>
                        <ScrollViewer
                            Padding="0,0,14,0"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto"
                            VerticalScrollMode="Enabled"
                            Visibility="{x:Bind ViewModel.ResultsVisibility, Mode=OneWay}">
                            <ItemsControl
                                ItemTemplate="{StaticResource SplitAudioResultCardTemplate}"
                                ItemsSource="{x:Bind ViewModel.ResultItems, Mode=OneWay}" />
                        </ScrollViewer>

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0.72"
                            Text="暂无处理结果"
                            Visibility="{x:Bind ViewModel.EmptyResultsVisibility, Mode=OneWay}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
