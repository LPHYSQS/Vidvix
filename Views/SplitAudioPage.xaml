<Page
    x:Class="Vidvix.Views.SplitAudioPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="SplitAudioInsetCardStyle"
            TargetType="Border"
            BasedOn="{StaticResource InsetSurfaceCardBorderStyle}">
            <Setter Property="CornerRadius" Value="18" />
        </Style>
    </Page.Resources>

    <Grid
        Padding="8,0,0,0"
        ColumnSpacing="12"
        RowSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

            <Border
                Grid.Column="0"
                Padding="20"
                Style="{StaticResource SurfaceCardBorderStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="导入文件" />
                        <TextBlock
                            Opacity="0.72"
                            Text="一次仅支持导入 1 个音频或视频文件；若导入视频，需包含可用音频轨道。"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Border
                        Grid.Row="1"
                        MinHeight="168"
                        Padding="16"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Grid>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="420"
                                Spacing="12">
                                <SymbolIcon
                                    HorizontalAlignment="Center"
                                    Symbol="OpenFile" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="请导入文件或拖拽到此处"
                                    TextAlignment="Center" />
                                <Button
                                    HorizontalAlignment="Center"
                                    IsEnabled="False">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="OpenFile" />
                                        <TextBlock Text="导入文件" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

        <Border
            Grid.RowSpan="2"
            Grid.Column="1"
            Padding="16"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        Style="{StaticResource SectionTitleTextStyle}"
                        Text="拆音相关设置" />
                    <TextBlock
                        Opacity="0.72"
                        Text="设置拆音结果的输出格式与全部导出目录。"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <ScrollViewer
                    Grid.Row="1"
                    Padding="0,0,14,0"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Enabled">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="8">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="输出格式" />
                            <ComboBox
                                x:Name="SplitAudioOutputFormatComboBox"
                                SelectedIndex="0"
                                SelectionChanged="OnOutputFormatSelectionChanged">
                                <ComboBoxItem
                                    Content="MP3"
                                    Tag="通用音频格式，兼容性高。" />
                                <ComboBoxItem
                                    Content="M4A"
                                    Tag="AAC 封装，音质和体积较平衡。" />
                                <ComboBoxItem
                                    Content="AAC"
                                    Tag="原始 AAC 音频流。" />
                                <ComboBoxItem
                                    Content="WAV"
                                    Tag="无压缩音频，适合继续编辑。" />
                                <ComboBoxItem
                                    Content="FLAC"
                                    Tag="无损压缩音频，适合存档。" />
                                <ComboBoxItem
                                    Content="WMA"
                                    Tag="适合部分 Windows 播放环境和旧式工作流。" />
                                <ComboBoxItem
                                    Content="OGG"
                                    Tag="开放音频容器，适合 Vorbis 音频分发。" />
                                <ComboBoxItem
                                    Content="OPUS"
                                    Tag="现代低码率高音质格式，适合语音和流媒体。" />
                                <ComboBoxItem
                                    Content="AIFF"
                                    Tag="无压缩音频，常见于部分专业音频和 Apple 工作流。" />
                                <ComboBoxItem
                                    Content="AIF"
                                    Tag="AIFF 的常见扩展名，适合需要 .aif 后缀的场景。" />
                                <ComboBoxItem
                                    Content="MKA"
                                    Tag="Matroska Audio 容器，适合保留原始音频编码输出。" />
                            </ComboBox>
                            <TextBlock
                                x:Name="SplitAudioOutputFormatDescriptionText"
                                Opacity="0.72"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="输出目录" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    x:Name="SplitAudioOutputDirectoryTextBox"
                                    IsReadOnly="True"
                                    PlaceholderText="原文件目录" />
                                <Button
                                    Grid.Column="1"
                                    Click="OnBrowseOutputDirectoryClick"
                                    Content="选择目录" />
                                <Button
                                    Grid.Column="2"
                                    Click="OnClearOutputDirectoryClick"
                                    Content="清空" />
                            </Grid>
                            <TextBlock
                                Opacity="0.72"
                                Text="该目录仅对全部导出生效。"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Grid.Column="0"
            Padding="20"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="处理完毕列表" />
                            <TextBlock
                                Opacity="0.72"
                                Text="处理完毕的音频拆音结果展示。"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <Button
                            Grid.Column="1"
                            IsEnabled="False"
                            HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Save" />
                                <TextBlock Text="全部导出" />
                            </StackPanel>
                        </Button>
                    </Grid>

                <Border
                    Grid.Row="1"
                    Padding="0"
                    Style="{StaticResource SplitAudioInsetCardStyle}">
                    <Grid>
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto"
                            VerticalScrollMode="Enabled">
                            <StackPanel Padding="16" Spacing="12" />
                        </ScrollViewer>

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0.72"
                            Text="暂无处理结果" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
