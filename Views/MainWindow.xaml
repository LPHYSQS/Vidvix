<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Vidvix.Views.MainWindow"
    x:Name="RootWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Vidvix.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Vidvix.Core.Models"
    xmlns:viewModels="using:Vidvix.ViewModels"
    mc:Ignorable="d"
    Title="Vidvix">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootLayout"
        AllowDrop="True"
        DragOver="OnRootDragOver"
        Drop="OnRootDrop"
        Loaded="OnRootLayoutLoaded"
        Padding="16,8,16,16"
        RequestedTheme="{x:Bind ViewModel.RequestedTheme, Mode=OneWay}"
        RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Padding="14,12"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    MaxWidth="360"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="12">
                    <Image
                        Width="40"
                        Height="40"
                        Source="ms-appx:///Assets/logo.png"
                        Stretch="Uniform" />

                    <StackPanel
                        MaxWidth="308"
                        VerticalAlignment="Center"
                        Spacing="2">
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="快速开始" />
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            MaxLines="2"
                            Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            Opacity="0.72"
                            Text="支持导入文件、文件夹，也支持直接拖拽到窗口"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>

                <CommandBar
                    Grid.Column="1"
                    Background="Transparent"
                    DefaultLabelPosition="Right"
                    IsDynamicOverflowEnabled="True"
                    VerticalAlignment="Center">
                    <AppBarButton Command="{x:Bind ViewModel.SelectFilesCommand}" Label="导入文件">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="OpenFile" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.SelectFolderCommand}" Label="导入文件夹">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Folder" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.ClearQueueCommand}" Label="清空列表">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Delete" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <AppBarButton Command="{x:Bind ViewModel.ExecuteProcessingCommand}" Label="开始处理">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Play" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.CancelExecutionCommand}" Label="取消任务">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Cancel" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <AppBarButton Command="{x:Bind ViewModel.ToggleSettingsPaneCommand}" Label="应用设置">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Setting" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>

            </Grid>
        </Border>

        <SplitView
            Grid.Row="1"
            CompactPaneLength="0"
            DisplayMode="Overlay"
            IsPaneOpen="{x:Bind ViewModel.IsSettingsPaneOpen, Mode=TwoWay}"
            OpenPaneLength="372"
            PaneClosed="OnSettingsPaneClosed"
            PanePlacement="Right"
            PaneBackground="Transparent">
            <SplitView.Pane>
                <Border
                    Margin="12,0,0,0"
                    Background="{ThemeResource SettingsPaneBackgroundBrush}"
                    BorderBrush="{ThemeResource SettingsPaneBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                    <controls:ApplicationSettingsPane
                        CloseCommand="{x:Bind ViewModel.CloseSettingsPaneCommand, Mode=OneWay}"
                        ViewModel="{x:Bind ViewModel, Mode=OneWay}" />
                </Border>
            </SplitView.Pane>

            <SplitView.Content>
                <Grid ColumnSpacing="11">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="76" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Width="76"
                        Padding="4,8"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource SurfaceCardBorderStyle}">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Spacing="6">
                            <ToggleButton
                                x:Name="VideoWorkspaceToggle"
                                Command="{x:Bind ViewModel.SwitchToVideoWorkspaceCommand, Mode=OneWay}"
                                IsChecked="{x:Bind ViewModel.IsVideoWorkspaceSelected, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.CanModifyInputs, Mode=OneWay}"
                                Style="{StaticResource WorkspaceModeToggleButtonStyle}">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Spacing="5">
                                    <SymbolIcon
                                        x:Name="VideoWorkspaceIcon"
                                        HorizontalAlignment="Center"
                                        Symbol="Video" />
                                    <TextBlock
                                        x:Name="VideoWorkspaceText"
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="视频" />
                                </StackPanel>
                            </ToggleButton>

                            <ToggleButton
                                x:Name="AudioWorkspaceToggle"
                                Command="{x:Bind ViewModel.SwitchToAudioWorkspaceCommand, Mode=OneWay}"
                                IsChecked="{x:Bind ViewModel.IsAudioWorkspaceSelected, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.CanModifyInputs, Mode=OneWay}"
                                Style="{StaticResource WorkspaceModeToggleButtonStyle}">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Spacing="5">
                                    <SymbolIcon
                                        x:Name="AudioWorkspaceIcon"
                                        HorizontalAlignment="Center"
                                        Symbol="Audio" />
                                    <TextBlock
                                        x:Name="AudioWorkspaceText"
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="音频" />
                                </StackPanel>
                            </ToggleButton>
                        </StackPanel>
                    </Border>

                    <Grid
                        Grid.Column="1"
                        ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.55*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="16"
                        Style="{StaticResource SurfaceCardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock
                                        Style="{StaticResource SectionTitleTextStyle}"
                                        Text="待处理队列" />
                                    <TextBlock
                                        Opacity="0.72"
                                        Text="{x:Bind ViewModel.QueueDragDropHintText, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                    <TextBlock
                                        Opacity="0.72"
                                        Text="{x:Bind ViewModel.SupportedInputFormatsHint, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <Border
                                    Grid.Column="1"
                                    Padding="12,8"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource SubtleBadgeBorderStyle}">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Width="26"
                                            Height="26"
                                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                            CornerRadius="13">
                                            <SymbolIcon
                                                Symbol="Bullets"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Spacing="0">
                                            <TextBlock
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="队列状态" />
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Text="{x:Bind ViewModel.QueueSummaryText, Mode=OneWay}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <ListView
                                Grid.Row="1"
                                ItemsSource="{x:Bind ViewModel.ImportItems, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:MediaJobViewModel">
                                        <Border
                                            Margin="0,0,0,10"
                                            Padding="14"
                                            Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                            CornerRadius="16">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border
                                                    Width="30"
                                                    Height="30"
                                                    VerticalAlignment="Top"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    CornerRadius="15">
                                                    <FontIcon
                                                        FontSize="16"
                                                        Glyph="{x:Bind StatusGlyph, Mode=OneWay}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel
                                                    Grid.Column="1"
                                                    Spacing="4">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Text="{x:Bind InputFileName}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Opacity="0.72"
                                                            Text="{x:Bind StatusText, Mode=OneWay}" />
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                                            <Button MinWidth="68" Padding="10,4" Command="{Binding ElementName=RootWindow, Path=ViewModel.ShowMediaDetailsCommand}" CommandParameter="{x:Bind}" Content="详情" />
                                                            <Button MinWidth="68" Padding="10,4" Command="{Binding ElementName=RootWindow, Path=ViewModel.RemoveImportItemCommand}" CommandParameter="{x:Bind}" Content="移除" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <TextBlock
                                                        Opacity="0.68"
                                                        Text="{x:Bind InputDirectory}"
                                                        TextWrapping="WrapWholeWords" />
                                                    <TextBlock
                                                        Text="{x:Bind PlannedOutputPath, Mode=OneWay}"
                                                        TextWrapping="WrapWholeWords" />
                                                    <TextBlock
                                                        Opacity="0.72"
                                                        Text="{x:Bind StatusDetail, Mode=OneWay}"
                                                        TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid x:Name="RightPanel" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border
                            Padding="16"
                            Style="{StaticResource SurfaceCardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="处理设置" />

                                <StackPanel
                                    Spacing="6"
                                    Visibility="{x:Bind ViewModel.VideoProcessingModeVisibility, Mode=OneWay}">
                                    <TextBlock Text="处理模式" />
                                    <ComboBox
                                        DisplayMemberPath="DisplayName"
                                        IsEnabled="{x:Bind ViewModel.CanModifyInputs, Mode=OneWay}"
                                        ItemsSource="{x:Bind ViewModel.ProcessingModes, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedProcessingMode, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel
                                    Spacing="6"
                                    Visibility="{x:Bind ViewModel.AudioProcessingModeVisibility, Mode=OneWay}">
                                    <TextBlock Text="处理模式" />
                                    <Border
                                        Padding="12,10"
                                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                        CornerRadius="14">
                                        <StackPanel Spacing="4">
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Text="{x:Bind ViewModel.FixedProcessingModeDisplayName, Mode=OneWay}" />
                                            <TextBlock
                                                Opacity="0.72"
                                                Text="{x:Bind ViewModel.FixedProcessingModeDescription, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="目标格式" />
                                    <ComboBox
                                        DisplayMemberPath="DisplayName"
                                        IsEnabled="{x:Bind ViewModel.CanModifyInputs, Mode=OneWay}"
                                        ItemsSource="{x:Bind ViewModel.AvailableOutputFormats, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedOutputFormat, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="输出目录" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox
                                            IsReadOnly="True"
                                            PlaceholderText="留空时使用原文件夹输出"
                                            Text="{x:Bind ViewModel.OutputDirectory, Mode=OneWay}" />
                                        <Button
                                            Grid.Column="1"
                                            Command="{x:Bind ViewModel.SelectOutputDirectoryCommand, Mode=OneWay}"
                                            Content="选择文件夹" />
                                        <Button
                                            Grid.Column="2"
                                            Command="{x:Bind ViewModel.ClearOutputDirectoryCommand, Mode=OneWay}"
                                            Content="清空" />
                                    </Grid>
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="留空时使用原文件夹输出；设置后，处理结果会统一输出到所选文件夹。"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="1"
                            MinHeight="220"
                            Padding="16"
                            Style="{StaticResource SurfaceCardBorderStyle}">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="处理结果" />

                                <ListView
                                    Grid.Row="1"
                                    ItemsSource="{x:Bind ViewModel.LogEntries, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:LogEntry">
                                            <Border
                                                Margin="0,0,0,8"
                                                Padding="12,10"
                                                Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                                CornerRadius="14">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="112" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock
                                                        Opacity="0.72"
                                                        Text="{x:Bind DisplayTimestamp}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Text="{x:Bind Message}"
                                                        TextWrapping="WrapWholeWords" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>
                        </Grid>
                        <Border x:Name="DetailOverlayPanel" Background="{ThemeResource DetailOverlayBackgroundBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="22" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" Opacity="0" Visibility="Collapsed">
                            <Border.RenderTransform>
                                <CompositeTransform x:Name="DetailOverlayTransform" TranslateX="300" />
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Padding="18,18,18,16" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" MinWidth="92" Padding="12,8" Command="{Binding ElementName=RootWindow, Path=ViewModel.CloseMediaDetailsCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Back" />
                                            <TextBlock VerticalAlignment="Center" Text="返回" />
                                        </StackPanel>
                                    </Button>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.HeaderTitle}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Opacity="0.72" Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.HeaderSubtitle}" TextWrapping="WrapWholeWords" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                                <ScrollViewer Grid.Row="1" Padding="18,0,18,18" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                                    <StackPanel Spacing="16">
                                        <Border Padding="22,28" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.LoadingVisibility}">
                                            <StackPanel HorizontalAlignment="Center" Spacing="12">
                                                <ProgressRing Width="34" Height="34" IsActive="True" HorizontalAlignment="Center" />
                                                <TextBlock HorizontalAlignment="Center" Text="正在解析媒体信息..." />
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="18" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.ErrorVisibility}">
                                            <StackPanel Spacing="10">
                                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="无法解析" />
                                                <TextBlock Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.ErrorMessage}" TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Border>
                                        <StackPanel Spacing="16" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.VideoTemplateVisibility}">
                                            <Border Padding="18" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.VideoOverviewVisibility}">
                                                <StackPanel Spacing="12">
                                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="概览" />
                                                    <TextBlock Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.OverviewSummaryText}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>
                                            <Border Padding="18" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.VideoInfoVisibility}">
                                                <StackPanel Spacing="12">
                                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="视频信息" />
                                                    <TextBlock Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.VideoSummaryText}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>
                                            <Border Padding="18" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AudioInfoVisibility}">
                                                <StackPanel Spacing="12">
                                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="音频信息" />
                                                    <TextBlock Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AudioSummaryText}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>
                                            <Border Padding="18" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AdvancedVisibility}">
                                                <StackPanel Spacing="12">
                                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="高级信息" />
                                                    <TextBlock Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AdvancedSummaryText}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Spacing="16" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AudioTemplateVisibility}">
                                            <Border Padding="18" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AudioOverviewVisibility}">
                                                <StackPanel Spacing="12">
                                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="音频概览" />
                                                    <TextBlock Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AudioOverviewSummaryText}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>
                                            <Border Padding="18" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AudioInfoVisibility}">
                                                <StackPanel Spacing="12">
                                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="音频信息" />
                                                    <TextBlock Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AudioSummaryText}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                    </Grid>
                </Grid>
            </SplitView.Content>
        </SplitView>
    </Grid>
</Window>
