<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Vidvix.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Vidvix.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Vidvix.Core.Models"
    xmlns:viewModels="using:Vidvix.ViewModels"
    mc:Ignorable="d"
    Title="Vidvix">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootLayout"
        AllowDrop="True"
        DragOver="OnRootDragOver"
        Drop="OnRootDrop"
        Loaded="OnRootLayoutLoaded"
        Padding="16,8,16,16"
        RequestedTheme="{x:Bind ViewModel.RequestedTheme, Mode=OneWay}"
        RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Padding="14,12"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    MaxWidth="360"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="12">
                    <Image
                        Width="40"
                        Height="40"
                        Source="ms-appx:///Assets/logo.png"
                        Stretch="Uniform" />

                    <StackPanel
                        MaxWidth="308"
                        VerticalAlignment="Center"
                        Spacing="2">
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="快速开始" />
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            MaxLines="2"
                            Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            Opacity="0.72"
                            Text="支持导入文件、文件夹，也支持直接拖拽到窗口"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>

                <CommandBar
                    Grid.Column="1"
                    Background="Transparent"
                    DefaultLabelPosition="Right"
                    IsDynamicOverflowEnabled="True"
                    VerticalAlignment="Center">
                    <AppBarButton Command="{x:Bind ViewModel.SelectFilesCommand}" Label="导入文件">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="OpenFile" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.SelectFolderCommand}" Label="导入文件夹">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Folder" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.ClearQueueCommand}" Label="清空列表">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Delete" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <AppBarButton Command="{x:Bind ViewModel.ExecuteProcessingCommand}" Label="开始处理">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Play" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.CancelExecutionCommand}" Label="取消任务">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Cancel" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <AppBarButton Command="{x:Bind ViewModel.ToggleSettingsPaneCommand}" Label="应用设置">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Setting" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>

                <Border
                    Grid.Column="2"
                    Padding="12,8"
                    VerticalAlignment="Center"
                    Style="{StaticResource SubtleBadgeBorderStyle}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.RuntimeIndicatorToolTip, Mode=OneWay}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid
                            Width="24"
                            Height="24"
                            VerticalAlignment="Center">
                            <Border
                                x:Name="RuntimePulseHalo"
                                Width="24"
                                Height="24"
                                Background="{x:Bind ViewModel.RuntimeIndicatorPulseBrush, Mode=OneWay}"
                                CornerRadius="12"
                                Opacity="0.18" />

                            <Border
                                x:Name="RuntimeIndicatorCore"
                                Width="12"
                                Height="12"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{x:Bind ViewModel.RuntimeIndicatorBrush, Mode=OneWay}"
                                CornerRadius="6" />
                        </Grid>

                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="1">
                            <TextBlock
                                Style="{StaticResource CaptionTextStyle}"
                                Text="运行环境" />
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.RuntimeIndicatorText, Mode=OneWay}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <SplitView
            Grid.Row="1"
            CompactPaneLength="0"
            DisplayMode="Overlay"
            IsPaneOpen="{x:Bind ViewModel.IsSettingsPaneOpen, Mode=TwoWay}"
            OpenPaneLength="372"
            PanePlacement="Right"
            PaneBackground="Transparent">
            <SplitView.Pane>
                <Border
                    Margin="12,0,0,0"
                    Background="{ThemeResource SettingsPaneBackgroundBrush}"
                    BorderBrush="{ThemeResource SettingsPaneBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                    <controls:ApplicationSettingsPane
                        CloseCommand="{x:Bind ViewModel.CloseSettingsPaneCommand, Mode=OneWay}"
                        ViewModel="{x:Bind ViewModel, Mode=OneWay}" />
                </Border>
            </SplitView.Pane>

            <SplitView.Content>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.55*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Padding="16"
                        Style="{StaticResource SurfaceCardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock
                                        Style="{StaticResource SectionTitleTextStyle}"
                                        Text="待处理队列" />
                                    <TextBlock
                                        Opacity="0.72"
                                        Text="支持拖拽视频文件或文件夹到窗口任意位置"
                                        TextWrapping="WrapWholeWords" />
                                    <TextBlock
                                        Opacity="0.72"
                                        Text="{x:Bind ViewModel.SupportedInputFormatsHint, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <Border
                                    Grid.Column="1"
                                    Padding="12,8"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource SubtleBadgeBorderStyle}">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Width="26"
                                            Height="26"
                                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                            CornerRadius="13">
                                            <SymbolIcon
                                                Symbol="Bullets"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Spacing="0">
                                            <TextBlock
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="队列状态" />
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Text="{x:Bind ViewModel.QueueSummaryText, Mode=OneWay}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <ListView
                                Grid.Row="1"
                                ItemsSource="{x:Bind ViewModel.ImportItems, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:MediaJobViewModel">
                                        <Border
                                            Margin="0,0,0,10"
                                            Padding="14"
                                            Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                            CornerRadius="16">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border
                                                    Width="30"
                                                    Height="30"
                                                    VerticalAlignment="Top"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    CornerRadius="15">
                                                    <FontIcon
                                                        FontSize="16"
                                                        Glyph="{x:Bind StatusGlyph}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel
                                                    Grid.Column="1"
                                                    Spacing="4">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Text="{x:Bind InputFileName}" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            Opacity="0.72"
                                                            Text="{x:Bind StatusText}" />
                                                    </Grid>
                                                    <TextBlock
                                                        Opacity="0.68"
                                                        Text="{x:Bind InputDirectory}"
                                                        TextWrapping="WrapWholeWords" />
                                                    <TextBlock
                                                        Text="{x:Bind PlannedOutputPath}"
                                                        TextWrapping="WrapWholeWords" />
                                                    <TextBlock
                                                        Opacity="0.72"
                                                        Text="{x:Bind StatusDetail}"
                                                        TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Grid
                        Grid.Column="1"
                        RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border
                            Padding="16"
                            Style="{StaticResource SurfaceCardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="处理设置" />

                                <StackPanel Spacing="6">
                                    <TextBlock Text="处理模式" />
                                    <ComboBox
                                        DisplayMemberPath="DisplayName"
                                        IsEnabled="{x:Bind ViewModel.CanModifyInputs, Mode=OneWay}"
                                        ItemsSource="{x:Bind ViewModel.ProcessingModes, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedProcessingMode, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="目标格式" />
                                    <ComboBox
                                        DisplayMemberPath="DisplayName"
                                        IsEnabled="{x:Bind ViewModel.CanModifyInputs, Mode=OneWay}"
                                        ItemsSource="{x:Bind ViewModel.AvailableOutputFormats, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedOutputFormat, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="1"
                            MinHeight="220"
                            Padding="16"
                            Style="{StaticResource SurfaceCardBorderStyle}">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="处理结果" />

                                <ListView
                                    Grid.Row="1"
                                    ItemsSource="{x:Bind ViewModel.LogEntries, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:LogEntry">
                                            <Border
                                                Margin="0,0,0,8"
                                                Padding="12,10"
                                                Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                                CornerRadius="14">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="72" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock
                                                        Opacity="0.72"
                                                        Text="{x:Bind DisplayTimestamp}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Text="{x:Bind Message}"
                                                        TextWrapping="WrapWholeWords" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </SplitView.Content>
        </SplitView>
    </Grid>
</Window>