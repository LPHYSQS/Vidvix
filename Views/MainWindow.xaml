<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Vidvix.Views.MainWindow"
    x:Name="RootWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Vidvix.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Vidvix.Core.Models"
    xmlns:views="using:Vidvix.Views"
    xmlns:viewModels="using:Vidvix.ViewModels"
    mc:Ignorable="d"
    Title="Vidvix">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootLayout"
        AllowDrop="True"
        DragOver="OnRootDragOver"
        Drop="OnRootDrop"
        Loaded="OnRootLayoutLoaded"
        Padding="16,8,16,16"
        RequestedTheme="{x:Bind ViewModel.RequestedTheme, Mode=OneWay}"
        RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            MinHeight="96"
            Padding="14,12"
            Style="{StaticResource SurfaceCardBorderStyle}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    MaxWidth="360"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="12">
                    <Image
                        Width="40"
                        Height="40"
                        Source="ms-appx:///Assets/logo.png"
                        Stretch="Uniform" />

                    <StackPanel
                        MaxWidth="308"
                        VerticalAlignment="Center"
                        Spacing="2">
                        <TextBlock
                            AutomationProperties.AutomationId="MainWindowWorkspaceHeaderCaption"
                            Style="{StaticResource CaptionTextStyle}"
                            Text="{x:Bind ViewModel.WorkspaceHeaderCaption, Mode=OneWay}" />
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            MaxLines="1"
                            Text="{x:Bind ViewModel.WorkspaceHeaderTitle, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                        <TextBlock
                            MaxLines="1"
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.WorkspaceHeaderDescription, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                    </StackPanel>
                </StackPanel>

                <CommandBar
                    Grid.Column="1"
                    Background="Transparent"
                    DefaultLabelPosition="Right"
                    IsDynamicOverflowEnabled="True"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.ProcessingWorkspaceVisibility, Mode=OneWay}">
                    <AppBarButton Command="{x:Bind ViewModel.SelectFilesCommand}" Label="{x:Bind ViewModel.MainWindowImportFilesButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="OpenFile" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.SelectFolderCommand}" Label="{x:Bind ViewModel.MainWindowImportFolderButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Folder" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.ClearQueueCommand}" Label="{x:Bind ViewModel.MainWindowClearQueueButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Delete" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <AppBarButton Command="{x:Bind ViewModel.ExecuteProcessingCommand}" Label="{x:Bind ViewModel.MainWindowStartProcessingButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Play" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.CancelExecutionCommand}" Label="{x:Bind ViewModel.MainWindowCancelTaskButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Cancel" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <AppBarButton Command="{x:Bind ViewModel.ToggleSettingsPaneCommand}" Label="{x:Bind ViewModel.MainWindowSettingsButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Setting" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>

                <CommandBar
                    Grid.Column="1"
                    Background="Transparent"
                    DefaultLabelPosition="Right"
                    IsDynamicOverflowEnabled="True"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                    <AppBarButton Command="{x:Bind ViewModel.ToggleSettingsPaneCommand}" Label="{x:Bind ViewModel.MainWindowSettingsButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Setting" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>

                <CommandBar
                    Grid.Column="1"
                    Background="Transparent"
                    DefaultLabelPosition="Right"
                    IsDynamicOverflowEnabled="True"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.SplitAudioWorkspaceVisibility, Mode=OneWay}">
                    <AppBarButton Command="{x:Bind ViewModel.SplitAudioWorkspace.SelectInputCommand, Mode=OneWay}" Label="{x:Bind ViewModel.MainWindowImportFilesButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="OpenFile" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.SplitAudioWorkspace.RemoveInputCommand, Mode=OneWay}" Label="{x:Bind ViewModel.MainWindowClearCurrentButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Delete" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <AppBarButton Command="{x:Bind ViewModel.SplitAudioWorkspace.StartSeparationCommand, Mode=OneWay}" Label="{x:Bind ViewModel.MainWindowStartSplitAudioButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Play" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.SplitAudioWorkspace.CancelSeparationCommand, Mode=OneWay}" Label="{x:Bind ViewModel.MainWindowCancelTaskButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Cancel" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <AppBarButton Command="{x:Bind ViewModel.ToggleSettingsPaneCommand}" Label="{x:Bind ViewModel.MainWindowSettingsButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Setting" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>

                <CommandBar
                    Grid.Column="1"
                    Background="Transparent"
                    DefaultLabelPosition="Right"
                    IsDynamicOverflowEnabled="True"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                    <AppBarButton Command="{x:Bind ViewModel.ToggleSettingsPaneCommand}" Label="{x:Bind ViewModel.MainWindowSettingsButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Setting" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>

                <CommandBar
                    Grid.Column="1"
                    Background="Transparent"
                    DefaultLabelPosition="Right"
                    IsDynamicOverflowEnabled="True"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.TrimWorkspaceVisibility, Mode=OneWay}">
                    <AppBarButton Command="{x:Bind ViewModel.TrimWorkspace.SelectVideoCommand}" Label="{x:Bind ViewModel.MainWindowImportFilesButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="OpenFile" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.TrimWorkspace.RemoveVideoCommand}" Label="{x:Bind ViewModel.TrimWorkspace.RemoveInputCommandText, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Delete" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <AppBarButton Command="{x:Bind ViewModel.TrimWorkspace.ExportTrimCommand}" Label="{x:Bind ViewModel.MainWindowExportTrimSegmentButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Save" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.TrimWorkspace.CancelExportCommand}" Label="{x:Bind ViewModel.MainWindowCancelExportButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Cancel" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <AppBarButton Command="{x:Bind ViewModel.ToggleSettingsPaneCommand}" Label="{x:Bind ViewModel.MainWindowSettingsButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Setting" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>

                <CommandBar
                    Grid.Column="1"
                    Background="Transparent"
                    DefaultLabelPosition="Right"
                    IsDynamicOverflowEnabled="True"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.MergeWorkspaceVisibility, Mode=OneWay}">
                    <AppBarButton Command="{x:Bind ViewModel.MergeWorkspace.StartVideoJoinProcessingCommand, Mode=OneWay}" Label="{x:Bind ViewModel.MainWindowStartProcessingButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Play" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.MergeWorkspace.CancelVideoJoinProcessingCommand, Mode=OneWay}" Label="{x:Bind ViewModel.MainWindowCancelTaskButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Cancel" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <AppBarButton Command="{x:Bind ViewModel.ToggleSettingsPaneCommand}" Label="{x:Bind ViewModel.MainWindowSettingsButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Setting" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>

                <CommandBar
                    Grid.Column="1"
                    Background="Transparent"
                    DefaultLabelPosition="Right"
                    IsDynamicOverflowEnabled="True"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.TerminalWorkspaceVisibility, Mode=OneWay}">
                    <AppBarButton Command="{x:Bind ViewModel.ToggleSettingsPaneCommand}" Label="{x:Bind ViewModel.MainWindowSettingsButtonLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Setting" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>

            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Padding="14,12"
            Style="{StaticResource SurfaceCardBorderStyle}"
            Visibility="{x:Bind ViewModel.ExecutionProgressVisibility, Mode=OneWay}">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="34"
                    Height="34"
                    VerticalAlignment="Top"
                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                    CornerRadius="17">
                    <SymbolIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Symbol="Sync" />
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="2">
                            <TextBlock
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind ViewModel.ExecutionProgressTitleText, Mode=OneWay}" />
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.ExecutionProgressSummaryText, Mode=OneWay}" />
                        </StackPanel>

                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.ExecutionProgressPercentText, Mode=OneWay}" />
                    </Grid>

                    <ProgressBar
                        Height="6"
                        IsIndeterminate="{x:Bind ViewModel.IsExecutionProgressIndeterminate, Mode=OneWay}"
                        Maximum="100"
                        Value="{x:Bind ViewModel.ExecutionProgressValue, Mode=OneWay}" />

                    <TextBlock
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.ExecutionProgressCurrentItemText, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />

                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{x:Bind ViewModel.ExecutionProgressDetailText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Padding="14,12"
            Style="{StaticResource SurfaceCardBorderStyle}"
            Visibility="{x:Bind ViewModel.SplitAudioWorkspace.ProgressVisibility, Mode=OneWay}">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="34"
                    Height="34"
                    VerticalAlignment="Top"
                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                    CornerRadius="17">
                    <SymbolIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Symbol="Audio" />
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.SplitAudioWorkspace.ProgressSummaryText, Mode=OneWay}" />

                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.SplitAudioWorkspace.ProgressPercentText, Mode=OneWay}" />
                    </Grid>

                    <ProgressBar
                        Height="6"
                        IsIndeterminate="{x:Bind ViewModel.SplitAudioWorkspace.IsProgressIndeterminate, Mode=OneWay}"
                        Maximum="100"
                        Value="{x:Bind ViewModel.SplitAudioWorkspace.ProgressValue, Mode=OneWay}" />

                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{x:Bind ViewModel.SplitAudioWorkspace.ProgressDetailText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Padding="14,12"
            Style="{StaticResource SurfaceCardBorderStyle}"
            Visibility="{x:Bind ViewModel.TrimWorkspace.ExportProgressVisibility, Mode=OneWay}">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="34"
                    Height="34"
                    VerticalAlignment="Top"
                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                    CornerRadius="17">
                    <SymbolIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Symbol="Cut" />
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.TrimWorkspace.ExportProgressSummaryText, Mode=OneWay}" />

                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.TrimWorkspace.ExportProgressPercentText, Mode=OneWay}" />
                    </Grid>

                    <ProgressBar
                        Height="6"
                        IsIndeterminate="{x:Bind ViewModel.TrimWorkspace.IsExportProgressIndeterminate, Mode=OneWay}"
                        Maximum="100"
                        Value="{x:Bind ViewModel.TrimWorkspace.ExportProgressValue, Mode=OneWay}" />

                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{x:Bind ViewModel.TrimWorkspace.ExportProgressDetailText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Padding="14,12"
            Style="{StaticResource SurfaceCardBorderStyle}"
            Visibility="{Binding ElementName=RootWindow, Path=ViewModel.MergeWorkspace.ProcessingProgressVisibility}">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="34"
                    Height="34"
                    VerticalAlignment="Top"
                    Background="{ThemeResource ControlFillColorTertiaryBrush}"
                    CornerRadius="17">
                    <Path
                        Width="18"
                        Height="18"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Stretch="Uniform"
                        Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                        StrokeThickness="1.9"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        Data="M4 7H10L14 12 M4 17H10L14 12 M14 12H20 M17 9L20 12L17 15" />
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{Binding ElementName=RootWindow, Path=ViewModel.MergeWorkspace.ProcessingProgressSummaryText}" />

                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Opacity="0.72"
                            Text="{Binding ElementName=RootWindow, Path=ViewModel.MergeWorkspace.ProcessingProgressPercentText}" />
                    </Grid>

                    <ProgressBar
                        Height="6"
                        IsIndeterminate="{Binding ElementName=RootWindow, Path=ViewModel.MergeWorkspace.IsProcessingProgressIndeterminate}"
                        Maximum="100"
                        Value="{Binding ElementName=RootWindow, Path=ViewModel.MergeWorkspace.ProcessingProgressValue}" />

                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{Binding ElementName=RootWindow, Path=ViewModel.MergeWorkspace.ProcessingProgressDetailText}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>
        </Border>

        <SplitView
            Grid.Row="2"
            CompactPaneLength="0"
            DisplayMode="Overlay"
            IsPaneOpen="{x:Bind ViewModel.IsSettingsPaneOpen, Mode=TwoWay}"
            OpenPaneLength="372"
            PaneClosed="OnSettingsPaneClosed"
            PanePlacement="Right"
            PaneBackground="Transparent">
            <SplitView.Pane>
                <Border
                    Margin="12,0,0,0"
                    Background="{ThemeResource SettingsPaneBackgroundBrush}"
                    BorderBrush="{ThemeResource SettingsPaneBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                    <controls:ApplicationSettingsPane
                        CloseCommand="{x:Bind ViewModel.CloseSettingsPaneCommand, Mode=OneWay}"
                        ViewModel="{x:Bind ViewModel, Mode=OneWay}" />
                </Border>
            </SplitView.Pane>

            <SplitView.Content>
                <Grid ColumnSpacing="11">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="76" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Width="76"
                        Padding="4,8"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource SurfaceCardBorderStyle}">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Spacing="6">
                            <ToggleButton
                                x:Name="VideoWorkspaceToggle"
                                Command="{x:Bind ViewModel.SwitchToVideoWorkspaceCommand, Mode=OneWay}"
                                IsChecked="{x:Bind ViewModel.IsVideoWorkspaceSelected, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.CanModifyInputs, Mode=OneWay}"
                                Style="{StaticResource WorkspaceModeToggleButtonStyle}">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Spacing="5">
                                    <SymbolIcon
                                        x:Name="VideoWorkspaceIcon"
                                        HorizontalAlignment="Center"
                                        Symbol="Video" />
                                    <TextBlock
                                        x:Name="VideoWorkspaceText"
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.VideoWorkspaceButtonText, Mode=OneWay}" />
                                </StackPanel>
                            </ToggleButton>

                            <ToggleButton
                                x:Name="AudioWorkspaceToggle"
                                Command="{x:Bind ViewModel.SwitchToAudioWorkspaceCommand, Mode=OneWay}"
                                IsChecked="{x:Bind ViewModel.IsAudioWorkspaceSelected, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.CanModifyInputs, Mode=OneWay}"
                                Style="{StaticResource WorkspaceModeToggleButtonStyle}">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Spacing="5">
                                    <SymbolIcon
                                        x:Name="AudioWorkspaceIcon"
                                        HorizontalAlignment="Center"
                                        Symbol="Audio" />
                                    <TextBlock
                                        x:Name="AudioWorkspaceText"
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.AudioWorkspaceButtonText, Mode=OneWay}" />
                                </StackPanel>
                            </ToggleButton>

                            <ToggleButton
                                x:Name="TrimWorkspaceToggle"
                                Command="{x:Bind ViewModel.SwitchToTrimWorkspaceCommand, Mode=OneWay}"
                                IsChecked="{x:Bind ViewModel.IsTrimWorkspaceSelected, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.CanModifyInputs, Mode=OneWay}"
                                Style="{StaticResource WorkspaceModeToggleButtonStyle}">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Spacing="5">
                                    <SymbolIcon
                                        x:Name="TrimWorkspaceIcon"
                                        HorizontalAlignment="Center"
                                        Symbol="Cut" />
                                    <TextBlock
                                        x:Name="TrimWorkspaceText"
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.TrimWorkspaceButtonText, Mode=OneWay}" />
                                </StackPanel>
                            </ToggleButton>

                            <ToggleButton
                                x:Name="MergeWorkspaceToggle"
                                Command="{x:Bind ViewModel.SwitchToMergeWorkspaceCommand, Mode=OneWay}"
                                IsChecked="{x:Bind ViewModel.IsMergeWorkspaceSelected, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.CanModifyInputs, Mode=OneWay}"
                                Style="{StaticResource WorkspaceModeToggleButtonStyle}">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Spacing="5">
                                    <Path
                                        x:Name="MergeWorkspaceIcon"
                                        HorizontalAlignment="Center"
                                        Width="18"
                                        Height="18"
                                        Stretch="Uniform"
                                        Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                        StrokeThickness="1.9"
                                        StrokeStartLineCap="Round"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round"
                                        Data="M4 7H10L14 12 M4 17H10L14 12 M14 12H20 M17 9L20 12L17 15" />
                                    <TextBlock
                                        x:Name="MergeWorkspaceText"
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.MergeWorkspaceButtonText, Mode=OneWay}" />
                                </StackPanel>
                            </ToggleButton>

                            <ToggleButton
                                x:Name="SplitAudioWorkspaceToggle"
                                Command="{x:Bind ViewModel.SwitchToSplitAudioWorkspaceCommand, Mode=OneWay}"
                                IsChecked="{x:Bind ViewModel.IsSplitAudioWorkspaceSelected, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.CanModifyInputs, Mode=OneWay}"
                                Style="{StaticResource WorkspaceModeToggleButtonStyle}">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Spacing="5">
                                    <Path
                                        x:Name="SplitAudioWorkspaceIcon"
                                        HorizontalAlignment="Center"
                                        Width="18"
                                        Height="18"
                                        Stretch="Uniform"
                                        Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                        StrokeThickness="1.9"
                                        StrokeStartLineCap="Round"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round"
                                        Data="M4 10H8 M8 10L12 6 M8 10L12 14 M12 6H15 M12 14H15 M5.5 7V13 M16.5 4V8 M16.5 12V16" />
                                    <TextBlock
                                        x:Name="SplitAudioWorkspaceText"
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.SplitAudioWorkspaceButtonText, Mode=OneWay}" />
                                </StackPanel>
                            </ToggleButton>

                            <ToggleButton
                                x:Name="TerminalWorkspaceToggle"
                                Command="{x:Bind ViewModel.SwitchToTerminalWorkspaceCommand, Mode=OneWay}"
                                IsChecked="{x:Bind ViewModel.IsTerminalWorkspaceSelected, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.CanModifyInputs, Mode=OneWay}"
                                Style="{StaticResource WorkspaceModeToggleButtonStyle}">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Spacing="5">
                                    <Path
                                        x:Name="TerminalWorkspaceIcon"
                                        HorizontalAlignment="Center"
                                        Width="18"
                                        Height="18"
                                        Stretch="Uniform"
                                        Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                        StrokeThickness="1.9"
                                        StrokeStartLineCap="Round"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round"
                                        Data="M4 6.5H20V17.5H4Z M7.5 10L10.5 12L7.5 14 M12.5 14H16.5" />
                                    <TextBlock
                                        x:Name="TerminalWorkspaceText"
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.TerminalWorkspaceButtonText, Mode=OneWay}" />
                                </StackPanel>
                            </ToggleButton>
                        </StackPanel>
                    </Border>

                    <Grid
                        Grid.Column="1"
                        ColumnSpacing="12"
                        Visibility="{x:Bind ViewModel.ProcessingWorkspaceVisibility, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.55*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="16"
                        Style="{StaticResource SurfaceCardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock
                                        Style="{StaticResource SectionTitleTextStyle}"
                                        Text="{x:Bind ViewModel.QueueSectionTitleText, Mode=OneWay}" />
                                    <TextBlock
                                        Opacity="0.72"
                                        Text="{x:Bind ViewModel.QueueDragDropHintText, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                    <TextBlock
                                        Opacity="0.72"
                                        Text="{x:Bind ViewModel.SupportedInputFormatsHint, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <Border
                                    Grid.Column="1"
                                    Padding="12,8"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource SubtleBadgeBorderStyle}">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Width="26"
                                            Height="26"
                                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                            CornerRadius="13">
                                            <SymbolIcon
                                                Symbol="Bullets"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Spacing="0">
                                            <TextBlock
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="{x:Bind ViewModel.QueueStatusTitleText, Mode=OneWay}" />
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Text="{x:Bind ViewModel.QueueSummaryText, Mode=OneWay}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <ListView
                                Grid.Row="1"
                                ItemsSource="{x:Bind ViewModel.ImportItems, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:MediaJobViewModel">
                                        <Border
                                            Margin="0,0,0,10"
                                            Padding="14"
                                            Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                            CornerRadius="16">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border
                                                    Width="30"
                                                    Height="30"
                                                    VerticalAlignment="Top"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    CornerRadius="15">
                                                    <FontIcon
                                                        FontSize="16"
                                                        Glyph="{x:Bind StatusGlyph, Mode=OneWay}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                                </Border>

                                                <Border
                                                    Grid.Column="1"
                                                    Width="152"
                                                    Height="86"
                                                    VerticalAlignment="Top"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    CornerRadius="12">
                                                    <Grid>
                                                        <Image
                                                            Margin="1"
                                                            Source="{x:Bind ThumbnailSource, Mode=OneWay}"
                                                            Opacity="0.24"
                                                            Stretch="UniformToFill"
                                                            Visibility="{x:Bind ThumbnailVisibility, Mode=OneWay}" />
                                                        <Border
                                                            Margin="1"
                                                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                            Opacity="0.42"
                                                            Visibility="{x:Bind ThumbnailVisibility, Mode=OneWay}" />
                                                        <Image
                                                            Margin="8"
                                                            Source="{x:Bind ThumbnailSource, Mode=OneWay}"
                                                            Stretch="Uniform"
                                                            Visibility="{x:Bind ThumbnailVisibility, Mode=OneWay}" />
                                                        <StackPanel
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Spacing="6"
                                                            Visibility="{x:Bind ThumbnailPlaceholderVisibility, Mode=OneWay}">
                                                            <ProgressRing
                                                                Width="18"
                                                                Height="18"
                                                                IsActive="{x:Bind IsThumbnailLoading, Mode=OneWay}"
                                                                Visibility="{x:Bind ThumbnailProgressVisibility, Mode=OneWay}" />
                                                            <SymbolIcon
                                                                HorizontalAlignment="Center"
                                                                Symbol="{x:Bind ThumbnailPlaceholderSymbol, Mode=OneWay}"
                                                                Visibility="{x:Bind ThumbnailPlaceholderIconVisibility, Mode=OneWay}" />
                                                            <TextBlock
                                                                FontSize="12"
                                                                Opacity="0.72"
                                                                Text="{x:Bind ThumbnailPlaceholderText, Mode=OneWay}"
                                                                TextAlignment="Center"
                                                                TextWrapping="WrapWholeWords" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <StackPanel
                                                    Grid.Column="2"
                                                    Spacing="4">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Text="{x:Bind InputFileName}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Opacity="0.72"
                                                            Text="{x:Bind StatusText, Mode=OneWay}" />
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                                            <Button MinWidth="68" Padding="10,4" Command="{Binding ElementName=RootWindow, Path=ViewModel.ShowMediaDetailsCommand}" CommandParameter="{x:Bind}" Content="{Binding ElementName=RootWindow, Path=ViewModel.QueueItemDetailsButtonText}" />
                                                            <Button MinWidth="68" Padding="10,4" Command="{Binding ElementName=RootWindow, Path=ViewModel.RemoveImportItemCommand}" CommandParameter="{x:Bind}" Content="{Binding ElementName=RootWindow, Path=ViewModel.QueueItemRemoveButtonText}" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <TextBlock
                                                        Opacity="0.68"
                                                        Text="{x:Bind InputDirectory}"
                                                        TextWrapping="WrapWholeWords" />
                                                    <TextBlock
                                                        Text="{x:Bind PlannedOutputPath, Mode=OneWay}"
                                                        TextWrapping="WrapWholeWords" />
                                                    <TextBlock
                                                        Opacity="0.72"
                                                        Text="{x:Bind StatusDetail, Mode=OneWay}"
                                                        TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid x:Name="RightPanel" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border
                            Padding="16"
                            Style="{StaticResource SurfaceCardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="{x:Bind ViewModel.ProcessingSettingsTitleText, Mode=OneWay}" />

                                <StackPanel
                                    Spacing="6"
                                    Visibility="{x:Bind ViewModel.VideoProcessingModeVisibility, Mode=OneWay}">
                                    <TextBlock Text="{x:Bind ViewModel.ProcessingModeLabelText, Mode=OneWay}" />
                                    <ComboBox
                                        DisplayMemberPath="DisplayName"
                                        IsEnabled="{x:Bind ViewModel.CanModifyInputs, Mode=OneWay}"
                                        ItemsSource="{x:Bind ViewModel.ProcessingModes, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedProcessingMode, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel
                                    Spacing="6"
                                    Visibility="{x:Bind ViewModel.AudioProcessingModeVisibility, Mode=OneWay}">
                                    <TextBlock Text="{x:Bind ViewModel.ProcessingModeLabelText, Mode=OneWay}" />
                                    <Border
                                        Padding="12,10"
                                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                        CornerRadius="14">
                                        <StackPanel Spacing="4">
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Text="{x:Bind ViewModel.FixedProcessingModeDisplayName, Mode=OneWay}" />
                                            <TextBlock
                                                Opacity="0.72"
                                                Text="{x:Bind ViewModel.FixedProcessingModeDescription, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="{x:Bind ViewModel.OutputFormatLabelText, Mode=OneWay}" />
                                    <ComboBox
                                        DisplayMemberPath="DisplayName"
                                        IsEnabled="{x:Bind ViewModel.CanModifyInputs, Mode=OneWay}"
                                        ItemsSource="{x:Bind ViewModel.AvailableOutputFormats, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedOutputFormat, Mode=TwoWay}" />
                                    <TextBlock
                                        Opacity="0.72"
                                        Text="{x:Bind ViewModel.SelectedOutputFormatDescription, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="{x:Bind ViewModel.OutputDirectoryLabelText, Mode=OneWay}" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox
                                            IsReadOnly="True"
                                            PlaceholderText="{x:Bind ViewModel.OutputDirectoryPlaceholderText, Mode=OneWay}"
                                            Text="{x:Bind ViewModel.OutputDirectory, Mode=OneWay}" />
                                        <Button
                                            Grid.Column="1"
                                            Command="{x:Bind ViewModel.SelectOutputDirectoryCommand, Mode=OneWay}"
                                            Content="{x:Bind ViewModel.SelectOutputDirectoryButtonText, Mode=OneWay}" />
                                        <Button
                                            Grid.Column="2"
                                            Command="{x:Bind ViewModel.ClearOutputDirectoryCommand, Mode=OneWay}"
                                            Content="{x:Bind ViewModel.ClearOutputDirectoryButtonText, Mode=OneWay}" />
                                    </Grid>
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="{x:Bind ViewModel.OutputDirectoryHintText, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="1"
                            MinHeight="220"
                            Padding="16"
                            Style="{StaticResource SurfaceCardBorderStyle}">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="{x:Bind ViewModel.ProcessingResultsTitleText, Mode=OneWay}" />

                                <ListView
                                    Grid.Row="1"
                                    ItemsSource="{x:Bind ViewModel.LogEntries, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:LogEntry">
                                            <Border
                                                Margin="0,0,0,8"
                                                Padding="12,10"
                                                Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                                CornerRadius="14">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="112" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock
                                                        Opacity="0.72"
                                                        Text="{x:Bind DisplayTimestamp}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Text="{x:Bind Message}"
                                                        TextWrapping="WrapWholeWords" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>
                        </Grid>
                        <Border x:Name="DetailOverlayPanel" Background="{ThemeResource DetailOverlayBackgroundBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="22" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" Opacity="0" Visibility="Collapsed">
                            <Border.RenderTransform>
                                <CompositeTransform x:Name="DetailOverlayTransform" TranslateX="300" />
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Padding="18,18,18,16" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" MinWidth="92" Padding="12,8" Command="{Binding ElementName=RootWindow, Path=ViewModel.CloseMediaDetailsCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Back" />
                                            <TextBlock VerticalAlignment="Center" Text="返回" />
                                        </StackPanel>
                                    </Button>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.HeaderTitle}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Opacity="0.72" Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.HeaderSubtitle}" TextWrapping="WrapWholeWords" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button Grid.Column="2" MinWidth="92" Padding="12,8" VerticalAlignment="Center" Command="{Binding ElementName=RootWindow, Path=ViewModel.CopyAllMediaDetailsCommand}" Content="复制全部" />
                                </Grid>
                                <ScrollViewer Grid.Row="1" Padding="18,0,18,18" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                                    <StackPanel Spacing="16">
                                        <Border Padding="22,28" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.LoadingVisibility}">
                                            <StackPanel HorizontalAlignment="Center" Spacing="12">
                                                <ProgressRing Width="34" Height="34" IsActive="True" HorizontalAlignment="Center" />
                                                <TextBlock HorizontalAlignment="Center" Text="正在解析媒体信息..." />
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="18" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.ErrorVisibility}">
                                            <StackPanel Spacing="10">
                                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="无法解析" />
                                                <TextBlock Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.ErrorMessage}" TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Border>
                                        <StackPanel Spacing="16" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.VideoTemplateVisibility}">
                                            <Border Padding="18" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.VideoOverviewVisibility}">
                                                <StackPanel Spacing="12">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="概览" />
                                                        <Button Grid.Column="1" MinWidth="72" Padding="10,4" Command="{Binding ElementName=RootWindow, Path=ViewModel.CopyMediaDetailSectionCommand}" CommandParameter="Overview" Content="复制" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.OverviewSummaryText}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>
                                            <Border Padding="18" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.VideoInfoVisibility}">
                                                <StackPanel Spacing="12">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="视频信息" />
                                                        <Button Grid.Column="1" MinWidth="72" Padding="10,4" Command="{Binding ElementName=RootWindow, Path=ViewModel.CopyMediaDetailSectionCommand}" CommandParameter="Video" Content="复制" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.VideoSummaryText}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>
                                            <Border Padding="18" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AudioInfoVisibility}">
                                                <StackPanel Spacing="12">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="音频信息" />
                                                        <Button Grid.Column="1" MinWidth="72" Padding="10,4" Command="{Binding ElementName=RootWindow, Path=ViewModel.CopyMediaDetailSectionCommand}" CommandParameter="Audio" Content="复制" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AudioSummaryText}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>
                                            <Border Padding="18" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AdvancedVisibility}">
                                                <StackPanel Spacing="12">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="高级信息" />
                                                        <Button Grid.Column="1" MinWidth="72" Padding="10,4" Command="{Binding ElementName=RootWindow, Path=ViewModel.CopyMediaDetailSectionCommand}" CommandParameter="Advanced" Content="复制" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AdvancedSummaryText}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Spacing="16" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AudioTemplateVisibility}">
                                            <Border Padding="18" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AudioOverviewVisibility}">
                                                <StackPanel Spacing="12">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="音频概览" />
                                                        <Button Grid.Column="1" MinWidth="72" Padding="10,4" Command="{Binding ElementName=RootWindow, Path=ViewModel.CopyMediaDetailSectionCommand}" CommandParameter="AudioOverview" Content="复制" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AudioOverviewSummaryText}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>
                                            <Border Padding="18" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="18" Visibility="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AudioInfoVisibility}">
                                                <StackPanel Spacing="12">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="音频信息" />
                                                        <Button Grid.Column="1" MinWidth="72" Padding="10,4" Command="{Binding ElementName=RootWindow, Path=ViewModel.CopyMediaDetailSectionCommand}" CommandParameter="Audio" Content="复制" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding ElementName=RootWindow, Path=ViewModel.DetailPanel.AudioSummaryText}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                        <Border x:Name="CopyToastPanel" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,18,0,0" Padding="14,10" Background="{ThemeResource DetailOverlaySectionBrush}" BorderBrush="{ThemeResource DetailOverlayBorderBrush}" BorderThickness="1" CornerRadius="16" IsHitTestVisible="False" Opacity="0" Visibility="Collapsed">
                            <Border.RenderTransform>
                                <CompositeTransform x:Name="CopyToastTransform" TranslateY="-18" />
                            </Border.RenderTransform>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon VerticalAlignment="Center" Symbol="Accept" />
                                <TextBlock x:Name="CopyToastText" VerticalAlignment="Center" FontWeight="SemiBold" Text="已复制" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    </Grid>

                    <controls:VideoTrimWorkspaceView
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        ViewModel="{x:Bind ViewModel.TrimWorkspace, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.TrimWorkspaceVisibility, Mode=OneWay}" />

                    <views:MergePage
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        ViewModel="{x:Bind ViewModel.MergeWorkspace, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.MergeWorkspaceVisibility, Mode=OneWay}" />

                    <views:SplitAudioPage
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        ViewModel="{x:Bind ViewModel.SplitAudioWorkspace, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.SplitAudioWorkspaceVisibility, Mode=OneWay}" />

                    <views:TerminalPage
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        ViewModel="{x:Bind ViewModel.TerminalWorkspace, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.TerminalWorkspaceVisibility, Mode=OneWay}" />
                </Grid>
            </SplitView.Content>
        </SplitView>
    </Grid>
</Window>
