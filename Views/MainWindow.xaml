<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Vidvix.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Vidvix.Core.Models"
    mc:Ignorable="d"
    Title="Vidvix">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock
                Style="{ThemeResource TitleLargeTextBlockStyle}"
                Text="Vidvix FFmpeg Demo" />
            <TextBlock
                Opacity="0.78"
                Style="{ThemeResource BodyTextBlockStyle}"
                Text="Select a video file, build a reusable FFmpeg command, and validate the async execution pipeline." />
        </StackPanel>

        <Grid
            Grid.Row="1"
            ColumnSpacing="12"
            RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="8">
                <TextBlock FontWeight="SemiBold" Text="Input File" />
                <TextBox
                    IsReadOnly="True"
                    PlaceholderText="Choose a source video file"
                    Text="{x:Bind ViewModel.SelectedInputFilePath, Mode=OneWay}" />
            </StackPanel>

            <Button
                Grid.Row="0"
                Grid.Column="1"
                Command="{x:Bind ViewModel.SelectInputFileCommand}"
                Content="Browse"
                VerticalAlignment="Bottom" />

            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="8">
                <TextBlock FontWeight="SemiBold" Text="Output File" />
                <TextBox
                    IsReadOnly="True"
                    PlaceholderText="The generated MP3 output path appears here"
                    Text="{x:Bind ViewModel.OutputFilePath, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Spacing="12">
            <CommandBar DefaultLabelPosition="Right">
                <AppBarButton Command="{x:Bind ViewModel.ExecuteConversionCommand}" Label="Convert to MP3">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Play" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Command="{x:Bind ViewModel.CancelExecutionCommand}" Label="Cancel">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Cancel" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBar>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ProgressRing
                    Width="24"
                    Height="24"
                    IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />

                <TextBlock
                    Grid.Column="1"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    TextWrapping="Wrap"
                    VerticalAlignment="Center" />
            </Grid>
        </StackPanel>

        <Grid Grid.Row="3" RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock FontWeight="SemiBold" Text="Execution Log" />

            <ListView
                Grid.Row="1"
                HorizontalAlignment="Stretch"
                ItemsSource="{x:Bind ViewModel.LogEntries, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:LogEntry">
                        <Grid ColumnSpacing="12" Padding="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                Opacity="0.72"
                                Text="{x:Bind DisplayTimestamp}" />
                            <TextBlock
                                Grid.Column="1"
                                FontWeight="SemiBold"
                                Text="{x:Bind DisplayLevel}" />
                            <TextBlock
                                Grid.Column="2"
                                Text="{x:Bind Message}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Window>
