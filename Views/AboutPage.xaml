<Page
    x:Class="Vidvix.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:Vidvix.ViewModels"
    x:Name="RootPage"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="DefaultAboutSectionRadioButtonStyle"
            TargetType="RadioButton"
            BasedOn="{StaticResource MergeModeSegmentRadioButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="72" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="LightAboutSectionRadioButtonStyle"
            TargetType="RadioButton">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="72" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="#30000000" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid
                            x:Name="LayoutRoot"
                            MinHeight="{TemplateBinding MinHeight}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="InteractionSurface.Background" Value="#FFF7F7F7" />
                                            <Setter Target="InteractionSurface.BorderBrush" Value="#42000000" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="InteractionSurface.Opacity" Value="0.94" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Opacity" Value="0.45" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>

                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Unchecked">
                                        <VisualState.Setters>
                                            <Setter Target="InteractionSurface.Background" Value="#FFFFFFFF" />
                                            <Setter Target="InteractionSurface.BorderBrush" Value="#30000000" />
                                            <Setter Target="SelectionIndicator.Opacity" Value="0" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Checked">
                                        <VisualState.Setters>
                                            <Setter Target="InteractionSurface.Background" Value="#FFF8FBFF" />
                                            <Setter Target="InteractionSurface.BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                            <Setter Target="SelectionIndicator.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Indeterminate">
                                        <VisualState.Setters>
                                            <Setter Target="InteractionSurface.Background" Value="#FFF8FBFF" />
                                            <Setter Target="InteractionSurface.BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                            <Setter Target="SelectionIndicator.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Border
                                x:Name="InteractionSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="1"
                                Padding="{TemplateBinding Padding}">
                                <ContentPresenter
                                    x:Name="ContentHost"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    ContentTransitions="{TemplateBinding ContentTransitions}" />
                            </Border>

                            <Border
                                x:Name="SelectionIndicator"
                                Width="34"
                                Height="3"
                                Margin="0,0,0,5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="999"
                                Opacity="0" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style
            x:Key="AboutContentCardStyle"
            TargetType="Border"
            BasedOn="{StaticResource SurfaceCardBorderStyle}">
            <Setter Property="CornerRadius" Value="24" />
        </Style>
        <Style
            x:Key="AboutInfoLabelTextStyle"
            TargetType="TextBlock"
            BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="Opacity" Value="0.72" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>
    </Page.Resources>

    <Grid
        Padding="12,8,8,0"
        RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <RadioButton
                x:Name="AboutSectionRadioButton"
                Command="{x:Bind ViewModel.SelectAboutSectionCommand, Mode=OneWay}"
                GroupName="AboutSections"
                IsChecked="{x:Bind ViewModel.IsAboutSectionSelected, Mode=OneWay}"
                Style="{StaticResource DefaultAboutSectionRadioButtonStyle}">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.AboutSectionTabText, Mode=OneWay}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="WrapWholeWords" />
            </RadioButton>

            <RadioButton
                x:Name="LicenseSectionRadioButton"
                Grid.Column="1"
                Command="{x:Bind ViewModel.SelectLicenseSectionCommand, Mode=OneWay}"
                GroupName="AboutSections"
                IsChecked="{x:Bind ViewModel.IsLicenseSectionSelected, Mode=OneWay}"
                Style="{StaticResource DefaultAboutSectionRadioButtonStyle}">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.LicenseSectionTabText, Mode=OneWay}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="WrapWholeWords" />
            </RadioButton>

            <RadioButton
                x:Name="PrivacySectionRadioButton"
                Grid.Column="2"
                Command="{x:Bind ViewModel.SelectPrivacySectionCommand, Mode=OneWay}"
                GroupName="AboutSections"
                IsChecked="{x:Bind ViewModel.IsPrivacySectionSelected, Mode=OneWay}"
                Style="{StaticResource DefaultAboutSectionRadioButtonStyle}">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.PrivacySectionTabText, Mode=OneWay}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="WrapWholeWords" />
            </RadioButton>
        </Grid>

        <Border
            Grid.Row="1"
            Padding="30,28"
            Style="{StaticResource AboutContentCardStyle}">
            <ScrollViewer
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Enabled">
                <Grid MinHeight="360">
                    <Grid
                        ColumnSpacing="52"
                        RowSpacing="28"
                        VerticalAlignment="Top"
                        Visibility="{x:Bind ViewModel.AboutDetailsVisibility, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="0"
                            Spacing="6">
                            <TextBlock
                                Style="{StaticResource AboutInfoLabelTextStyle}"
                                Text="{x:Bind ViewModel.ApplicationNameLabelText, Mode=OneWay}" />
                            <TextBlock
                                ContextRequested="OnSelectableTextContextRequested"
                                FontSize="30"
                                FontWeight="SemiBold"
                                IsTextSelectionEnabled="True"
                                Tag="{x:Bind ViewModel.ApplicationNameValueText, Mode=OneWay}"
                                Text="{x:Bind ViewModel.ApplicationNameValueText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords">
                                <TextBlock.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            Click="OnCopySelectableTextClick"
                                            Text="{x:Bind ViewModel.CopyContextMenuText, Mode=OneWay}" />
                                    </MenuFlyout>
                                </TextBlock.ContextFlyout>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="1"
                            Spacing="6">
                            <TextBlock
                                Style="{StaticResource AboutInfoLabelTextStyle}"
                                Text="{x:Bind ViewModel.ApplicationVersionLabelText, Mode=OneWay}" />
                            <TextBlock
                                ContextRequested="OnSelectableTextContextRequested"
                                FontSize="17"
                                IsTextSelectionEnabled="True"
                                Tag="{x:Bind ViewModel.ApplicationVersionValueText, Mode=OneWay}"
                                Text="{x:Bind ViewModel.ApplicationVersionValueText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords">
                                <TextBlock.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            Click="OnCopySelectableTextClick"
                                            Text="{x:Bind ViewModel.CopyContextMenuText, Mode=OneWay}" />
                                    </MenuFlyout>
                                </TextBlock.ContextFlyout>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="0"
                            Spacing="6">
                            <TextBlock
                                Style="{StaticResource AboutInfoLabelTextStyle}"
                                Text="{x:Bind ViewModel.ApplicationAuthorLabelText, Mode=OneWay}" />
                            <TextBlock
                                ContextRequested="OnSelectableTextContextRequested"
                                FontSize="17"
                                IsTextSelectionEnabled="True"
                                Tag="{x:Bind ViewModel.ApplicationAuthorValueText, Mode=OneWay}"
                                Text="{x:Bind ViewModel.ApplicationAuthorValueText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords">
                                <TextBlock.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            Click="OnCopySelectableTextClick"
                                            Text="{x:Bind ViewModel.CopyContextMenuText, Mode=OneWay}" />
                                    </MenuFlyout>
                                </TextBlock.ContextFlyout>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="1"
                            Spacing="6">
                            <TextBlock
                                Style="{StaticResource AboutInfoLabelTextStyle}"
                                Text="{x:Bind ViewModel.RepositoryLabelText, Mode=OneWay}" />
                            <TextBlock
                                ContextRequested="OnSelectableTextContextRequested"
                                FontSize="17"
                                IsTextSelectionEnabled="True"
                                Tag="{x:Bind ViewModel.RepositoryUrlText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords">
                                <TextBlock.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            Click="OnCopySelectableTextClick"
                                            Text="{x:Bind ViewModel.CopyContextMenuText, Mode=OneWay}" />
                                    </MenuFlyout>
                                </TextBlock.ContextFlyout>
                                <Hyperlink NavigateUri="{x:Bind ViewModel.RepositoryUri, Mode=OneWay}">
                                    <Run Text="{x:Bind ViewModel.RepositoryUrlText, Mode=OneWay}" />
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel
                            Grid.Row="2"
                            Grid.Column="0"
                            Spacing="6">
                            <TextBlock
                                Style="{StaticResource AboutInfoLabelTextStyle}"
                                Text="{x:Bind ViewModel.ContactAuthorLabelText, Mode=OneWay}" />
                            <TextBlock
                                ContextRequested="OnSelectableTextContextRequested"
                                FontSize="17"
                                IsTextSelectionEnabled="True"
                                Tag="{x:Bind ViewModel.AuthorEmailText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords">
                                <TextBlock.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            Click="OnCopySelectableTextClick"
                                            Text="{x:Bind ViewModel.CopyContextMenuText, Mode=OneWay}" />
                                    </MenuFlyout>
                                </TextBlock.ContextFlyout>
                                <Hyperlink NavigateUri="{x:Bind ViewModel.AuthorEmailUri, Mode=OneWay}">
                                    <Run Text="{x:Bind ViewModel.AuthorEmailText, Mode=OneWay}" />
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel
                            Grid.Row="2"
                            Grid.Column="1"
                            Spacing="6">
                            <TextBlock
                                Style="{StaticResource AboutInfoLabelTextStyle}"
                                Text="{x:Bind ViewModel.WebsiteLabelText, Mode=OneWay}" />
                            <TextBlock
                                ContextRequested="OnSelectableTextContextRequested"
                                FontSize="17"
                                IsTextSelectionEnabled="True"
                                Tag="{x:Bind ViewModel.WebsiteUrlText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords">
                                <TextBlock.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            Click="OnCopySelectableTextClick"
                                            Text="{x:Bind ViewModel.CopyContextMenuText, Mode=OneWay}" />
                                    </MenuFlyout>
                                </TextBlock.ContextFlyout>
                                <Hyperlink NavigateUri="{x:Bind ViewModel.WebsiteUri, Mode=OneWay}">
                                    <Run Text="{x:Bind ViewModel.WebsiteUrlText, Mode=OneWay}" />
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <StackPanel
                        MaxWidth="640"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="14"
                        Visibility="{x:Bind ViewModel.SectionPlaceholderVisibility, Mode=OneWay}">
                        <TextBlock
                            FontSize="28"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            Text="{x:Bind ViewModel.SelectedSectionTitleText, Mode=OneWay}"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.SelectedSectionDescriptionText, Mode=OneWay}"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
