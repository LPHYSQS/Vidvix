<Page
    x:Class="Vidvix.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:Vidvix.ViewModels"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="AboutSectionRadioButtonStyle"
            TargetType="RadioButton"
            BasedOn="{StaticResource MergeModeSegmentRadioButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="72" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style
            x:Key="AboutContentCardStyle"
            TargetType="Border"
            BasedOn="{StaticResource SurfaceCardBorderStyle}">
            <Setter Property="CornerRadius" Value="24" />
        </Style>
    </Page.Resources>

    <Grid
        Padding="12,8,8,0"
        RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <RadioButton
                Command="{x:Bind ViewModel.SelectAboutSectionCommand, Mode=OneWay}"
                GroupName="AboutSections"
                IsChecked="{x:Bind ViewModel.IsAboutSectionSelected, Mode=OneWay}"
                Style="{StaticResource AboutSectionRadioButtonStyle}">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.AboutSectionTabText, Mode=OneWay}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="WrapWholeWords" />
            </RadioButton>

            <RadioButton
                Grid.Column="1"
                Command="{x:Bind ViewModel.SelectLicenseSectionCommand, Mode=OneWay}"
                GroupName="AboutSections"
                IsChecked="{x:Bind ViewModel.IsLicenseSectionSelected, Mode=OneWay}"
                Style="{StaticResource AboutSectionRadioButtonStyle}">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.LicenseSectionTabText, Mode=OneWay}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="WrapWholeWords" />
            </RadioButton>

            <RadioButton
                Grid.Column="2"
                Command="{x:Bind ViewModel.SelectPrivacySectionCommand, Mode=OneWay}"
                GroupName="AboutSections"
                IsChecked="{x:Bind ViewModel.IsPrivacySectionSelected, Mode=OneWay}"
                Style="{StaticResource AboutSectionRadioButtonStyle}">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.PrivacySectionTabText, Mode=OneWay}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="WrapWholeWords" />
            </RadioButton>
        </Grid>

        <Border
            Grid.Row="1"
            Padding="30,28"
            Style="{StaticResource AboutContentCardStyle}">
            <ScrollViewer
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Enabled">
                <Grid MinHeight="360">
                    <StackPanel
                        MaxWidth="640"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="14">
                        <TextBlock
                            FontSize="28"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            Text="{x:Bind ViewModel.SelectedSectionTitleText, Mode=OneWay}"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.SelectedSectionDescriptionText, Mode=OneWay}"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
