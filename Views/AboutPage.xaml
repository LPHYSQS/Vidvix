<Page
    x:Class="Vidvix.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:Vidvix.ViewModels"
    x:Name="RootPage"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="DefaultAboutSectionRadioButtonStyle"
            TargetType="RadioButton"
            BasedOn="{StaticResource MergeModeSegmentRadioButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="72" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="LightAboutSectionRadioButtonStyle"
            TargetType="RadioButton">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="72" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="#30000000" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid
                            x:Name="LayoutRoot"
                            MinHeight="{TemplateBinding MinHeight}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="InteractionSurface.Background" Value="#FFF7F7F7" />
                                            <Setter Target="InteractionSurface.BorderBrush" Value="#42000000" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="InteractionSurface.Opacity" Value="0.94" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Opacity" Value="0.45" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>

                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Unchecked">
                                        <VisualState.Setters>
                                            <Setter Target="InteractionSurface.Background" Value="#FFFFFFFF" />
                                            <Setter Target="InteractionSurface.BorderBrush" Value="#30000000" />
                                            <Setter Target="SelectionIndicator.Opacity" Value="0" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Checked">
                                        <VisualState.Setters>
                                            <Setter Target="InteractionSurface.Background" Value="#FFF8FBFF" />
                                            <Setter Target="InteractionSurface.BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                            <Setter Target="SelectionIndicator.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Indeterminate">
                                        <VisualState.Setters>
                                            <Setter Target="InteractionSurface.Background" Value="#FFF8FBFF" />
                                            <Setter Target="InteractionSurface.BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                            <Setter Target="SelectionIndicator.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Border
                                x:Name="InteractionSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="1"
                                Padding="{TemplateBinding Padding}">
                                <ContentPresenter
                                    x:Name="ContentHost"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    ContentTransitions="{TemplateBinding ContentTransitions}" />
                            </Border>

                            <Border
                                x:Name="SelectionIndicator"
                                Width="34"
                                Height="3"
                                Margin="0,0,0,5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="999"
                                Opacity="0" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style
            x:Key="AboutContentCardStyle"
            TargetType="Border"
            BasedOn="{StaticResource SurfaceCardBorderStyle}">
            <Setter Property="CornerRadius" Value="24" />
        </Style>
        <Style
            x:Key="AboutInfoLabelTextStyle"
            TargetType="TextBlock"
            BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="Opacity" Value="0.72" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>
        <Style
            x:Key="AboutInsetCardStyle"
            TargetType="Border"
            BasedOn="{StaticResource InsetSurfaceCardBorderStyle}">
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="24,22" />
        </Style>
        <Style
            x:Key="AboutSectionTitleTextStyle"
            TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>
        <Style
            x:Key="AboutSectionBodyTextStyle"
            TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.78" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>
        <DataTemplate
            x:Key="AboutSummaryItemTemplate"
            x:DataType="viewModels:AboutSummaryItem">
            <StackPanel
                Margin="0,0,0,18"
                HorizontalAlignment="Left"
                Spacing="4">
                <TextBlock
                    FontSize="15"
                    FontWeight="SemiBold"
                    TextAlignment="Left"
                    Text="{x:Bind Title}"
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    Style="{StaticResource AboutSectionBodyTextStyle}"
                    Text="{x:Bind Description}" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate
            x:Key="AboutOpenSourceItemTemplate"
            x:DataType="viewModels:AboutOpenSourceItem">
            <StackPanel
                Margin="0,0,0,18"
                HorizontalAlignment="Left"
                Spacing="5">
                <TextBlock
                    FontSize="15"
                    FontWeight="SemiBold"
                    TextAlignment="Left"
                    TextWrapping="WrapWholeWords">
                    <Hyperlink NavigateUri="{x:Bind LinkUri}">
                        <Run Text="{x:Bind Title}" />
                    </Hyperlink>
                </TextBlock>
                <TextBlock
                    Style="{StaticResource AboutInfoLabelTextStyle}"
                    TextAlignment="Left"
                    TextWrapping="WrapWholeWords">
                    <Hyperlink NavigateUri="{x:Bind LinkUri}">
                        <Run Text="{x:Bind LinkUrl}" />
                    </Hyperlink>
                </TextBlock>
                <TextBlock
                    Style="{StaticResource AboutSectionBodyTextStyle}"
                    Text="{x:Bind Description}" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate
            x:Key="AboutLicenseItemTemplate"
            x:DataType="viewModels:AboutLicenseItem">
            <StackPanel
                Margin="0,0,0,22"
                HorizontalAlignment="Left"
                Spacing="5">
                <TextBlock
                    FontSize="16"
                    FontWeight="SemiBold"
                    TextAlignment="Left"
                    TextWrapping="WrapWholeWords">
                    <Hyperlink NavigateUri="{x:Bind LinkUri}">
                        <Run Text="{x:Bind Title}" />
                    </Hyperlink>
                </TextBlock>
                <TextBlock
                    Style="{StaticResource AboutInfoLabelTextStyle}"
                    Text="{x:Bind VersionDisplay}" />
                <TextBlock
                    Style="{StaticResource AboutInfoLabelTextStyle}"
                    Text="{x:Bind LicenseDisplay}" />
                <TextBlock
                    Style="{StaticResource AboutInfoLabelTextStyle}"
                    Text="{x:Bind NoticeDisplay}" />
                <TextBlock
                    Style="{StaticResource AboutInfoLabelTextStyle}"
                    TextWrapping="WrapWholeWords">
                    <Run Text="{x:Bind SourceLabelText}" />
                    <Run Text=": " />
                    <Hyperlink NavigateUri="{x:Bind LinkUri}">
                        <Run Text="{x:Bind LinkUrl}" />
                    </Hyperlink>
                </TextBlock>
                <TextBlock
                    Style="{StaticResource AboutSectionBodyTextStyle}"
                    Text="{x:Bind Description}" />
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid
        Padding="12,8,8,0"
        RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <RadioButton
                x:Name="AboutSectionRadioButton"
                Command="{x:Bind ViewModel.SelectAboutSectionCommand, Mode=OneWay}"
                GroupName="AboutSections"
                IsChecked="{x:Bind ViewModel.IsAboutSectionSelected, Mode=OneWay}"
                Style="{StaticResource DefaultAboutSectionRadioButtonStyle}">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.AboutSectionTabText, Mode=OneWay}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="WrapWholeWords" />
            </RadioButton>

            <RadioButton
                x:Name="UpdateLogSectionRadioButton"
                Grid.Column="1"
                Command="{x:Bind ViewModel.SelectUpdateLogSectionCommand, Mode=OneWay}"
                GroupName="AboutSections"
                IsChecked="{x:Bind ViewModel.IsUpdateLogSectionSelected, Mode=OneWay}"
                Style="{StaticResource DefaultAboutSectionRadioButtonStyle}">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.UpdateLogSectionTabText, Mode=OneWay}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="WrapWholeWords" />
            </RadioButton>

            <RadioButton
                x:Name="LicenseSectionRadioButton"
                Grid.Column="2"
                Command="{x:Bind ViewModel.SelectLicenseSectionCommand, Mode=OneWay}"
                GroupName="AboutSections"
                IsChecked="{x:Bind ViewModel.IsLicenseSectionSelected, Mode=OneWay}"
                Style="{StaticResource DefaultAboutSectionRadioButtonStyle}">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.LicenseSectionTabText, Mode=OneWay}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="WrapWholeWords" />
            </RadioButton>

            <RadioButton
                x:Name="PrivacySectionRadioButton"
                Grid.Column="3"
                Command="{x:Bind ViewModel.SelectPrivacySectionCommand, Mode=OneWay}"
                GroupName="AboutSections"
                IsChecked="{x:Bind ViewModel.IsPrivacySectionSelected, Mode=OneWay}"
                Style="{StaticResource DefaultAboutSectionRadioButtonStyle}">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.PrivacySectionTabText, Mode=OneWay}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="WrapWholeWords" />
            </RadioButton>
        </Grid>

        <Border
            Grid.Row="1"
            Padding="30,28,10,28"
            Style="{StaticResource AboutContentCardStyle}">
            <ScrollViewer
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Enabled">
                <Grid
                    MinHeight="360"
                    Margin="0,0,20,0">
                    <StackPanel
                        Spacing="26"
                        VerticalAlignment="Top"
                        Visibility="{x:Bind ViewModel.AboutDetailsVisibility, Mode=OneWay}">
                        <Grid
                            ColumnSpacing="52"
                            RowSpacing="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Spacing="6">
                                <TextBlock
                                    Style="{StaticResource AboutInfoLabelTextStyle}"
                                    Text="{x:Bind ViewModel.ApplicationNameLabelText, Mode=OneWay}" />
                                <TextBlock
                                    ContextRequested="OnSelectableTextContextRequested"
                                    FontSize="30"
                                    FontWeight="SemiBold"
                                    IsTextSelectionEnabled="True"
                                    Tag="{x:Bind ViewModel.ApplicationNameValueText, Mode=OneWay}"
                                    Text="{x:Bind ViewModel.ApplicationNameValueText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords">
                                    <TextBlock.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem
                                                Click="OnCopySelectableTextClick"
                                                Text="{x:Bind ViewModel.CopyContextMenuText, Mode=OneWay}" />
                                        </MenuFlyout>
                                    </TextBlock.ContextFlyout>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="1"
                                Spacing="6">
                                <TextBlock
                                    Style="{StaticResource AboutInfoLabelTextStyle}"
                                    Text="{x:Bind ViewModel.ApplicationVersionLabelText, Mode=OneWay}" />
                                <TextBlock
                                    ContextRequested="OnSelectableTextContextRequested"
                                    FontSize="17"
                                    IsTextSelectionEnabled="True"
                                    Tag="{x:Bind ViewModel.ApplicationVersionValueText, Mode=OneWay}"
                                    Text="{x:Bind ViewModel.ApplicationVersionValueText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords">
                                    <TextBlock.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem
                                                Click="OnCopySelectableTextClick"
                                                Text="{x:Bind ViewModel.CopyContextMenuText, Mode=OneWay}" />
                                        </MenuFlyout>
                                    </TextBlock.ContextFlyout>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="0"
                                Spacing="6">
                                <TextBlock
                                    Style="{StaticResource AboutInfoLabelTextStyle}"
                                    Text="{x:Bind ViewModel.ApplicationAuthorLabelText, Mode=OneWay}" />
                                <TextBlock
                                    ContextRequested="OnSelectableTextContextRequested"
                                    FontSize="17"
                                    IsTextSelectionEnabled="True"
                                    Tag="{x:Bind ViewModel.ApplicationAuthorValueText, Mode=OneWay}"
                                    Text="{x:Bind ViewModel.ApplicationAuthorValueText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords">
                                    <TextBlock.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem
                                                Click="OnCopySelectableTextClick"
                                                Text="{x:Bind ViewModel.CopyContextMenuText, Mode=OneWay}" />
                                        </MenuFlyout>
                                    </TextBlock.ContextFlyout>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="1"
                                Spacing="6">
                                <TextBlock
                                    Style="{StaticResource AboutInfoLabelTextStyle}"
                                    Text="{x:Bind ViewModel.RepositoryLabelText, Mode=OneWay}" />
                                <TextBlock
                                    ContextRequested="OnSelectableTextContextRequested"
                                    FontSize="17"
                                    IsTextSelectionEnabled="True"
                                    Tag="{x:Bind ViewModel.RepositoryUrlText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords">
                                    <TextBlock.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem
                                                Click="OnCopySelectableTextClick"
                                                Text="{x:Bind ViewModel.CopyContextMenuText, Mode=OneWay}" />
                                        </MenuFlyout>
                                    </TextBlock.ContextFlyout>
                                    <Hyperlink NavigateUri="{x:Bind ViewModel.RepositoryUri, Mode=OneWay}">
                                        <Run Text="{x:Bind ViewModel.RepositoryUrlText, Mode=OneWay}" />
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="0"
                                Spacing="6">
                                <TextBlock
                                    Style="{StaticResource AboutInfoLabelTextStyle}"
                                    Text="{x:Bind ViewModel.ContactAuthorLabelText, Mode=OneWay}" />
                                <TextBlock
                                    ContextRequested="OnSelectableTextContextRequested"
                                    FontSize="17"
                                    IsTextSelectionEnabled="True"
                                    Tag="{x:Bind ViewModel.AuthorEmailText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords">
                                    <TextBlock.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem
                                                Click="OnCopySelectableTextClick"
                                                Text="{x:Bind ViewModel.CopyContextMenuText, Mode=OneWay}" />
                                        </MenuFlyout>
                                    </TextBlock.ContextFlyout>
                                    <Hyperlink NavigateUri="{x:Bind ViewModel.AuthorEmailUri, Mode=OneWay}">
                                        <Run Text="{x:Bind ViewModel.AuthorEmailText, Mode=OneWay}" />
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="1"
                                Spacing="6">
                                <TextBlock
                                    Style="{StaticResource AboutInfoLabelTextStyle}"
                                    Text="{x:Bind ViewModel.WebsiteLabelText, Mode=OneWay}" />
                                <TextBlock
                                    ContextRequested="OnSelectableTextContextRequested"
                                    FontSize="17"
                                    IsTextSelectionEnabled="True"
                                    Tag="{x:Bind ViewModel.WebsiteUrlText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords">
                                    <TextBlock.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem
                                                Click="OnCopySelectableTextClick"
                                                Text="{x:Bind ViewModel.CopyContextMenuText, Mode=OneWay}" />
                                        </MenuFlyout>
                                    </TextBlock.ContextFlyout>
                                    <Hyperlink NavigateUri="{x:Bind ViewModel.WebsiteUri, Mode=OneWay}">
                                        <Run Text="{x:Bind ViewModel.WebsiteUrlText, Mode=OneWay}" />
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <Border
                            Height="1"
                            Background="{ThemeResource SurfaceCardBorderBrush}" />

                        <Border Style="{StaticResource AboutInsetCardStyle}">
                            <StackPanel
                                HorizontalAlignment="Left"
                                MaxWidth="980"
                                Spacing="10">
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    TextAlignment="Left"
                                    Text="{x:Bind ViewModel.ProductSummaryLabelText, Mode=OneWay}" />
                                <TextBlock
                                    FontSize="28"
                                    FontWeight="SemiBold"
                                    TextAlignment="Left"
                                    Text="{x:Bind ViewModel.ProductSummaryTitleText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Style="{StaticResource AboutSectionBodyTextStyle}"
                                    Text="{x:Bind ViewModel.ProductSummaryDescriptionText, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource AboutInsetCardStyle}">
                            <StackPanel Spacing="18">
                                <StackPanel
                                    HorizontalAlignment="Left"
                                    MaxWidth="980"
                                    Spacing="6">
                                    <TextBlock
                                        Style="{StaticResource AboutSectionTitleTextStyle}"
                                        Text="{x:Bind ViewModel.CapabilitySectionTitleText, Mode=OneWay}" />
                                    <TextBlock
                                        Style="{StaticResource AboutSectionBodyTextStyle}"
                                        Text="{x:Bind ViewModel.CapabilitySectionDescriptionText, Mode=OneWay}" />
                                </StackPanel>
                                <ItemsControl
                                    ItemTemplate="{StaticResource AboutSummaryItemTemplate}"
                                    ItemsSource="{x:Bind ViewModel.CapabilityItems, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource AboutInsetCardStyle}">
                            <StackPanel Spacing="18">
                                <StackPanel
                                    HorizontalAlignment="Left"
                                    MaxWidth="980"
                                    Spacing="6">
                                    <TextBlock
                                        Style="{StaticResource AboutSectionTitleTextStyle}"
                                        Text="{x:Bind ViewModel.OpenSourceSectionTitleText, Mode=OneWay}" />
                                    <TextBlock
                                        Style="{StaticResource AboutSectionBodyTextStyle}"
                                        Text="{x:Bind ViewModel.OpenSourceSectionDescriptionText, Mode=OneWay}" />
                                </StackPanel>
                                <ItemsControl
                                    ItemTemplate="{StaticResource AboutOpenSourceItemTemplate}"
                                    ItemsSource="{x:Bind ViewModel.OpenSourceItems, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel
                        Spacing="26"
                        VerticalAlignment="Top"
                        Visibility="{x:Bind ViewModel.UpdateLogDetailsVisibility, Mode=OneWay}">
                        <Border Style="{StaticResource AboutInsetCardStyle}">
                            <StackPanel Spacing="18">
                                <StackPanel
                                    HorizontalAlignment="Left"
                                    MaxWidth="980"
                                    Spacing="10">
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        TextAlignment="Left"
                                        Text="{x:Bind ViewModel.UpdateLogSummaryLabelText, Mode=OneWay}" />
                                    <TextBlock
                                        FontSize="28"
                                        FontWeight="SemiBold"
                                        TextAlignment="Left"
                                        Text="{x:Bind ViewModel.UpdateLogSummaryTitleText, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                    <TextBlock
                                        Style="{StaticResource AboutSectionBodyTextStyle}"
                                        Text="{x:Bind ViewModel.UpdateLogSummaryDescriptionText, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel
                                    HorizontalAlignment="Left"
                                    MaxWidth="980"
                                    Spacing="6">
                                    <TextBlock
                                        Style="{StaticResource AboutSectionTitleTextStyle}"
                                        Text="{x:Bind ViewModel.UpdateLogSectionTitleText, Mode=OneWay}" />
                                    <TextBlock
                                        Style="{StaticResource AboutSectionBodyTextStyle}"
                                        Text="{x:Bind ViewModel.UpdateLogSectionDescriptionText, Mode=OneWay}" />
                                </StackPanel>

                                <ItemsControl
                                    ItemTemplate="{StaticResource AboutSummaryItemTemplate}"
                                    ItemsSource="{x:Bind ViewModel.UpdateLogItems, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel
                        Spacing="26"
                        VerticalAlignment="Top"
                        Visibility="{x:Bind ViewModel.LicenseDetailsVisibility, Mode=OneWay}">
                        <Border Style="{StaticResource AboutInsetCardStyle}">
                            <StackPanel
                                HorizontalAlignment="Left"
                                MaxWidth="980"
                                Spacing="10">
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    TextAlignment="Left"
                                    Text="{x:Bind ViewModel.LicenseSummaryLabelText, Mode=OneWay}" />
                                <TextBlock
                                    FontSize="28"
                                    FontWeight="SemiBold"
                                    TextAlignment="Left"
                                    Text="{x:Bind ViewModel.LicenseSummaryTitleText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Style="{StaticResource AboutSectionBodyTextStyle}"
                                    Text="{x:Bind ViewModel.LicenseSummaryDescriptionText, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource AboutInsetCardStyle}">
                            <StackPanel Spacing="18">
                                <StackPanel
                                    HorizontalAlignment="Left"
                                    MaxWidth="980"
                                    Spacing="6">
                                    <TextBlock
                                        Style="{StaticResource AboutSectionTitleTextStyle}"
                                        Text="{x:Bind ViewModel.FirstPartyLicenseSectionTitleText, Mode=OneWay}" />
                                    <TextBlock
                                        Style="{StaticResource AboutSectionBodyTextStyle}"
                                        Text="{x:Bind ViewModel.FirstPartyLicenseSectionDescriptionText, Mode=OneWay}" />
                                </StackPanel>
                                <ItemsControl
                                    ItemTemplate="{StaticResource AboutLicenseItemTemplate}"
                                    ItemsSource="{x:Bind ViewModel.FirstPartyLicenseItems, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource AboutInsetCardStyle}">
                            <StackPanel Spacing="18">
                                <StackPanel
                                    HorizontalAlignment="Left"
                                    MaxWidth="980"
                                    Spacing="6">
                                    <TextBlock
                                        Style="{StaticResource AboutSectionTitleTextStyle}"
                                        Text="{x:Bind ViewModel.ThirdPartyLicenseSectionTitleText, Mode=OneWay}" />
                                    <TextBlock
                                        Style="{StaticResource AboutSectionBodyTextStyle}"
                                        Text="{x:Bind ViewModel.ThirdPartyLicenseSectionDescriptionText, Mode=OneWay}" />
                                </StackPanel>
                                <ItemsControl
                                    ItemTemplate="{StaticResource AboutLicenseItemTemplate}"
                                    ItemsSource="{x:Bind ViewModel.ThirdPartyLicenseItems, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource AboutInsetCardStyle}">
                            <StackPanel Spacing="18">
                                <StackPanel
                                    HorizontalAlignment="Left"
                                    MaxWidth="980"
                                    Spacing="6">
                                    <TextBlock
                                        Style="{StaticResource AboutSectionTitleTextStyle}"
                                        Text="{x:Bind ViewModel.LicenseNotesSectionTitleText, Mode=OneWay}" />
                                    <TextBlock
                                        Style="{StaticResource AboutSectionBodyTextStyle}"
                                        Text="{x:Bind ViewModel.LicenseNotesSectionDescriptionText, Mode=OneWay}" />
                                </StackPanel>
                                <ItemsControl
                                    ItemTemplate="{StaticResource AboutSummaryItemTemplate}"
                                    ItemsSource="{x:Bind ViewModel.LicenseNoteItems, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel
                        Spacing="26"
                        VerticalAlignment="Top"
                        Visibility="{x:Bind ViewModel.PrivacyDetailsVisibility, Mode=OneWay}">
                        <Border Style="{StaticResource AboutInsetCardStyle}">
                            <StackPanel
                                HorizontalAlignment="Left"
                                MaxWidth="980"
                                Spacing="10">
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    TextAlignment="Left"
                                    Text="{x:Bind ViewModel.PrivacySummaryLabelText, Mode=OneWay}" />
                                <TextBlock
                                    FontSize="28"
                                    FontWeight="SemiBold"
                                    TextAlignment="Left"
                                    Text="{x:Bind ViewModel.PrivacySummaryTitleText, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Style="{StaticResource AboutSectionBodyTextStyle}"
                                    Text="{x:Bind ViewModel.PrivacySummaryDescriptionText, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

